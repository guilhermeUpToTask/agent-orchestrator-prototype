# =============================================================================
# AIPOM / Agent Orchestrator — devcontainer environment
#
# Copy this file to `.env` at the repo root and fill in what you need:
#     cp .env.example .env
#
# The devcontainer injects THIS file into the container via the
# `--env-file ${localWorkspaceFolder}/.env` runArg (see .devcontainer/
# devcontainer.json). It is the single source of container env vars — nothing
# is hardcoded in devcontainer.json anymore.
#
# `.env` is gitignored; ONLY this `.env.example` is committed. Never put a real
# secret in `.env.example`.
#
# WHAT IS REQUIRED
#   Nothing. The default dry-run + stub path runs with an empty environment.
#   You only need vars once you go real (a master key + a provider key) or move
#   state off the defaults.
#
# WHAT BELONGS HERE
#   The environment configures WHERE things are, never HOW the system behaves.
#   Behavioral switches (reasoner.mode, agent_runner.mode, timeouts, provider/
#   model bindings) live in the SQLite config store, NOT here:
#       orchestrate config set <key> <value>
#   There is NO AGENT_MODE env var — runtime selection is data.
#
# Every variable below is read ONLY in the composition root
# (backend/src/infra/container.py) or the API server — never deep in the code.
# =============================================================================

# --- State & workspace -------------------------------------------------------

# Root state directory: the SQLite DB (orchestrator.db) and, unless
# PROJECT_REPO_DIR is set, the default workspace repo live under it.
# In the devcontainer this defaults to /root/.orchestrator (the bind-mounted
# dir that persists across rebuilds), so you normally leave it unset.
#ORCHESTRATOR_HOME=/root/.orchestrator

# The git repository task agents work on. Each plan gets a plan/<id> branch;
# each attempt runs in a worktree on task/<id>/a<n>. main is never touched.
# Defaults to <ORCHESTRATOR_HOME>/workspace-repo (auto-seeded if absent).
#PROJECT_REPO_DIR=/path/to/target/repo

# --- Secrets & auth ----------------------------------------------------------

# Fernet master key wrapping the envelope-encrypted secret store.
# ONLY needed when a real provider key must be decrypted (reasoner.mode=llm or
# agent_runner.mode=real). Dry-run/stub modes never construct the store.
# Generate one:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#ORCHESTRATOR_MASTER_KEY=

# Control-plane auth: bearer token required by the API when set; open when unset.
#ORCHESTRATOR_API_TOKEN=

# --- API server --------------------------------------------------------------

# Frontend origins allowed to read the API (incl. the SSE stream).
# Comma-separated. Defaults cover the Vite dev server (localhost:5173/5174).
#CORS_ALLOW_ORIGINS=http://localhost:5173

# JSON structured logs (default on). Set to 0 for human-readable console logs.
#LOG_JSON=1

# Per-request access logging (default on). Set to 0 to silence it.
#REQUEST_LOG=1

# --- Provider API keys -------------------------------------------------------
# NOT read at runtime — the runtime resolves keys from the encrypted catalog.
# Env keys are used only:
#   1. once, by `orchestrate seed demo --api-key-env <VAR>` to import a key into
#      the secret store (preset picks the var by convention below);
#   2. by the cost-gated real-LLM smoke test (pytest -m llm).
# Preset -> default key var: openai=OPENAI_API_KEY, openrouter=OPENROUTER_API_KEY,
#   anthropic=ANTHROPIC_API_KEY, gemini=GEMINI_API_KEY.
#OPENAI_API_KEY=
#OPENROUTER_API_KEY=
#ANTHROPIC_API_KEY=
#GEMINI_API_KEY=

# Real-provider smoke test (never runs in normal CI):
#REASONER_SMOKE_API_KEY=
#REASONER_SMOKE_BASE_URL=
#REASONER_SMOKE_MODEL=

# --- Agent CLI auth ----------------------------------------------------------
# The bundled agent CLIs (codex, grok, mimo, claude, pi, gh) authenticate via
# their own config dirs, which the devcontainer bind-mounts from the host so
# logins survive a rebuild (~/.codex, ~/.grok, ~/.mimocode, ~/.config/gh). Set
# a key here only if you drive a CLI by env var instead of an interactive login
# (e.g. pi's backend derives its key from one of the provider vars above).
#GITHUB_TOKEN=
