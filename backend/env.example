# =============================================================================
# AIPOM / Agent Orchestrator — environment configuration
#
# HOW TO USE THIS FILE
#   Nothing in the app auto-loads .env — every variable is read straight from
#   the process environment (os.environ) in the composition root. A .env file
#   just sitting here does NOTHING. You must export the vars into each shell
#   that runs `orchestrate` (the api process AND the worker process each need
#   them). Easiest:
#       cp env.example .env      # then edit
#       set -a; source .env; set +a     # export every var into THIS shell
#   Run that in every terminal (api, worker, seed), or export them from your
#   shell profile.
#
# WHAT BELONGS HERE
#   The environment configures WHERE things are, never HOW the system behaves.
#   Behavioral switches (reasoner.mode, agent_runner.mode, timeouts, provider/
#   model bindings) live in the SQLite config store:
#       orchestrate config set <key> <value>
#   There is NO AGENT_MODE env var — runtime selection is data.
#
# WHAT IS REQUIRED
#   Nothing. The default dry-run + stub path runs with an empty environment
#   (sensible defaults for all of these). You only need vars once you go real
#   (a master key + provider key) or move state off the defaults.
#
# Every variable below is read ONLY in the composition root
# (src/infra/container.py) or the API server — never deep in the code.
# =============================================================================

# --- State & workspace -------------------------------------------------------

# Root state directory: the SQLite database (orchestrator.db) and, unless
# PROJECT_REPO_DIR is set, the default workspace repo live under it.
ORCHESTRATOR_HOME=~/.orchestrator

# The git repository task agents work on. Each plan gets a plan/<id> branch;
# each attempt runs in a worktree on task/<id>/a<n>. main is never touched.
# Defaults to <ORCHESTRATOR_HOME>/workspace-repo (auto-seeded if absent).
#PROJECT_REPO_DIR=/path/to/target/repo

# --- Secrets & auth ----------------------------------------------------------

# Fernet master key wrapping the envelope-encrypted secret store.
# ONLY needed when a real provider key must be decrypted (reasoner.mode=llm
# or agent_runner.mode=real). Dry-run/stub modes never construct the store.
# Generate one:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#ORCHESTRATOR_MASTER_KEY=

# Control-plane auth: bearer token required by the API when set; open when unset.
#ORCHESTRATOR_API_TOKEN=

# --- API server --------------------------------------------------------------

# Frontend origins allowed to read the API (incl. the SSE stream).
# Comma-separated. Defaults cover the Vite dev server (localhost:5173/5174).
#CORS_ALLOW_ORIGINS=http://localhost:5173

# JSON structured logs (default on). Set to 0 for human-readable console logs.
#LOG_JSON=1

# Per-request access logging (default on). Set to 0 to silence it.
#REQUEST_LOG=1

# -----------------------------------------------------------------------------
# Provider API keys — NOT read at runtime.
# The runtime resolves keys from the encrypted catalog. Env keys are used only:
#   1. once, by `orchestrate seed demo --api-key-env <VAR>` to import a key
#      into the secret store (preset picks the var by convention below);
#   2. by the cost-gated real-LLM smoke test (pytest -m llm).
# Preset -> default key var: openai=OPENAI_API_KEY, openrouter=OPENROUTER_API_KEY,
#   anthropic=ANTHROPIC_API_KEY, gemini=GEMINI_API_KEY.
# -----------------------------------------------------------------------------
#OPENAI_API_KEY=
#OPENROUTER_API_KEY=
#ANTHROPIC_API_KEY=
#GEMINI_API_KEY=

# Real-provider smoke test (never runs in normal CI):
#REASONER_SMOKE_API_KEY=
#REASONER_SMOKE_BASE_URL=
#REASONER_SMOKE_MODEL=
