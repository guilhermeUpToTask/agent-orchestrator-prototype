# =============================================================================
# Agent Orchestrator — Environment Configuration
# Copy this file to .env and fill in the values.
# .env is loaded automatically by OrchestratorConfig (pydantic-settings).
# Environment variables always override .env values.
# =============================================================================

# -----------------------------------------------------------------------------
# Orchestrator
# -----------------------------------------------------------------------------

# Execution mode:
#   dry-run  → in-memory stubs, no Redis, no real CLI calls (default, safe for CI)
#   real     → Redis + live agent CLI calls
AGENT_MODE=dry-run

# Identity of this worker process — must be unique per worker instance.
# Used for lease ownership and log correlation.
AGENT_ID=agent-worker-001

# How long (seconds) to wait for an agent CLI to complete a task before timeout.
TASK_TIMEOUT_SECONDS=600

# -----------------------------------------------------------------------------
# Infrastructure
# -----------------------------------------------------------------------------

REDIS_URL=redis://localhost:6379/0

# Root directory for all orchestrator state.
# tasks_dir, registry_path, and workspace_dir are derived from this if not set.
ORCHESTRATOR_HOME=~/.orchestrator

# Override individual paths (optional — derived from ORCHESTRATOR_HOME if absent)
# TASKS_DIR=~/.orchestrator/tasks
# REGISTRY_PATH=~/.orchestrator/agents/registry.json
# WORKSPACE_DIR=~/.orchestrator/repos/workspaces
# REPO_URL=file://~/.orchestrator/repos/my-repo

# -----------------------------------------------------------------------------
# API Keys
# Both keys can coexist — each runtime only uses the one it needs.
# SecretStr: values are never printed in logs or repr().
# -----------------------------------------------------------------------------

# Used by: claude runtime, pi runtime (backend=anthropic, default)
ANTHROPIC_API_KEY=

# Used by: gemini runtime, pi runtime (backend=gemini)
GEMINI_API_KEY=

# Used by: pi runtime (backend=openrouter)
# Models use the format: "provider/model-id" e.g. "anthropic/claude-sonnet-4-5", "openai/gpt-4o"
OPENROUTER_API_KEY=
