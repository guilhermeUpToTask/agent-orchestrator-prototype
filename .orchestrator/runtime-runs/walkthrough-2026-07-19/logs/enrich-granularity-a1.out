item.get(\"description\"), str):\n   243\t        errors.append(f\"{where}: task 'description' must be a string\")\n   244\t    caps = item.get(\"required_capabilities\", [])\n   245\t    if not isinstance(caps, list) or not all(isinstance(c, str) for c in caps):\n   246\t        errors.append(f\"{where}: 'required_capabilities' must be a list of strings\")\n   247\t    else:\n   248\t        unknown = [c for c in caps if c not in known_caps]\n   249\t        if unknown:\n   250\t            errors.append(\n   251\t                f\"{where}: unknown capability id(s) {unknown} — use only ids \"\n   252\t                \"from the catalog (or omit required_capabilities)\"\n   253\tdef _validate_tdd_task_granularity(item: dict[str, Any], where: str) -> list[str]:\n   254\t    if item.get(\"verification_strategy\") != VerificationStrategy.TDD.value:\n   255\t        return []\n   256\t    candidates = [item.get(\"name\"), item.get(\"objective\")]\n   257\t    texts = [value.strip().lower() for value in candidates if isinstance(value, str)]\n   258\t    write_tests_only = any(\"write failing test\" in text or \"write tests for\" in text for text in texts)\n   259\t    make_tests_pass_only = any(re.fullmatch(r\"make(?:\\s+\\S+){0,8}\\s+tests?\\s+pass[.!]?\", text) for text in texts)\n   260\t    if not (write_tests_only or make_tests_pass_only):\n   261\t        return []\n   262\t    return [f\"{where}: TDD tasks must be feature-level deliverable slices; the runtime performs the red/green split per task. Do not submit a write-tests-only or make-tests-pass-only task; state the validated feature delivered instead.\"]\n   263\t\n   264\t            )\n   265\t    return errors\n   266\t\n   267\t\n   268\tdef _build_task(item: dict[str, Any], position: int, known_caps: set[str]) -> Task:\n   269\t    caps_raw = item.get(\"required_capabilities\", [])\n   270\t    caps = [c for c in caps_raw if isinstance(c, str)] if isinstance(caps_raw, list) else []\n   271\t    kept = [c