"),\nbackend/tests/integration/test_tdd_execution.py:152:            _agent(\"implementer\", \"implementation\"),\nbackend/tests/integration/test_tdd_execution.py:154:        default_id=\"implementer\",\nbackend/tests/integration/test_tdd_execution.py:170:    assert task_after_red.tdd_stage == \"implementation\"\nbackend/tests/integration/test_tdd_execution.py:181:    implementer_signal = asyncio.run(handler.handle(plan.id, after_red, uow))\nbackend/tests/integration/test_tdd_execution.py:184:        assert implementer_signal.value == \"paused\"\nbackend/tests/integration/test_tdd_execution.py:200:    assert implementer_signal.value == \"continue\", (\nbackend/tests/integration/test_tdd_execution.py:249:        role_agent_ids={\"test_author\": \"test-author\", \"implementer\": \"implementer\"},\nbackend/tests/integration/test_tdd_execution.py:283:        [_agent(\"test-author\", \"test_authoring\"), _agent(\"implementer\", \"implementation\")],\nbackend/tests/integration/test_tdd_execution.py:284:        default_id=\"implementer\",\nbackend/tests/integration/test_tdd_execution.py:352:        role_agent_ids={\nbackend/tests/integration/test_tdd_execution.py:353:            \"test_author\": \"test-author\",\nbackend/tests/integration/test_tdd_execution.py:354:            \"implementer\": \"implementer\",\nbackend/tests/integration/test_tdd_execution.py:390:            _agent(\"test-author\", \"test_authoring\"),\nbackend/tests/integration/test_tdd_execution.py:391:            _agent(\"implementer\", \"implementation\"),\nbackend/tests/integration/test_tdd_execution.py:393:        default_id=\"implementer\",\nbackend/tests/integration/test_full_cycle_llm.py:112:        test_authoring = Capability(\nbackend/tests/integration/test_full_cycle_llm.py:113:            id=\"test_authoring\", name=\"Test authoring\", description=\"authors tests\"\nbackend/tests/integration/test_full_cycle_llm.py:116:            update={\"capabilities\": [CAPS[0], implementation, test_authoring]}\nbackend/tests/integration/test_full_cycle_llm.py:119:        self.capabilities = InMemoryCapabilityRepository([*CAPS, implementation, test_authoring])\nbackend/tests/integration/test_full_cycle_llm.py:193:    assert goal.tasks[0].role_agent_ids[\"implementer\"] == \"a1\"\nbackend/tests/integration/test_runner_taxonomy.py:62:        role=\"implementer\",\nbackend/tests/integration/test_plan_run_export.py:57:                                \"role_agent_ids\": {\"implementer\": \"agent-1\"},\nbackend/tests/integration/test_plan_run_export.py:131:                    \"implementer\",\nbackend/tests/integration/test_plan_run_export.py:143:                    \"implementer\",\nbackend/tests/integration/test_plan_run_export.py:438:            \"model_role\": \"implementer\",\nbackend/tests/integration/test_agent_runner_factory.py:54:        role=\"implementer\",\nbackend/tests/integration/test_agent_runner_factory.py:264:        \"test_authoring\",\nbackend/tests/integration/test_api.py:301:    for capability_id in (\"implementation\", \"test_authoring\"):\nbackend/tests/integration/test_api.py:316:            \"role\": \"implementer\",\nbackend/tests/integration/test_api.py:326:            \"role\": \"test_author\",\nbackend/tests/integration/test_api.py:328:            \"capability_ids\": [\"test_authoring\"],\nbackend/tests/integration/test_api.py:459:                stage=task.tdd_stage,\nbackend/tests/integration/test_api.py:841:        json={\"name\": \"A\", \"role\": \"implementer\", \"model_role\": \"smart\"},\nbackend/tests/integration/test_api.py:861:                \"role\": \"implementer\",\nbackend/tests/integration/test_api.py:885:            \"role\": \"implementer\",\nbackend/tests/integration/test_api.py:897:            \"role\": \"implementer\",\nbackend/tests/integration/test_api.py:917:            \"role\": \"implementer\",\nbackend/tests/integration/test_api.py:931:        json={\"name\": \"A\", \"role\": \"implementer\", \"model_role\": \"smart\"},\nbackend/tests/integration/test_api.py:944:            \"role\": \"implementer\",\nbackend/tests/integration/test_api.py:1101:    agent = client.post(\"/api/agents\", json={\"name\": \"A\", \"role\": \"implementer\", \"model_role\": \"smart\"})\nbackend/tests/integration/test_api.py:1105:    assert client.put(f\"/api/agents/{agent_id}\", json={\"name\": \"A2\", \"role\": \"implementer\", \"model_role\": \"smart\"}).status_code == 204\nbackend/src/domain/entities/task.py:24:    role_agent_ids: dict[str, str] = {}\nbackend/src/domain/entities/task.py:126:    def tdd_stage(self) -> str:\nbackend/src/domain/entities/task.py:130:            return \"test_authoring\"\nbackend/src/domain/entities/agent_spec.py:13:    \"implementer\", \"reviewer\"). `model_role` is an indirection key into the\nbackend/src/domain/entities/README.md:40:`role` = the agent's functional job (\"test_writer\", \"implementer\", \"reviewer\").\nbackend/src/domain/services/agent_role_resolution.py:13:    TEST_AUTHOR = \"test_author\"\nbackend/src/domain/services/agent_role_resolution.py:14:    IMPLEMENTER = \"implementer\"\nbackend/src/domain/services/agent_role_resolution.py:19:    RunRole.TEST_AUTHOR: \"test_authoring\",\nbackend/src/domain/aggregates/planner_orchestrator.py:374:        role_agent_ids_by_task: dict[str, dict[str, str]],\nbackend/src/domain/aggregates/planner_orchestrator.py:389:        if not expected_task_ids or set(role_agent_ids_by_task) != expected_task_ids:\nbackend/src/domain/aggregates/planner_orchestrator.py:391:        required_roles = {\"test_author\", \"implementer\"}\nbackend/src/domain/aggregates/planner_orchestrator.py:393:            binding = role_agent_ids_by_task[task.id]\nbackend/src/domain/aggregates/planner_orchestrator.py:397:                raise InvalidEditError(\"each task requires test-author and implementer bindings\")\nbackend/src/domain/aggregates/planner_orchestrator.py:400:            task.role_agent_ids = dict(role_agent_ids_by_task[task.id])\nbackend/src/domain/aggregates/planner_orchestrator.py:401:            task.agent_id = task.role_agent_ids[\"implementer\"]\nbackend/src/app/use_cases/pause_resume.py:124:    role_agent_ids_by_task = {\nbackend/src/app/use_cases/pause_resume.py:138:        plan.retry_agent_binding(goal_id, role_agent_ids_by_task, clock.now())\nbackend/src/app/handlers/planning_handler.py:336:                        task.role_agent_ids = role_bindings[task.id]\nbackend/src/app/handlers/planning_handler.py:337:                        task.agent_id = task.role_agent_ids[\"implementer\"]\nbackend/src/app/handlers/execution_handler.py:177:                if unit.run_role == \"implementer\" and unit.task_snapshot.test_bundle is not None\nbackend/src/app/handlers/execution_handler.py:198:                if unit.run_role == \"test_author\":\nbackend/src/app/handlers/execution_handler.py:199:                    return await self._finalize_test_author(plan_id, unit, handle, uow)\nbackend/src/app/handlers/execution_handler.py:261:    def _test_author_path_allowed(path: str, strategy: VerificationStrategy) -> bool:\nbackend/src/app/handlers/execution_handler.py:273:    async def _finalize_test_author(\nbackend/src/app/handlers/execution_handler.py:294:            if not self._test_author_path_allowed(path, contract.verification_strategy)\nbackend/src/app/handlers/execution_handler.py:309:            if not self._test_author_path_allowed(path, contract.verification_strategy)\nbackend/src/app/handlers/execution_handler.py:796:                stage=failed.tdd_stage,\nbackend/src/app/handlers/execution_handler.py:848:            \"test_author\"\nbackend/src/app/handlers/execution_handler.py:852:            else \"implementer\"\nbackend/src/app/handlers/execution_handler.py:925:            \"test_author\"\nbackend/src/app/handlers/execution_handler.py:929:            else \"implementer\"\nbackend/src/app/handlers/execution_handler.py:931:        agent_id = task.role_agent_ids.get(run_role, task.agent_id)\