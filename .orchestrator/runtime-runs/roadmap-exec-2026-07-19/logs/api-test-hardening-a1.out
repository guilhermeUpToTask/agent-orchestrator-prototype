ntities.planning_artifacts import PlanStatus\n        with container.new_unit_of_work() as uow:\n            plan = uow.plans.get(plan_id)\n            plan.status = PlanStatus.IDLE\n            plan.bump_version()\n            uow.plans.save(plan)\n        committed = client.post(f\"/api/plans/{plan_id}/replanning/message\", json={\"message\": \"\"})\n        assert committed.status_code == 200\n        assert committed.json()[\"committed\"] is True\n>       assert committed.json()[\"phase\"] == PlanPhase.ARCHITECTURE.value\nE       AssertionError: assert 'replanning' == 'architecture'\nE         \nE         - architecture\nE         + replanning\n\ntests/integration/test_api.py:1061: AssertionError\n---------------------------- Captured stdout setup -----------------------------\n{\"url\": \"sqlite:////tmp/pytest-of-root/pytest-408/test_mid_running_replan_and_re0/orchestrator.db\", \"event\": \"db.engine_built\", \"request_id\": \"-\", \"level\": \"info\", \"timestamp\": \"2026-07-19T17:30:15.223887Z\"}\n{\"poll_seconds\": 0.5, \"event\": \"outbox_relay.started\", \"request_id\": \"-\", \"level\": \"info\", \"timestamp\": \"2026-07-19T17:30:15.292884Z\"}\n{\"version\": \"0.3.0\", \"event\": \"api.started\", \"request_id\": \"-\", \"level\": \"info\", \"timestamp\": \"2026-07-19T17:30:15.292980Z\"}\n----------------------------- Captured stdout call -----------------------------\n{\"request_id\": \"b00e3d589060475ab08e3c89cd8d0887\", \"method\": \"POST\", \"path\": \"/api/capabilities\", \"client_ip\": \"testclient\", \"event\": \"request_started\", \"level\": \"info\", \"timestamp\": \"2026-07-19T17:30:15.296157Z\"}\n{\"request_id\": \"b00e3d589060475ab08e3c89cd8d0887\", \"status_code\": 201, \"duration_ms\": 119.06, \"event\": \"request_finished\", \"level\": \"info\", \"timestamp\": \"2026-07-19T17:30:15.415197Z\"}\n{\"request_id\": \"24118d01cf694bf3be08542aaafbbe18\", \"method\": \"POST\", \"path\": \"/api/capabilities\", \"client_ip\": \"testclient\", \"event