PLANNING.value\n        container = dependencies.get_container()\n        from src.domain.entities.planning_artifacts import PlanStatus\n        with container.new_unit_of_work() as uow:\n            plan = uow.plans.get(plan_id)\n            plan.status = PlanStatus.IDLE\n            plan.bump_version()\n            uow.plans.save(plan)\n        committed = client.post(f\"/api/plans/{plan_id}/replanning/message\", json={\"message\": \"\"})\n        assert committed.status_code == 200\n        assert committed.json()[\"committed\"] is True\n>       assert client.get(f\"/api/plans/{plan_id}\").json()[\"phase\"] == PlanPhase.ARCHITECTURE.value\nE       AssertionError: assert 'replanning' == 'architecture'\nE         \nE         - architecture\nE         + replanning\n\ntests/integration/test_api.py:1056: AssertionError\n---------------------------- Captured stdout setup -----------------------------\n{\"url\": \"sqlite:////tmp/pytest-of-root/pytest-407/test_mid_running_replan_and_re0/orchestrator.db\", \"event\": \"db.engine_built\", \"request_id\": \"-\", \"level\": \"info\", \"timestamp\": \"2026-07-19T17:29:16.650975Z\"}\n{\"poll_seconds\": 0.5, \"event\": \"outbox_relay.started\", \"request_id\": \"-\", \"level\": \"info\", \"timestamp\": \"2026-07-19T17:29:16.741588Z\"}\n{\"version\": \"0.3.0\", \"event\": \"api.started\", \"request_id\": \"-\", \"level\": \"info\", \"timestamp\": \"2026-07-19T17:29:16.741684Z\"}\n----------------------------- Captured stdout call -----------------------------\n{\"request_id\": \"874398a94f304d5da13a81d173acd4b5\", \"method\": \"POST\", \"path\": \"/api/capabilities\", \"client_ip\": \"testclient\", \"event\": \"request_started\", \"level\": \"info\", \"timestamp\": \"2026-07-19T17:29:16.744851Z\"}\n{\"request_id\": \"874398a94f304d5da13a81d173acd4b5\", \"status_code\": 201, \"duration_ms\": 116.34, \"event\": \"request_finished\", \"level\": \"info\", \"timestamp\": \"2026-07-19T17:29:16.861163Z\"}\n{\"request_id\": \"847a4ee648