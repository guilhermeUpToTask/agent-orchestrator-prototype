 404, \"duration_ms\": 3.94, \"event\": \"request_finished\", \"level\": \"info\", \"timestamp\": \"2026-07-19T17:25:10.984516Z\"}\n{\"request_id\": \"50fa8688f731414da8e1fab03cad5c7e\", \"method\": \"DELETE\", \"path\": \"/api/providers/ghost\", \"client_ip\": \"testclient\", \"event\": \"request_started\", \"level\": \"info\", \"timestamp\": \"2026-07-19T17:25:10.986195Z\"}\n{\"code\": \"PROVIDER_NOT_FOUND\", \"message\": \"Model provider 'ghost' not found.\", \"status_code\": 404, \"path\": \"/api/providers/ghost\", \"context\": {\"provider_id\": \"ghost\"}, \"event\": \"request_error\", \"request_id\": \"50fa8688f731414da8e1fab03cad5c7e\", \"level\": \"warning\", \"timestamp\": \"2026-07-19T17:25:10.990602Z\"}\n{\"request_id\": \"50fa8688f731414da8e1fab03cad5c7e\", \"status_code\": 404, \"duration_ms\": 4.74, \"event\": \"request_finished\", \"level\": \"info\", \"timestamp\": \"2026-07-19T17:25:10.990894Z\"}\n{\"request_id\": \"3f245907fd9742819d8b0faa4cbb516e\", \"method\": \"POST\", \"path\": \"/api/plans/add5829f-e80f-4544-b1f5-3026059799ee/edits\", \"client_ip\": \"testclient\", \"event\": \"request_started\", \"level\": \"info\", \"timestamp\": \"2026-07-19T17:25:10.992644Z\"}\n{\"request_id\": \"3f245907fd9742819d8b0faa4cbb516e\", \"status_code\": 204, \"duration_ms\": 5.95, \"event\": \"request_finished\", \"level\": \"info\", \"timestamp\": \"2026-07-19T17:25:10.998585Z\"}\n--------------------------- Captured stdout teardown ---------------------------\n{\"event\": \"outbox_relay.stopped\", \"request_id\": \"-\", \"level\": \"info\", \"timestamp\": \"2026-07-19T17:25:11.199073Z\"}\n{\"event\": \"api.stopped\", \"request_id\": \"-\", \"level\": \"info\", \"timestamp\": \"2026-07-19T17:25:11.199830Z\"}\n=============================== warnings summary ===============================\n.venv/lib/python3.11/site-packages/fastapi/testclient.py:1\n  /workspaces/agent-orchestrator/.orchestrator/worktrees/api-tests/backend/.venv/lib/python3.11/site-packages/fas