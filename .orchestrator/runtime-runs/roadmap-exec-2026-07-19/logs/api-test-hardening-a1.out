src.domain.aggregates.planner_orchestrator import Plan, PlanPhase\nbackend/src/app/use_cases/conversation.py:45:    phase: PlanPhase\nbackend/src/app/use_cases/advance_plan.py:9:  DISCOVERY/ARCHITECTURE/ENRICHING/REPLANNING -> PlanningHandler (reasoner; Phase 2.5 seam)\nbackend/src/app/use_cases/advance_plan.py:10:  AWAITING_REVIEW/REVIEW                    -> GateHandler (pause/resume)\nbackend/src/app/use_cases/advance_plan.py:19:from src.domain.aggregates.planner_orchestrator import Plan, PlanPhase\nbackend/src/app/use_cases/advance_plan.py:37:        PlanPhase.DISCOVERY,\nbackend/src/app/use_cases/advance_plan.py:38:        PlanPhase.ARCHITECTURE,\nbackend/src/app/use_cases/advance_plan.py:39:        PlanPhase.ENRICHING,\nbackend/src/app/use_cases/advance_plan.py:40:        PlanPhase.REPLANNING,\nbackend/src/app/use_cases/advance_plan.py:43:_GATE_PHASES = frozenset({PlanPhase.AWAITING_REVIEW, PlanPhase.REVIEW})\nbackend/src/app/use_cases/advance_plan.py:44:_TERMINAL_PHASES = frozenset({PlanPhase.DONE, PlanPhase.FAILED})\nbackend/src/app/use_cases/advance_plan.py:64:    async def advance(self, plan_id: str, uow: UnitOfWork) -> Signal:\nbackend/src/app/use_cases/advance_plan.py:94:            return Signal.DONE if phase == PlanPhase.DONE else Signal.FAILED\nbackend/src/app/use_cases/advance_plan.py:101:        if phase == PlanPhase.RUNNING:\nbackend/src/app/use_cases/advance_plan.py:117:async def advance_plan(\nbackend/src/app/use_cases/request_replan.py:3:Two entry points, one phase: from REVIEW (\"replan next phase\") and from\nbackend/src/app/use_cases/request_replan.py:6:tolerant finalize in ExecutionHandler) and the plan lands in REPLANNING — a\nbackend/src/app/use_cases/request_replan.py:21:def request_replan(plan_id: str, uow: UnitOfWork) -> None:\nbackend/src/app/use_cases/cyclic_planning.py:6:from src.domain.aggregates.planner_orchestrator import PlanPhase\nbackend/src/app/use_cases/cyclic_planning.py:82:def approve_intent(\nbackend/src/app/use_cases/cyclic_planning.py:309:        plan._set_phase(PlanPhase.ENRICHING)\nbackend/src/app/use_cases/control.py:3:  AWAITING_REVIEW (pre-execution):  approve            -> RUNNING\nbackend/src/app/use_cases/control.py:4:  REVIEW          (post-execution): finish             -> DONE (PlanCompleted)\nbackend/src/app/use_cases/control.py:5:                                    replan next phase  -> REPLANNING\nbackend/src/app/use_cases/control.py:13:from src.domain.aggregates.planner_orchestrator import PlanPhase\nbackend/src/app/use_cases/control.py:29:                from_phase=PlanPhase.AWAITING_REVIEW.value,\nbackend/src/app/use_cases/control.py:30:                to_phase=PlanPhase.RUNNING.value,\nbackend/src/app/use_cases/control.py:36:def reopen_discovery(plan_id: str, uow: UnitOfWork) -> None:\nbackend/src/app/use_cases/control.py:37:    \"\"\"Human \"request changes\" at the pre-execution gate: AWAITING_REVIEW ->\nbackend/src/app/use_cases/control.py:47:                from_phase=PlanPhase.AWAITING_REVIEW.value,\nbackend/src/app/use_cases/control.py:48:                to_phase=PlanPhase.DISCOVERY.value,\nbackend/src/app/use_cases/control.py:54:def finish_review(plan_id: str, uow: UnitOfWork) -> None:\nbackend/src/app/use_cases/control.py:55:    \"\"\"Human \"finish\" at the post-execution gate: REVIEW -> DONE. This is the ONLY\nbackend/src/app/use_cases/control.py:66:    \"\"\"Human \"replan next phase\" at the post-execution gate: REVIEW -> REPLANNING.\n\"\"\"\nsrc/api/server.py — FastAPI application factory (the thin API).\n\nResponsibilities — zero business logic:\n  1. Create the FastAPI app with OpenAPI metadata.\n  2. Structured logging + the one error->HTTP mapping layer.\n  3. CORS + request-correlation middleware.\n  4. Mount the thin routers under /api (route -> use case).\n  5. Lifespan: bind the SSE broker to the loop and run the OUTBOX RELAY thread\n     (the thing that actually delivers outbox rows -> SSE; without it events\n     are written but never seen).\n  6. /health.\n\nThe worker runs as its own process (`orchestrate worker start`) — the old\nin-process coordinator daemons are gone with the pre-refactor architecture.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport asyncio\nimport os\nimport threading\nfrom contextlib import asynccontextmanager\nfrom typing import AsyncIterator\n\nimport structlog\nfrom fastapi import FastAPI\nfrom fastapi.middleware.cors import CORSMiddleware\nfrom fastapi.routing import APIRoute\n\nfrom src.api.dependencies import get_container, set_container\nfrom src.api.exceptions import register_exception_handlers\nfrom src.api.logging.config import configure_logging\nfrom src.api.middleware.request_logging import RequestLoggingMiddleware\nfrom src.api.outbox_relay import run_outbox_relay\nfrom src.api.routers import (\n    config,\n    events,\n    metrics,\n    plans,\n    reasoner,\n    reference,\n    runner,\n)\nfrom src.api.schemas.common import HealthResponse\nfrom src.api.sse import get_broker\nfrom src.infra.container import AppContainer\n\nlog = structlog.get_logger(__name__)\n\n_API_VERSION = \"0.3.0\"\n\n\ndef _cors_origins() -> list[str]:\n    \"\"\"Frontend origins allowed to read the API (incl. the SSE stream).\n    Defaults cover the Vite dev server; override with CORS_ALLOW_ORIGINS.\"\"\"\n    raw = os.environ.get(\"CORS_ALLOW_ORIGINS\")\n    if raw:\n        return [origin.strip() for origin in raw.split(\",\") if origin.strip()]\n    return [\n        \"http://localhost:5173\",\n        \"http://127.0.0.1:5173\",\n        \"http://localhost:5174\",\n        \"http://127.0.0.1:5174\",\n    ]\n\n\ndef _unique_operation_id(route: APIRoute) -> str:\n    \"\"\"Clean operation IDs (`plans-create`) for typed client generators.\"\"\"\n    tag = str(route.tags[0]) if route.tags else \"default\"\n    return f\"{tag}-{route.name}\"\n\n\ndef create_app(container: AppContainer | None = None) -> FastAPI:\n    \"\"\"Build the configured FastAPI application. Pass `container` explicitly in\n    tests; production resolves it from the environment.\"\"\"\n    if container is not None:\n        set_container(container)\n\n    @asynccontextmanager\n    async def lifespan(_app: FastAPI) -> AsyncIterator[None]:\n        # Threadpool routers and the relay thread publish from off-loop; the\n        # broker needs the loop to hop onto it safely.\n        get_broker().bind_loop(asyncio.get_running_loop())\n\n        stop_event = threading.Event()\n        relay = threading.Thread(\n            target=run_outbox_relay,\n            args=(get_container().session_factory, get_broker(), stop_event.is_set),\n            daemon=True,\n            name=\"outbox-relay\",\n        )\n        relay.start()\n        log.info(\"api.started\", version=_API_VERSION)\n        yield\n        stop_event.set()\n        relay.join(timeout=5.0)\n        log.info(\"api.stopped\")\n\n    app = FastAPI(\n        title=\"AIPOM Orchestrator API\",\n        version=_API_VERSION,\n        description=(\n            \"RESTful API for the AIPOM AI project orchestrator: the 9-phase \"\n            \"plan lifecycle (discovery, architecture, enriching, the two human \"\n            \"gates, execution, the replan loop), reference-data catalogs, \"\n            \"two-tier config, and the live SSE event stream.\"\n        ),\n        generate_unique_id_function=_unique_operation_id,\n        lifespan=lifespan,\n    )\n\n    configure_logging()\n    register_exception_handlers(app)\n\n    # Request logging (correlation id) before CORS so the id contextvar covers\n    # CORS-handled responses too.\n    app.add_middleware(RequestLoggingMiddleware)\n    app.add_middleware(\n        CORSMiddleware,\n        allow_origins=_cors_origins(),\n        allow_methods=[\"*\"],\n        allow_headers=[\"*\"],\n        expose_headers=[\"X-Request-ID\"],\n    )\n\n    _prefix = \"/api\"\n    app.include_router(plans.router, prefix=_prefix)\n    app.include_router(reference.router, prefix=_prefix)\n    app.include_router(config.router, prefix=_prefix)\n    app.include_router(reasoner.router, prefix=_prefix)\n    app.include_router(runner.router, prefix=_prefix)\n    app.include_router(metrics.router, prefix=_prefix)\n    app.include_router(events.router, prefix=_prefix)\n\n    @app.get(\n        \"/health\",\n        response_model=HealthResponse,\n        tags=[\"system\"],\n        summary=\"Health Check\",\n    )\n    def health() -> HealthResponse:\n        return HealthResponse(status=\"ok\", version=_API_VERSION)\n\n    return app\n2:/api/agents, /api/capabilities, /api/providers, /api/models, /api/projects —\n40:@router.get(\"/capabilities\")\n47:@router.post(\"/capabilities\", status_code=201)\n55:@router.put(\"/capabilities/{capability_id}\", status_code=204)\n64:@router.delete(\"/capabilities/{capability_id}\", status_code=204)\n125:@router.get(\"/agents\")\n130:@router.get(\"/agents/default\")\n137:@router.post(\"/agents\", status_code=201)\n144:@router.put(\"/agents/{agent_id}\", status_code=204)\n153:@router.delete(\"/agents/{agent_id}\", status_code=204)\n158:@router.post(\"/agents/{agent_id}/default\", status_code=204)\n180:@router.get(\"/providers\")\n187:@router.post(\"/providers\", status_code=201)\n205:@router.put(\"/providers/{provider_id}\", status_code=204)\n219:@router.delete(\"/providers/{provider_id}\", status_code=204)\n230:@router.get(\"/models\")\n235:@router.post(\"/providers/{provider_id}/models\", status_code=201)\n244:@router.put(\"/models/{model_id}\", status_code=204)\n253:@router.delete(\"/models/{model_id}\", status_code=204)\n268:@router.get(\"/projects\")\n275:@router.post(\"/projects\", status_code=201)\n284:@router.put(\"/projects/{project_id}\", status_code=204)\n293:@router.delete(\"/projects/{project_id}\", status_code=204)\nbackend/src/api/exceptions.py:9:  409  conflict           STALE_VERSION, GOAL_ALREADY_RUNNING, ENTITY_IN_USE,\nbackend/src/api/exceptions.py:12:  422  unprocessable      INVALID_EDIT, EMPTY_PLAN, INVALID_TRANSITION,\nbackend/src/api/exceptions.py:39:    \"GOAL_NOT_FOUND\": 404,\nbackend/src/api/exceptions.py:40:    \"TASK_NOT_FOUND\": 404,\nbackend/src/api/exceptions.py:41:    \"AGENT_NOT_FOUND\": 404,\nbackend/src/api/exceptions.py:43:    \"PROVIDER_NOT_FOUND\": 404,\nbackend/src/api/exceptions.py:48:    \"STALE_VERSION\": 409,\nbackend/src/api/exceptions.py:55:    \"INVALID_EDIT\": 422,\nbackend/src/domain/errors/planning_errors.py:24:    code = \"INVALID_EDIT\"\nbackend/src/domain/errors/agent_errors.py:19:class AgentNotFoundError(DomainError):\nbackend/src/domain/errors/agent_errors.py:23:    code = \"AGENT_NOT_FOUND\"\nbackend/src/domain/errors/README.md:11:| `GoalNotFoundError` | GOAL_NOT_FOUND | goal id not in the plan |\nbackend/src/domain/errors/README.md:12:| `TaskNotFoundError` | TASK_NOT_FOUND | task id not in the goal |\nbackend/src/domain/errors/README.md:15:| `StaleVersionError` | STALE_VERSION | optimistic-lock conflict (worker-vs-edit race) |\nbackend/src/domain/errors/README.md:18:| `AgentNotFoundError` | AGENT_NOT_FOUND | task references a deleted agent (reactive net) |\nbackend/src/domain/errors/README.md:28:| `InvalidEditError` | INVALID_EDIT | malformed structural edit |\nbackend/src/domain/errors/config_errors.py:15:    code = \"PROVIDER_NOT_FOUND\"\nbackend/src/domain/errors/tasks_errors.py:6:class GoalNotFoundError(DomainError):\nbackend/src/domain/errors/tasks_errors.py:7:    code = \"GOAL_NOT_FOUND\"\nbackend/src/domain/errors/tasks_errors.py:14:class TaskNotFoundError(DomainError):\nbackend/src/domain/errors/tasks_errors.py:15:    code = \"TASK_NOT_FOUND\"\nbackend/src/domain/errors/tasks_errors.py:56:    code = \"STALE_VERSION\"\n","exit_code":0,"status":"completed"}}
