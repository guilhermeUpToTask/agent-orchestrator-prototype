h pytest.raises(StaleVersionError):\nbackend/tests/integration/test_api.py:1099:    from src.domain.errors.tasks_errors import StaleVersionError\nbackend/tests/integration/test_api.py:1102:    monkeypatch.setattr(SqlitePlanRepository, \"save\", lambda self, plan: (_ for _ in ()).throw(StaleVersionError(plan.id, plan.version, plan.version + 1)))\nbackend/tests/unit/orchestration/test_plan_dispatcher.py:25:    async def handle(self, plan_id: str, plan: Plan, uow: UnitOfWork) -> Signal:\nbackend/tests/unit/orchestration/test_goal_parallel_execution.py:331:    still converges -- every goal reaches DONE, no StaleVersionError escapes\nbackend/tests/unit/orchestration/test_use_cases.py:19:    StaleVersionError,\nbackend/tests/unit/orchestration/test_use_cases.py:405:    with pytest.raises(StaleVersionError):\nbackend/tests/unit/orchestration/test_plan_dispatcher.py:25:    async def handle(self, plan_id: str, plan: Plan, uow: UnitOfWork) -> Signal:\nbackend/src/infra/reasoner/runtime/tool_profiles.py:58:    def handle(_args: dict[str, Any]) -> str:\nbackend/src/infra/db/plan_repository.py:15:from src.domain.errors.tasks_errors import StaleVersionError\nbackend/src/infra/db/plan_repository.py:135:            raise StaleVersionError(plan.id, plan.version, int(stored))\nbackend/src/infra/worker/main.py:114:    async def _run_goal(plan_id: str, goal_id: str) -> tuple[str, int]:\nbackend/src/domain/repositories/planner_repo.py:17:                     and raises StaleVersionError on conflict (worker-vs-edit race).\nbackend/src/domain/repositories/planner_repo.py:33:    def save(self, plan: Plan) -> None: ...  # version CAS -> StaleVersionError\nbackend/src/app/testing/fakes.py:18:from src.domain.errors.tasks_errors import StaleVersionError\nbackend/src/app/testing/fakes.py:91:            raise StaleVersionError(plan.id, plan.version, current.version)\nbackend/src/app/handlers/planning_handler.py:156:    async def handle(self, plan_id: str, plan: Plan, uow: UnitOfWork) -> Signal:\nbackend/src/app/use_cases/apply_edit.py:6:StaleVersionError and the caller retries or returns 409.\nbackend/src/app/use_cases/apply_edit.py:204:        uow.plans.save(plan)  # version-CAS: StaleVersionError if worker raced\nbackend/src/app/handlers/gate_handler.py:22:    async def handle(self, plan_id: str, plan: Plan, uow: UnitOfWork) -> Signal:\nbackend/src/app/handlers/base.py:35:    async def handle(self, plan_id: str, plan: Plan, uow: UnitOfWork) -> Signal: ...\nbackend/src/app/handlers/execution_handler.py:26:from src.domain.errors.tasks_errors import StaleVersionError\nbackend/src/app/handlers/execution_handler.py:108:class ExecutionHandler:\nbackend/src/app/handlers/execution_handler.py:125:    async def handle_goal(\nbackend/src/app/handlers/execution_handler.py:134:    async def handle(\nbackend/src/app/handlers/execution_handler.py:438:        # StaleVersionError here means a concurrent GOAL's write landed in\nbackend/src/app/handlers/execution_handler.py:583:        re-fetching current plan/task state each call) on StaleVersionError —\nbackend/src/app/handlers/execution_handler.py:598:            except StaleVersionError:\nbackend/src/app/handlers/execution_handler.py:605:        Retries on StaleVersionError; exhaustion degrades to False (the\nbackend/src/app/handlers/execution_handler.py:643:        except StaleVersionError:\nbackend/src/domain/errors/tasks_errors.py:53:class StaleVersionError(DomainError):\n","exit_code":0,"status":"completed"}}
