{"type":"item.started","item":{"id":"item_6","type":"command_execution","command":"/bin/bash -lc \"git status --short && sed -n '1,220p' backend/src/infra/db/goal_lease_repository.py && sed -n '1,160p' backend/src/domain/repositories/goal_lease_repo.py && rg -n \\\"class InMemoryGoalLeaseRepository|def heartbeat|_advance_with_heartbeats|drive_goal|_run_goal|goal_lease\\\" backend/src/app/testing/fakes.py backend/src/app/use_cases/run_worker.py backend/src/infra/worker/main.py backend/tests/unit/orchestration/test_goal_lease_repository.py backend/tests/unit/orchestration/test_goal_parallel_execution.py\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
{"type":"item.completed","item":{"id":"item_6","type":"command_execution","command":"/bin/bash -lc \"git status --short && sed -n '1,220p' backend/src/infra/db/goal_lease_repository.py && sed -n '1,160p' backend/src/domain/repositories/goal_lease_repo.py && rg -n \\\"class InMemoryGoalLeaseRepository|def heartbeat|_advance_with_heartbeats|drive_goal|_run_goal|goal_lease\\\" backend/src/app/testing/fakes.py backend/src/app/use_cases/run_worker.py backend/src/infra/worker/main.py backend/tests/unit/orchestration/test_goal_lease_repository.py backend/tests/unit/orchestration/test_goal_parallel_execution.py\"","aggregated_output":"\"\"\"SQLite repository for per-goal worker leases.\"\"\"\n\nfrom __future__ import annotations\n\nfrom datetime import datetime\nfrom typing import Any\n\nfrom sqlalchemy import text\nfrom sqlalchemy.engine import CursorResult\nfrom sqlalchemy.orm import Session, sessionmaker\n\nfrom src.infra.db._session import run_in_session\n\n_INSERT_SQL = text(\n    \"\"\"\n    INSERT OR IGNORE INTO goal_leases (plan_id, goal_id)\n    VALUES (:plan_id, :goal_id)\n    \"\"\"\n)\n\n_CLAIM_SQL = text(\n    \"\"\"\n    UPDATE goal_leases\n    SET claimed_by = :worker_id,\n        claimed_at = :now_epoch,\n        lease_expires_at = :expires_epoch,\n        lease_seconds = :lease_seconds\n    WHERE plan_id = :plan_id\n      AND goal_id = :goal_id\n      AND (claimed_by IS NULL OR lease_expires_at < :now_epoch)\n    \"\"\"\n)\n\n_HEARTBEAT_SQL = text(\n    \"\"\"\n    UPDATE goal_leases\n    SET lease_expires_at = :expires_epoch,\n        lease_seconds = :lease_seconds\n    WHERE plan_id = :plan_id\n      AND goal_id = :goal_id\n      AND claimed_by = :worker_id\n    \"\"\"\n)\n\n_RELEASE_SQL = text(\n    \"\"\"\n    UPDATE goal_leases\n    SET claimed_by = NULL, claimed_at = NULL,\n        lease_expires_at = NULL, lease_seconds = NULL\n    WHERE plan_id = :plan_id\n      AND goal_id = :goal_id\n      AND claimed_by = :worker_id\n    \"\"\"\n)\n\n_IS_LIVE_SQL = text(\n    \"\"\"\n    SELECT 1 FROM goal_leases\n    WHERE plan_id = :plan_id\n      AND goal_id = :goal_id\n      AND claimed_by IS NOT NULL\n      AND lease_expires_at > :now_epoch\n    \"\"\"\n)\n\n\nclass SqliteGoalLeaseRepository:\n    def __init__(self, session_factory: sessionmaker[Session]) -> None:\n        self._session_factory = session_factory\n\n    def claim_one_ready_goal(\n        self,\n        plan_id: str,\n        goal_id: str,\n        worker_id: str,\n        lease_seconds: int,\n        now: datetime,\n    ) -> bool:\n        now_epoch = int(now.timestamp())\n\n        def claim(session: Session) -> bool:\n            session.execute(_INSERT_SQL, {\"plan_id\": plan_id, \"goal_id\": goal_id})\n            result: CursorResult[Any] = session.execute(  # type: ignore[assignment]\n                _CLAIM_SQL,\n                {\n                    \"plan_id\": plan_id,\n                    \"goal_id\": goal_id,\n                    \"worker_id\": worker_id,\n                    \"now_epoch\": now_epoch,\n                    \"expires_epoch\": now_epoch + lease_seconds,\n                    \"lease_seconds\": lease_seconds,\n                },\n            )\n            return result.rowcount == 1\n\n        return run_in_session(self._session_factory, claim)\n\n    def heartbeat(\n        self,\n        plan_id: str,\n        goal_id: str,\n        worker_id: str,\n        lease_seconds: int,\n        now: datetime,\n    ) -> None:\n        now_epoch = int(now.timestamp())\n        run_in_session(\n            self._session_factory,\n            lambda session: session.execute(\n                _HEARTBEAT_SQL,\n                {\n                    \"plan_id\": plan_id,\n                    \"goal_id\": goal_id,\n                    \"worker_id\": worker_id,\n                    \"expires_epoch\": now_epoch + lease_seconds,\n                    \"lease_seconds\": lease_seconds,\n                },\n            ),\n        )\n\n    def release(self, plan_id: str, goal_id: str, worker_id: str) -> None:\n        run_in_session(\n            self._session_factory,\n            lambda session: session.execute(\n                _RELEASE_SQL,\n                {\"plan_id\": plan_id, \"goal_id\": goal_id, \"worker_id\": worker_id},\n            ),\n        )\n\n    def is_claim_live(self, plan_id: str, goal_id: str, now: datetime) -> bool:\n        now_epoch = int(now.timestamp())\n\n        def check(session: Session) -> bool:\n            row = session.execute(\n                _IS_LIVE_SQL,\n                {\"plan_id\": plan_id, \"goal_id\": goal_id, \"now_epoch\": now_epoch},\n            ).one_or_none()\n            return row is not None\n\n        return run_in_session(self._session_factory, check)\nfrom __future__ import annotations\n\nfrom datetime import datetime\nfrom typing import Protocol\n\n\nclass GoalLeaseRepository(Protocol):\n    \"\"\"Per-goal concurrency primitives for one already-selected ready goal.\n\n    The application identifies ready goals from the Plan aggregate; this contract\n    only coordinates ownership of one ``(plan_id, goal_id)`` pair at a time.\n    \"\"\"\n\n    def claim_one_ready_goal(\n        self,\n        plan_id: str,\n        goal_id: str,\n        worker_id: str,\n        lease_seconds: int,\n        now: datetime,\n    ) -> bool:\n        \"\"\"Claim the pair if it is unclaimed or its existing lease has expired.\"\"\"\n        ...\n\n    def heartbeat(\n        self,\n        plan_id: str,\n        goal_id: str,\n        worker_id: str,\n        lease_seconds: int,\n        now: datetime,\n    ) -> None:\n        \"\"\"Renew the pair's lease only while it is still owned by the worker.\"\"\"\n        ...\n\n    def release(self, plan_id: str, goal_id: str, worker_id: str) -> None:\n        \"\"\"Release the pair only while it is still owned by the worker.\"\"\"\n        ...\n\n    def is_claim_live(self, plan_id: str, goal_id: str, now: datetime) -> bool:\n        \"\"\"Report whether the pair currently has an unexpired worker claim.\"\"\"\n        ...\nbackend/tests/unit/orchestration/test_goal_parallel_execution.py:3:drive_goal + ExecutionHandler.handle_goal, on both backends via env_factory.\nbackend/tests/unit/orchestration/test_goal_parallel_execution.py:19:from src.app.use_cases.run_worker import drive_goal\nbackend/tests/unit/orchestration/test_goal_parallel_execution.py:59:    are claimable through goal_leases — there is no privileged goal left to\nbackend/tests/unit/orchestration/test_goal_parallel_execution.py:85:def test_drive_goal_progresses_only_its_own_goal(env_factory):\nbackend/tests/unit/orchestration/test_goal_parallel_execution.py:95:        drive_goal(plan_id, goal_id, env.uow, *env.args[1:], \"w1\")\nbackend/tests/unit/orchestration/test_goal_parallel_execution.py:210:    # drive_goal loops until the goal stops making progress -- reliably\nbackend/tests/unit/orchestration/test_goal_parallel_execution.py:214:    signal, _ = asyncio.run(drive_goal(\"p1\", \"g1\", env.uow, *env.args[1:], \"w0\"))\nbackend/tests/unit/orchestration/test_goal_parallel_execution.py:230:        drive_goal(\"p1\", \"g2\", env.uow, *env.args[1:], \"w1\")\nbackend/tests/unit/orchestration/test_goal_parallel_execution.py:241:def test_handle_goal_matches_handle_for_a_legacy_single_goal_lease_free_call(env_factory):\nbackend/tests/unit/orchestration/test_goal_parallel_execution.py:313:                drive_goal(plan_id, goal_id, env.uow, *env.args[1:], f\"w{i}\")\nbackend/src/app/use_cases/run_worker.py:42:async def _advance_with_heartbeats(\nbackend/src/app/use_cases/run_worker.py:49:    both the plan-level (`drive_plan`) and goal-level (`drive_goal`) loops\nbackend/src/app/use_cases/run_worker.py:97:        signal = await _advance_with_heartbeats(\nbackend/src/app/use_cases/run_worker.py:169:async def drive_goal(\nbackend/src/app/use_cases/run_worker.py:198:        signal = await _advance_with_heartbeats(\nbackend/src/app/use_cases/run_worker.py:200:            lambda: uow.goal_leases.heartbeat(\nbackend/src/app/use_cases/run_worker.py:205:        uow.goal_leases.heartbeat(plan_id, goal_id, worker_id, lease_seconds, clock.now())\nbackend/tests/unit/orchestration/test_goal_lease_repository.py:12:from src.infra.db.goal_lease_repository import SqliteGoalLeaseRepository\nbackend/tests/unit/orchestration/test_goal_lease_repository.py:33:    leases = env.uow.goal_leases\nbackend/tests/unit/orchestration/test_goal_lease_repository.py:44:def test_heartbeat_extends_only_the_current_workers_goal_lease(env_factory) -> None:\nbackend/tests/unit/orchestration/test_goal_lease_repository.py:47:    leases = env.uow.goal_leases\nbackend/tests/unit/orchestration/test_goal_lease_repository.py:59:def test_release_clears_only_the_current_workers_goal_lease(env_factory) -> None:\nbackend/tests/unit/orchestration/test_goal_lease_repository.py:62:    leases = env.uow.goal_leases\nbackend/src/app/testing/fakes.py:128:    def heartbeat(self, plan_id: str, worker_id: str) -> None:\nbackend/src/app/testing/fakes.py:149:class InMemoryGoalLeaseRepository:\nbackend/src/app/testing/fakes.py:175:    def heartbeat(\nbackend/src/app/testing/fakes.py:236:        self.goal_leases = InMemoryGoalLeaseRepository()\nbackend/src/infra/worker/main.py:15:claimed and driven exclusively through `claim_ready_goal`/`drive_goal`. So\nbackend/src/infra/worker/main.py:23:`goal_leases` row is a real cross-process lease either way).\nbackend/src/infra/worker/main.py:69:    from src.app.use_cases.run_worker import drive_goal, worker_tick\nbackend/src/infra/worker/main.py:114:    async def _run_goal(plan_id: str, goal_id: str) -> tuple[str, int]:\nbackend/src/infra/worker/main.py:117:            return await drive_goal(\nbackend/src/infra/worker/main.py:131:            # drive_goal does not release its own lease (goal_tick used to be\nbackend/src/infra/worker/main.py:135:            goal_uow.goal_leases.release(plan_id, goal_id, worker_id)\nbackend/src/infra/worker/main.py:187:            task = asyncio.ensure_future(_run_goal(plan_id, goal_id))\n","exit_code":0,"status":"completed"}}
