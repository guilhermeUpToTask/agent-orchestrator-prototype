payload.stdout_bytes,\\\\n                                \\\"stderr_bytes\\\": observation.payload.stderr_bytes,\\\\n                                \\\"exit_code\\\": observation.payload.exit_code,\\\\n                                \\\"duration_seconds\\\": observation.payload.duration_seconds,\\\\n                                \\\"log_path\\\": observation.payload.log_path,\\\\n                            }\\\\n                            if isinstance(observation.payload, ProcessObservationPayload)\\\\n                            else {}\\\\n                        ),\\\\n                    ),\\\\n                )[-1],\\\\n'''\nassert old_callback in s\ns = s.replace(old_callback, new_callback, 1)\n# Add optional dependency to each concrete runner and pass it through.\nfor marker in [\n    'class PiAgentRunner(CliAgentRunner):',\n    'class ClaudeCodeRunner(CliAgentRunner):',\n    'class GeminiRunner(CliAgentRunner):',\n]:\n    start = s.index(marker)\n    next_start = s.find('\\\\nclass ', start + 1)\n    if next_start == -1:\n        next_start = len(s)\n    chunk = s[start:next_start]\n    chunk = chunk.replace('        orchestrator_home: Path | None = None,\\\\n    ) -> None:', '        orchestrator_home: Path | None = None,\\\\n        observation_repository: ObservationRepository | None = None,\\\\n    ) -> None:', 1)\n    old_super = '        super().__init__(timeout_seconds, provider_id=provider_id, model_id=model_id, orchestrator_home=orchestrator_home)'\n    new_super = '''        super().__init__(\\\\n            timeout_seconds,\\\\n            provider_id=provider_id,\\\\n            model_id=model_id,\\\\n            orchestrator_home=orchestrator_home,\\\\n            observation_repository=observation_repository,\\\\n        )'''\n    assert old_super in chunk\n    chunk = chunk.replace(old_super, new_super, 1)\n    s = s[:start] + chunk + s[next_start:]\np.write_text(s)\n\np = root / 'backend/src/infra/runtime/factory.py'\ns = p.read_text(