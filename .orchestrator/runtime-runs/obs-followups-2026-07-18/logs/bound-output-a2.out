{"type":"item.completed","item":{"id":"item_21","type":"command_execution","command":"/bin/bash -lc \"sed -n '1,180p' backend/pyproject.toml\"","aggregated_output":"[project]\nname = \"agent-orchestrator\"\nversion = \"0.1.0\"\ndescription = \"Agent Orchestrated Dev System — Agent-CLI Mode (Hexagonal + Event-Driven)\"\nrequires-python = \">=3.11\"\ndependencies = [\n    \"pydantic>=2.0\",\n    \"pydantic-settings>=2.0\",\n    \"redis>=5.0\",\n    \"pyyaml>=6.0\",\n    \"gitpython>=3.1\",\n    \"click>=8.1\",\n    \"structlog>=24.0\",\n    \"openai>=2.30.0\",\n    \"fastapi>=0.111.0\",\n    \"uvicorn[standard]>=0.30.0\",\n    \"sqlalchemy>=2.0\",\n    \"alembic>=1.13\",\n    \"cryptography>=42.0\",\n]\n\n[project.optional-dependencies]\ndev = [\n    \"pytest>=8.0\",\n    \"pytest-asyncio>=0.23\",\n    \"pytest-cov>=5.0\",\n    \"coverage>=7.0\",\n    # >=2.36: earlier releases lose messages on multi-stream XREADGROUP\n    # (cursor advances on every stream while delivering only one)\n    \"fakeredis>=2.36\",\n    \"ruff>=0.4\",\n    \"mypy>=1.10\",\n    \"types-PyYAML>=6.0\",\n]\n\n[project.scripts]\norchestrate = \"src.infra.cli.main:cli\"\n\n[build-system]\nrequires = [\"hatchling\"]\nbuild-backend = \"hatchling.build\"\n\n[tool.hatch.build.targets.wheel]\npackages = [\"src\"]\n\n[tool.pytest.ini_options]\ntestpaths = [\"tests\"]\naddopts = \"--cov=src --cov-report=term-missing\"\nmarkers = [\n    \"integration: exercises real adapters (SQLite, git, subprocess); deselect with -m 'not integration'\",\n    \"llm: cost-gated real-provider smoke tests; run explicitly with -m llm and REASONER_SMOKE_* set\",\n]\n\n[tool.ruff]\nline-length = 100\ntarget-version = \"py311\"\n\n[tool.mypy]\npython_version = \"3.11\"\nstrict = true\n\n# Honest per-layer typing: src/domain and src/app are fully strict (the\n# layers that claim it); the adapter layers carry explicit relaxations\n# until they are brought up to strict. Ratchet rule: `mypy src` must stay\n# at zero errors under this config — tighten flags here, never loosen.\n# TODO(type-health): remove these overrides module by module.\n[[tool.mypy.overrides]]\nmodule = [\"src.infra.*\", \"src.api.*\"]\ndisallow_untyped_defs = false\ndisallow_incomplete_defs = false\ndisallow_any_generics = false\ndisallow_untyped_calls = false\ndisallow_untyped_decorators = false\nwarn_return_any = false\n","exit_code":0,"status":"completed"}}
