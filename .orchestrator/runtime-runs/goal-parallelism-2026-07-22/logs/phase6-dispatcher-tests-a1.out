   runner = _ReplanDuringRun({\"t0\": DummyBehavior(output=\"late ok\")}, uow, \"t0\")\nbackend/tests/unit/orchestration/test_replan_loop.py:257:            return await DummyAgentRunner.run(self, task, spec, **kw)\nbackend/tests/unit/orchestration/test_replan_loop.py:259:    runner = _ReplanAndCommit({\"t0\": DummyBehavior(output=\"too late\")}, uow, \"t0\")\nbackend/tests/unit/orchestration/test_execution_handler_unpromotable_goal.py:21:    DummyAgentRunner,\nbackend/tests/unit/orchestration/test_execution_handler_unpromotable_goal.py:74:        DummyAgentRunner(),\nbackend/tests/unit/orchestration/test_pause_resume.py:28:from src.app.testing.fakes import DummyBehavior, InMemoryCapabilityRepository\nbackend/tests/unit/orchestration/test_pause_resume.py:404:            \"t0\": DummyBehavior(\nbackend/tests/unit/orchestration/test_pause_resume.py:416:    env.runner.script[\"t0\"] = DummyBehavior(output=\"ok\")  # human fixed the key\nbackend/tests/unit/orchestration/test_pause_resume.py:427:    env = env_factory({\"t0\": DummyBehavior(always_fail=True, fail_reason=\"boom\")})\nbackend/tests/unit/orchestration/test_pause_resume.py:449:    from src.app.testing.fakes import DummyAgentRunner\nbackend/tests/unit/orchestration/test_pause_resume.py:451:    class PauseMidRun(DummyAgentRunner):\nbackend/tests/unit/orchestration/test_pause_resume.py:465:    env.runner = PauseMidRun({\"t0\": DummyBehavior(always_fail=True, fail_reason=\"boom\")}, env.uow)\nbackend/tests/unit/orchestration/test_pause_resume.py:485:    env = env_factory({\"t0\": DummyBehavior(always_fail=True, fail_reason=\"rate limited\")})\nbackend/tests/unit/orchestration/test_pause_resume.py:491:    env.runner.script[\"t0\"] = DummyBehavior(output=\"ok\")  # quota restored\nbackend/tests/unit/orchestration/test_backoff_gate.py:18:from src.app.testing.fakes import DummyBehavior\nbackend/tests/unit/orchestration/test_backoff_gate.py:114:    env = env_factory({\"t0\": DummyBehavior(always_fail=True)})\nbackend/tests/unit/orchestration/test_backoff_gate.py:126:    env = env_factory({\"t0\": DummyBehavior(always_fail=True)})\nbackend/tests/unit/orchestration/test_backoff_gate.py:136:    env = env_factory({\"t0\": DummyBehavior(fail_times=1)})  # fail once, then succeed\nbackend/tests/unit/orchestration/test_backoff_gate.py:150:    env = env_factory({\"t0\": DummyBehavior(always_fail=True)})\nbackend/tests/unit/orchestration/test_execution_records.py:11:from src.app.testing.fakes import DummyBehavior\nbackend/tests/unit/orchestration/test_execution_records.py:91:    env = env_factory({\"t1\": DummyBehavior(fail_times=1)})\nbackend/tests/unit/orchestration/test_execution_records.py:113:            \"t1\": DummyBehavior(\nbackend/tests/unit/orchestration/test_execution_records.py:126:    env.runner.script[\"t1\"] = DummyBehavior(output=\"recovered\")\nbackend/tests/unit/orchestration/test_execution_records.py:214:            \"t1\": DummyBehavior(\nbackend/tests/unit/orchestration/test_edge_cases.py:29:    DummyAgentRunner,\nbackend/tests/unit/orchestration/test_edge_cases.py:30:    DummyBehavior,\nbackend/tests/unit/orchestration/test_edge_cases.py:51:    runner = DummyAgentRunner(script or {})\nbackend/tests/unit/orchestration/test_edge_cases.py:153:    script = {\"t0\": DummyBehavior(fail_times=1), \"t1\": DummyBehavior(fail_times=1)}\nbackend/tests/unit/orchestration/test_edge_cases.py:180:    script = {\"t1\": DummyBehavior(always_fail=True, fail_reason=\"boom\")}\nbackend/tests/unit/orchestration/test_edge_cases.py:221:    script = {\"t0\": DummyBehavior(always_fail=True)}\nbackend/tests/unit/orchestration/test_advance_plan.py:20:from src.app.testing.fakes import DummyBehavior\nbackend/tests/unit/orchestration/test_advance_plan.py:92:    env = env_factory({\"g0t0\": DummyBehavior(fail_times=2, output=\"recovered\")})\nbackend/tests/unit/orchestration/test_advance_plan.py:106:    env = env_factory({\"g0t0\": DummyBehavior(always_fail=True, fail_reason=\"boom\")})\nbackend/tests/unit/orchestration/test_advance_plan.py:124:            \"g0t0\": DummyBehavior(\nbackend/tests/unit/orchestration/test_advance_plan.py:170:    env = env_factory({\"g0t0\": DummyBehavior(emit_events=3)})\nbackend/tests/integration/test_drive_plan_sqlite_git.py:15:    DummyAgentRunner,\nbackend/tests/integration/test_drive_plan_sqlite_git.py:16:    DummyBehavior,\nbackend/tests/integration/test_drive_plan_sqlite_git.py:37:class WritingDummyRunner(DummyAgentRunner):\nbackend/tests/integration/test_drive_plan_sqlite_git.py:86:    runner = WritingDummyRunner({\"t1\": DummyBehavior(fail_times=2, emit_events=1)})\nbackend/tests/integration/test_full_cycle_llm.py:13:    DummyAgentRunner,\nbackend/tests/integration/test_full_cycle_llm.py:108:        self.runner = DummyAgentRunner({})\nbackend/tests/integration/test_agent_runner_factory.py:23:from src.infra.runtime.dummy_runner import DryRunAgentRunner, DummyAgentRunner\nbackend/tests/integration/test_agent_runner_factory.py:160:    assert isinstance(runner._runner_for(spec_with(runtime_type=\"dry-run\")), DummyAgentRunner)\nbackend/tests/integration/test_full_cycle.py:20:    DummyAgentRunner,\nbackend/tests/integration/test_full_cycle.py:21:    DummyBehavior,\nbackend/tests/integration/test_full_cycle.py:77:        self.runner = DummyAgentRunner(script or {})\nbackend/tests/integration/test_full_cycle.py:208:    class ReplanMidRun(DummyAgentRunner):\nbackend/tests/integration/test_full_cycle.py:221:    runner = ReplanMidRun({\"__all__\": DummyBehavior()}, stack.uow)\nbackend/tests/integration/test_full_cycle.py:310:    stack = Stack(tmp_path, script={\"__fail__\": DummyBehavior(always_fail=True)})\n","exit_code":0,"status":"completed"}}
