{"type":"item.completed","item":{"id":"item_58","type":"command_execution","command":"/bin/bash -lc \"nl -ba backend/src/app/use_cases/advance_plan.py | sed -n '64,104p'\"","aggregated_output":"    64\t        self._clock = clock\n    65\t\n    66\t    async def advance(self, plan_id: str, uow: UnitOfWork) -> Signal:\n    67\t        with uow:\n    68\t            plan: Plan = uow.plans.get(plan_id)\n    69\t            phase = plan.phase\n    70\t\n    71\t        if plan.active_cycle is not None:\n    72\t            if plan.status.value != \"running\" or plan.pause_requested:\n    73\t                return Signal.PAUSED\n    74\t            goals = plan.execution_goals\n    75\t            # Goal-level parallelism (ADR-001, domain unfreeze #12) is PURELY\n    76\t            # ADDITIVE here: this plan-level tick keeps driving execution\n    77\t            # exactly as it always has (next_action's single-earliest-ready\n    78\t            # result, unchanged since Phase 1) so a lone worker process (no\n    79\t            # separate goal-lease worker running) behaves byte-identically to\n    80\t            # before this unfreeze. The only change is routing to planning\n    81\t            # when ANY ready goal needs enrichment (not just the\n    82\t            # earliest-position one — the actual fix for the fan-out gap\n    83\t            # Phase 2 addressed inside PlanningHandler, but the DISPATCHER\n    84\t            # must also stop assuming \"earliest non-terminal goal has no\n    85\t            # tasks yet\" is the only case that needs a planning tick).\n    86\t            # Separate goal_tick workers (run_worker.py) ADDITIONALLY claim\n    87\t            # and drive OTHER ready-and-enriched goals concurrently — this\n    88\t            # tick never needs to know whether any exist.\n    89\t            ready_ids = ready_goal_ids(goals, self._clock.now())\n    90\t            needs_enrichment = any(goal.id in ready_ids and not goal.tasks for goal in goals)\n    91\t            if needs_enrichment:\n    92\t                if self._planning is None:\n    93\t                    return Signal.PAUSED\n    94\t                return await self._planning.handle(plan_id, plan, uow)\n    95\t            return await self._execution.handle(plan_id, plan, uow)\n    96\t\n    97\t        if (\n    98\t            plan.status.value == \"running\"\n    99\t            and plan.intent_proposal is not None\n   100\t            and plan.intent_proposal.approved_at is not None\n   101\t            and plan.cycle_draft is None\n   102\t        ):\n   103\t            if self._planning is None:\n   104\t                return Signal.PAUSED\n","exit_code":0,"status":"completed"}}
