nd_planning.py:254:    assert [g.id for g in stored.active_cycle.goals] == [\"g1\"]\nbackend/tests/unit/orchestration/test_conversation_and_planning.py:267:    cycle = Cycle(\nbackend/tests/unit/orchestration/test_conversation_and_planning.py:300:    assert [item.status for item in settled.active_cycle.goals[0].tasks] == [\nbackend/tests/unit/orchestration/test_conversation_and_planning.py:307:    assert settled.review_gate is None\nbackend/tests/unit/orchestration/test_conversation_and_planning.py:308:    assert settled.active_cycle is not None\nbackend/tests/unit/orchestration/test_conversation_and_planning.py:391:    assert stored.phase == PlanPhase.AWAITING_REVIEW\nbackend/tests/unit/orchestration/test_worker_loop.py:42:def test_worker_tick_drives_plan_to_review_gate(env_factory):\nbackend/tests/unit/orchestration/test_worker_loop.py:110:    phases (DISCOVERY, REPLANNING) and the gates (AWAITING_REVIEW, REVIEW) are\nbackend/tests/unit/orchestration/test_worker_loop.py:116:        PlanPhase.AWAITING_REVIEW,\nbackend/tests/unit/orchestration/test_execution_records.py:229:    plan.status = PlanStatus.RUNNING\nbackend/tests/unit/orchestration/test_execution_records.py:231:        Cycle(\nbackend/tests/unit/orchestration/test_execution_records.py:266:    assert stored.active_cycle is not None\nbackend/tests/unit/orchestration/test_execution_records.py:267:    assert stored.active_cycle.goals[0].tasks[1].status == Status.PENDING\nbackend/tests/unit/orchestration/test_pause_resume.py:113:    plan.phase = PlanPhase.AWAITING_REVIEW  # gates are already paused by design\nbackend/tests/unit/orchestration/test_pause_resume.py:189:    cycle = Cycle(\nbackend/tests/unit/orchestration/test_pause_resume.py:218:    assert stored.status == PlanStatus.RUNNING\nbackend/tests/unit/orchestration/test_pause_resume.py:220:    retried = stored.active_cycle.goals[0].tasks[0]\nbackend/tests/unit/orchestration/test_pause_resume.py:243:            Cycle(\nbackend/tests/unit/orchestration/te