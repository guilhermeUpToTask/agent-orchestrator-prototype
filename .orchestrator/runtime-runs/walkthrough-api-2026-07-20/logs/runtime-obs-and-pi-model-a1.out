time.process_observation_persist_failed\",\nbackend/src/infra/runtime/cli_runner.py:372:                \"runtime.process_observation\",\nbackend/src/infra/runtime/cli_runner.py:417:                model_id=self._model_id,\nbackend/src/infra/runtime/cli_runner.py:428:                model_id=self._model_id,\nbackend/src/infra/runtime/cli_runner.py:442:                model_id=self._model_id,\nbackend/src/infra/runtime/cli_runner.py:470:PI_BACKEND_ENV_VAR: dict[str, str] = {\nbackend/src/infra/runtime/cli_runner.py:477:class PiAgentRunner(CliAgentRunner):\nbackend/src/infra/runtime/cli_runner.py:490:        observation_repository: ObservationRepository | None = None,\nbackend/src/infra/runtime/cli_runner.py:492:        if backend not in PI_BACKEND_ENV_VAR:\nbackend/src/infra/runtime/cli_runner.py:494:                f\"Invalid pi backend '{backend}'. Valid: {', '.join(sorted(PI_BACKEND_ENV_VAR))}\"\nbackend/src/infra/runtime/cli_runner.py:503:            observation_repository=observation_repository,\nbackend/src/infra/runtime/cli_runner.py:529:        return {**_base_child_env(), PI_BACKEND_ENV_VAR[self._backend]: self._api_key}\nbackend/src/infra/runtime/cli_runner.py:553:        observation_repository: ObservationRepository | None = None,\nbackend/src/infra/runtime/cli_runner.py:560:            observation_repository=observation_repository,\nbackend/src/infra/runtime/cli_runner.py:592:        observation_repository: ObservationRepository | None = None,\nbackend/src/infra/runtime/cli_runner.py:599:            observation_repository=observation_repository,\n","exit_code":0,"status":"completed"}}
