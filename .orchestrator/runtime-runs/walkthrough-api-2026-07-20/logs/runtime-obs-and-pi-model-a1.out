vider row whose id maps to a pi backend, one model, and the key.\"\"\"\nbackend/tests/integration/test_agent_runner_factory.py:114:        spec_with(runtime_type=\"pi\", provider_id=\"anthropic\", model_id=\"anthropic:sonnet\")\nbackend/tests/integration/test_agent_runner_factory.py:116:    assert isinstance(pi, PiAgentRunner)\nbackend/tests/integration/test_agent_runner_factory.py:118:    assert pi._model == \"claude-sonnet-4-5\"  # the provider model string\nbackend/tests/integration/test_agent_runner_factory.py:123:        spec_with(runtime_type=\"claude\", provider_id=\"anthropic\", model_id=\"anthropic:sonnet\")\nbackend/tests/integration/test_agent_runner_factory.py:129:    runner = PiAgentRunner(\nbackend/tests/integration/test_agent_runner_factory.py:203:            spec_with(runtime_type=\"claude\", provider_id=\"anthropic\", model_id=\"ghost\"),\nbackend/tests/integration/test_agent_runner_factory.py:226:        spec_with(runtime_type=\"pi\", provider_id=\"acme\", model_id=\"acme:m1\"),\nbackend/tests/integration/test_agent_runner_factory.py:243:        spec_with(runtime_type=\"claude\", provider_id=\"anthropic\", model_id=\"anthropic:sonnet\")\nbackend/tests/integration/test_api.py:768:    model = client.post(f\"/api/providers/{provider_id}/models\", json={\"name\": \"gpt-old\"}).json()\nbackend/tests/integration/test_api.py:770:    renamed = client.put(f\"/api/models/{model['id']}\", json={\"name\": \"gpt-new\"})\nbackend/tests/integration/test_api.py:772:    listing = {m[\"id\"]: m for m in client.get(\"/api/models\").json()}\nbackend/tests/integration/test_api.py:776:    ghost = client.put(\"/api/models/ghost\", json={\"name\": \"x\"})\nbackend/tests/integration/test_api.py:799:    model = client.post(f\"/api/providers/{provider['id']}/models\", json={\"name\": \"gpt-x\"}).json()\nbackend/tests/integration/test_api.py:804:    client.put(\"/api/config/orchestrator/reasoner.model_id\", json={\"value\": model[\"id\"]})\nbackend/tests/integration/test_api.