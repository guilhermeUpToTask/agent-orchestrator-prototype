{"type":"item.completed","item":{"id":"item_3","type":"command_execution","command":"/bin/bash -lc \"rg -n \\\"PlanPhase|WORKER_CLAIMABLE_PHASES|self\\\\.status =|def (legal_actions|activity|request_pause|pause|resume|settle_pause|begin_replanning|resolve_block|commit_replanned_goals|active_cycle|review_gate|intent_proposal)\\\" backend/src/domain/aggregates/planner_orchestrator.py backend/src/app/use_cases/request_replan.py backend/src/app/use_cases/cyclic_planning.py backend/src/app/use_cases/conversation.py backend/src/infra/db/plan_repository.py && rg -n \\\"phase|WORKER_CLAIMABLE_PHASES|status|paused|intent_proposal|review_gate|begin_replanning|resolve_block|commit_replanned_goals\\\" tests/unit/orchestration\"","aggregated_output":"backend/src/app/use_cases/conversation.py:28:from src.domain.aggregates.planner_orchestrator import Plan, PlanPhase\nbackend/src/app/use_cases/conversation.py:45:    phase: PlanPhase\nbackend/src/app/use_cases/cyclic_planning.py:6:from src.domain.aggregates.planner_orchestrator import PlanPhase\nbackend/src/app/use_cases/cyclic_planning.py:309:        plan._set_phase(PlanPhase.ENRICHING)\nbackend/src/domain/aggregates/planner_orchestrator.py:33:class PlanPhase(str, Enum):\nbackend/src/domain/aggregates/planner_orchestrator.py:60:TERMINAL_PHASES: frozenset[PlanPhase] = frozenset({PlanPhase.DONE, PlanPhase.FAILED})\nbackend/src/domain/aggregates/planner_orchestrator.py:64:WORKER_CLAIMABLE_PHASES: frozenset[PlanPhase] = frozenset(\nbackend/src/domain/aggregates/planner_orchestrator.py:65:    {PlanPhase.ARCHITECTURE, PlanPhase.ENRICHING, PlanPhase.RUNNING}\nbackend/src/domain/aggregates/planner_orchestrator.py:70:WORKER_PLANNING_PHASES: frozenset[PlanPhase] = frozenset(\nbackend/src/domain/aggregates/planner_orchestrator.py:71:    {PlanPhase.ARCHITECTURE, PlanPhase.ENRICHING}\nbackend/src/domain/aggregates/planner_orchestrator.py:103:    phase: PlanPhase = PlanPhase.DISCOVERY\nbackend/src/domain/aggregates/planner_orchestrator.py:128:        raw_phase = data.get(\"phase\", PlanPhase.DISCOVERY.value)\nbackend/src/domain/aggregates/planner_orchestrator.py:129:        phase = raw_phase.value if isinstance(raw_phase, PlanPhase) else str(raw_phase)\nbackend/src/domain/aggregates/planner_orchestrator.py:131:            PlanPhase.DISCOVERY.value: PlanStatus.WAITING,\nbackend/src/domain/aggregates/planner_orchestrator.py:132:            PlanPhase.REPLANNING.value: PlanStatus.WAITING,\nbackend/src/domain/aggregates/planner_orchestrator.py:133:            PlanPhase.ARCHITECTURE.value: PlanStatus.RUNNING,\nbackend/src/domain/aggregates/planner_orchestrator.py:134:            PlanPhase.ENRICHING.value: PlanStatus.RUNNING,\nbackend/src/domain/aggregates/planner_orchestrator.py:135:            PlanPhase.AWAITING_REVIEW.value: PlanStatus.WAITING,\nbackend/src/domain/aggregates/planner_orchestrator.py:136:            PlanPhase.RUNNING.value: PlanStatus.RUNNING,\nbackend/src/domain/aggregates/planner_orchestrator.py:137:            PlanPhase.REVIEW.value: PlanStatus.WAITING,\nbackend/src/domain/aggregates/planner_orchestrator.py:138:            PlanPhase.DONE.value: PlanStatus.IDLE,\nbackend/src/domain/aggregates/planner_orchestrator.py:139:            PlanPhase.FAILED.value: PlanStatus.BLOCKED,\nbackend/src/domain/aggregates/planner_orchestrator.py:144:    def _set_phase(self, phase: PlanPhase) -> None:\nbackend/src/domain/aggregates/planner_orchestrator.py:147:        self.status = {\nbackend/src/domain/aggregates/planner_orchestrator.py:148:            PlanPhase.DISCOVERY: PlanStatus.WAITING,\nbackend/src/domain/aggregates/planner_orchestrator.py:149:            PlanPhase.REPLANNING: PlanStatus.WAITING,\nbackend/src/domain/aggregates/planner_orchestrator.py:150:            PlanPhase.ARCHITECTURE: PlanStatus.RUNNING,\nbackend/src/domain/aggregates/planner_orchestrator.py:151:            PlanPhase.ENRICHING: PlanStatus.RUNNING,\nbackend/src/domain/aggregates/planner_orchestrator.py:152:            PlanPhase.AWAITING_REVIEW: PlanStatus.WAITING,\nbackend/src/domain/aggregates/planner_orchestrator.py:153:            PlanPhase.RUNNING: PlanStatus.RUNNING,\nbackend/src/domain/aggregates/planner_orchestrator.py:154:            PlanPhase.REVIEW: PlanStatus.WAITING,\nbackend/src/domain/aggregates/planner_orchestrator.py:155:            PlanPhase.DONE: PlanStatus.IDLE,\nbackend/src/domain/aggregates/planner_orchestrator.py:156:            PlanPhase.FAILED: PlanStatus.BLOCKED,\nbackend/src/domain/aggregates/planner_orchestrator.py:193:    def _guard_phase(self, allowed_from: set[PlanPhase], to: PlanPhase) -> None:\nbackend/src/domain/aggregates/planner_orchestrator.py:264:    def request_pause(self, active_action: bool, reason: str | None = None) -> None:\nbackend/src/domain/aggregates/planner_orchestrator.py:271:            self.active_cycle is None and self.phase not in WORKER_CLAIMABLE_PHASES\nbackend/src/domain/aggregates/planner_orchestrator.py:280:    def settle_pause(self) -> None:\nbackend/src/domain/aggregates/planner_orchestrator.py:284:        self.status = PlanStatus.PAUSED\nbackend/src/domain/aggregates/planner_orchestrator.py:286:    def pause(self, reason: str | None = None) -> None:\nbackend/src/domain/aggregates/planner_orchestrator.py:296:        if self.active_cycle is None and self.phase not in WORKER_CLAIMABLE_PHASES:\nbackend/src/domain/aggregates/planner_orchestrator.py:300:        self.status = PlanStatus.PAUSED\nbackend/src/domain/aggregates/planner_orchestrator.py:302:    def resume(self) -> None:\nbackend/src/domain/aggregates/planner_orchestrator.py:309:        self.status = (\nbackend/src/domain/aggregates/planner_orchestrator.py:311:            if self.active_cycle is not None or self.phase in WORKER_CLAIMABLE_PHASES\nbackend/src/domain/aggregates/planner_orchestrator.py:356:            self.status = PlanStatus.RUNNING\nbackend/src/domain/aggregates/planner_orchestrator.py:371:        self.status = PlanStatus.RUNNING\nbackend/src/domain/aggregates/planner_orchestrator.py:407:        self._set_phase(PlanPhase.RUNNING)\nbackend/src/domain/aggregates/planner_orchestrator.py:430:        self._guard_phase(set(WORKER_PLANNING_PHASES), PlanPhase.FAILED)\nbackend/src/domain/aggregates/planner_orchestrator.py:431:        self._set_phase(PlanPhase.FAILED)\nbackend/src/domain/aggregates/planner_orchestrator.py:434:    def advance_phase(self, to: PlanPhase) -> None:\nbackend/src/domain/aggregates/planner_orchestrator.py:443:        self._guard_phase({PlanPhase.AWAITING_REVIEW}, PlanPhase.RUNNING)\nbackend/src/domain/aggregates/planner_orchestrator.py:444:        self._set_phase(PlanPhase.RUNNING)\nbackend/src/domain/aggregates/planner_orchestrator.py:453:        self._guard_phase({PlanPhase.AWAITING_REVIEW}, PlanPhase.DISCOVERY)\nbackend/src/domain/aggregates/planner_orchestrator.py:456:        self._set_phase(PlanPhase.DISCOVERY)\nbackend/src/domain/aggregates/planner_orchestrator.py:461:        self._guard_phase({PlanPhase.RUNNING}, PlanPhase.REVIEW)\nbackend/src/domain/aggregates/planner_orchestrator.py:462:        self._set_phase(PlanPhase.REVIEW)\nbackend/src/domain/aggregates/planner_orchestrator.py:466:        self._guard_phase({PlanPhase.REVIEW}, PlanPhase.DONE)\nbackend/src/domain/aggregates/planner_orchestrator.py:467:        self._set_phase(PlanPhase.DONE)\nbackend/src/domain/aggregates/planner_orchestrator.py:469:    def begin_replanning(self) -> None:\nbackend/src/domain/aggregates/planner_orchestrator.py:480:        # the legacy PlanPhase projection — which for a replanned cycle is already\nbackend/src/domain/aggregates/planner_orchestrator.py:484:            self._guard_phase({PlanPhase.RUNNING, PlanPhase.REVIEW}, PlanPhase.REPLANNING)\nbackend/src/domain/aggregates/planner_orchestrator.py:498:        self._set_phase(PlanPhase.REPLANNING)\nbackend/src/domain/aggregates/planner_orchestrator.py:508:            {PlanPhase.DISCOVERY, PlanPhase.ARCHITECTURE, PlanPhase.ENRICHING},\nbackend/src/domain/aggregates/planner_orchestrator.py:517:    def commit_replanned_goals(self, new_goals: list[Goal]) -> None:\nbackend/src/domain/aggregates/planner_orchestrator.py:524:        self._guard_phase({PlanPhase.REPLANNING}, PlanPhase.ARCHITECTURE)\nbackend/src/domain/aggregates/planner_orchestrator.py:537:        self._set_phase(PlanPhase.ARCHITECTURE)\nbackend/src/domain/aggregates/planner_orchestrator.py:550:        self.status = self.legacy_mapped_status or PlanStatus.IDLE\nbackend/src/domain/aggregates/planner_orchestrator.py:554:    def active_cycle(self) -> Cycle | None:\nbackend/src/domain/aggregates/planner_orchestrator.py:595:    def legal_actions(self) -> list[str]:\nbackend/src/domain/aggregates/planner_orchestrator.py:597:            return [\"pause\"] if self.status == PlanStatus.RUNNING else []\nbackend/src/domain/aggregates/planner_orchestrator.py:604:        if self.status == PlanStatus.RUNNING:\nbackend/src/domain/aggregates/planner_orchestrator.py:606:        if self.status == PlanStatus.PAUSED:\nbackend/src/domain/aggregates/planner_orchestrator.py:612:        if self.status == PlanStatus.IDLE or (\nbackend/src/domain/aggregates/planner_orchestrator.py:613:            self.status == PlanStatus.WAITING\nbackend/src/domain/aggregates/planner_orchestrator.py:621:    def activity(self) -> str:\nbackend/src/domain/aggregates/planner_orchestrator.py:639:            return \"intent_discovery\" if self.status == PlanStatus.WAITING else \"idle\"\nbackend/src/domain/aggregates/planner_orchestrator.py:652:        self.status = PlanStatus.WAITING\nbackend/src/domain/aggregates/planner_orchestrator.py:732:        self.status = PlanStatus.PAUSED if self.active_cycle is not None else PlanStatus.IDLE\nbackend/src/domain/aggregates/planner_orchestrator.py:741:        self.status = PlanStatus.RUNNING\nbackend/src/domain/aggregates/planner_orchestrator.py:815:        self.status = PlanStatus.RUNNING\nbackend/src/domain/aggregates/planner_orchestrator.py:825:        self.status = PlanStatus