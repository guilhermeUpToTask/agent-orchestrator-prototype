plan_id,\n   353\t                            block_id=block.id,\n   354\t                            stage=block.stage,\n   355\t                            goal_id=fresh.id,\n   356\t                        )\n   357\t                    )\n   358\t                    uow.plans.save(plan)\n   359\t                    self._finish_operation(\n   360\t                        uow,\n   361\t                        operation,\n   362\t                        PlanningOperationStatus.FAILED,\n   363\t                        failure_kind=\"agent_capability\",\n   364\t                        safe_message=str(exc),\n   365\t                    )\n   366\t                    return Signal.PAUSED\n   367\t                plan._set_phase(PlanPhase.RUNNING)\n   368\t            else:\n   369\t                goals = [g.model_copy(deep=True) for g in plan.goals if not g.is_terminal]\n   370\t                for goal in goals:\n   371\t                    if goal.id == target.id:\n   372\t                        goal.tasks = [\n   373\t                            task.model_copy(update={\"position\": index})\n   374\t                            for index, task in enumerate(tasks)\n   375\t                        ]\n   376\t                plan.set_iteration_goals(goals)\n   377\t            plan.clear_planning_retry()  # progressed: disarm any prior backoff gate\n   378\t            plan.bump_version()\n   379\t            self._finish_operation(uow, operation, PlanningOperationStatus.COMMITTED)\n   380\t            uow.plans.save(plan)\n   390\t        \"\"\"A reasoner failure during ENRICHING: re-read + re-guard, then either arm\n   391\t        the plan-level backoff gate (transient, budget left) or fail the plan\n   392\t        (permanent, or budget exhausted). Emits a ReasonerFailed event either way so\n   393\t        the frontend sees it; the transient path returns NOT_READY so the worker\n   394\t        releases and sleeps (the gate blocks re-claim until it opens).\"\"\"\n   395\t        with uow:\n   396\t            plan = uow.plans.get(plan_id)\n   397\t            cyclic = plan.status == PlanStatus.RUNNING and (\n   398\t                plan.active_cycle is not None\n   399\t                or (\n   400\t                    plan.intent_proposal is not None\n   401\t                    and plan.intent_proposal.approved_at is not None\n   402\t                )\n   403\t            )\n   404\t            if (not cyclic and plan.phase not in WORKER_PLANNING_PHASES) or plan.paused:\n   405\t                if operation is not None:\n   406\t                    self._finish_operation(\n   407\t                        uow,\n   408\t                        operation,\n   409\t                        PlanningOperationStatus.FAILED,\n   410\t                        failure_kind=\"planning_interrupted\",\n   411\t                        safe_message=\"Planning stopped because the plan state changed.\",\n   412\t                    )\n   413\t                return Signal.PAUSED  # raced by a human command; theirs wins\n   414\t            phase = plan.activity if cyclic else plan.phase.value\n   415\t            next_attempt = plan.planning_attempts + 1\n   416\t            terminal = not exc.transient or next_attempt >= plan.retry_policy.max_attempts\n   417\t\n   418\t            if terminal:\n   419\t                if cyclic:\n   420\t                    block = PlanBlock(\n   421\t                        id=new_id(),\n   422\t                        kind=\"reasoner_failure\",\n   423\t                        explanation=exc.reason,\n   424\t                        stage=phase,\n   425\t                        legal_resolutions=[\"retry_stage\", \"start_replan\"],\n   475\t                self._finish_operation(\n   476\t                    uow,\n   477\t                    operation,\n   478\t                    PlanningOperationStatus.BACKING_OFF,\n   479\t                    failure_kind=\"reasoner_failure\",\n   480\t                    safe_message=exc.reason,\n   481\t                    retry_at=not_before,\n   482\t                )\n   483\t            uow.plans.save(plan)\n   484\t        return Signal.NOT_READY\n   485\t\n   486\t    async def _bind_and_gate(self, plan_id: str, uow: UnitOfWork) -> Signal:\n   487\t        \"\"\"Every goal carries tasks: bind agents and pause at the gate.\"\"\"\n   488\t        agents = self._agents.list()\n   489\t        default_id = self._agents.default_agent_id()\n   490\t        with uow:\n   491\t            plan = uow.plans.get(plan_id)\n   492\t            if plan.phase != PlanPhase.ENRICHING or plan.paused:\n   493\t                return Signal.PAUSED\n   494\t            fell_back = plan.bind_agents(agents, default_id)\n   495\t            plan.advance_phase(PlanPhase.AWAITING_REVIEW)\n   496\t            plan.bump_version()\n   497\t            for task_id in fell_back:\n   498\t                task = next(t for g in plan.goals for t in g.tasks if t.id == task_id)\n   499\t                uow.outbox.add(\n   500\t                    AgentFellBackToDefault(\n   501\t                        plan_id=plan_id,\n   502\t                        task_id=task_id,\n   503\t                        required_capabilities=list(task.required_capabilities),\n   504\t                    )\n   505\t                )\n   525\t                    task_revision=unit.task_revision,\n   526\t                    evidence_refs=[item.bounded_output_ref for item in evidence],\n   527\t                )\n   528\t            )\n   529\t            uow.outbox.add(\n   530\t                TaskCompleted(\n   531\t                    plan_id=plan_id,\n   532\t                    goal_id=unit.goal_id,\n   533\t                    task_id=unit.task_id,\n   534\t                )\n   535\t            )\n   536\t            uow.plans.save(plan)\n   537\t        return Signal.PAUSED if paused_at_boundary else Signal.CONTINUE\n   538\t\n   539\t    def _candidate_is_current(self, plan_id: str, unit: _Unit, uow: UnitOfWork) -> bool:\n   540\t        \"\"\"Re-read every identity that authorizes a branch merge/finalize.\"\"\"\n   541\t        with uow:\n   542\t            plan = uow.plans.get(plan_id)\n   543\t            if plan.phase != PlanPhase.RUNNING or plan.status != PlanStatus.RUNNING:\n   544\t                return False\n   545\t            if unit.cycle_id is not None and (\n   546\t                plan.active_cycle is None or plan.active_cycle.id != unit.cycle_id\n   547\t            ):\n   548\t                return False\n   549\t            task = self._unit_task(plan, unit)\n   550\t            if (\n   551\t                task.status != Status.RUNNING\n   552\t                or task.revision != unit.task_revision\n   553\t                or task.attempt != unit.attempt\n   554\t            ):\n   555\t                return False\n   556\t            safe_pause_version = plan.pause_requested and plan.version == unit.plan_version + 1\n   557\t            if plan.version != unit.plan_version and not safe_pause_version:\n   558\t                return False\n   559\t            open_attempts = [\n   560\t                attempt\n   561\t                for attempt in uow.executions.list_open_attempts(plan_id)\n   562\t                if attempt.task_id == unit.task_id\n   563\t            ]\n   564\t            if not open_attempts:\n   565\t                return False\n   566\t            latest = max(open_attempts, key=lambda attempt: attempt.number)\n   567\t            return latest.id == unit.execution.id\n   568\t\n   569\t    def _reserve_candidate(self, plan_id: str, unit: _Unit, uow: UnitOfWork) -> bool:\n   570\t        \"\"\"Atomically guard the candidate and reserve its Git promotion.\"\"\"\n   571\t        with uow:\n   572\t            plan = uow.plans.get(plan_id)\n   573\t            if plan.phase != PlanPhase.RUNNING or plan.status != PlanStatus.RUNNING:\n   574\t                return False\n   575\t            if unit.cycle_id is not None and (\n   576\t                plan.active_cycle is None or plan.active_cycle.id != unit.cycle_id\n   577\t            ):\n   578\t                return False\n   579\t            task = self._unit_task(plan, unit)\n   580\t            if (\n   581\t                task.status != Status.RUNNING\n   582\t                or task.revision != unit.task_revision\n   583\t                or task.attempt != unit.attempt\n   584\t            ):\n   585\t                return False\n   586\t            safe_pause_version = plan.pause_requested and plan.version == unit.plan_version + 1\n   587\t            if plan.version != unit.plan_version and not safe_pause_version:\n   588\t                return False\n   589\t            open_attempts = [\n   590\t                attempt\n   615\t                    FailureKind.VERIFICATION_ERROR,\n   616\t                )\n   617\t            goals = cycle.goals\n   618\t        return find_task(find_goal(goals, unit.goal_id), unit.task_id)\n   619\t\n   620\t    def _abandon_stale(self, plan_id: str, unit: _Unit, uow: UnitOfWork) -> None:\n   621\t        with uow:\n   622\t            plan = uow.plans.get(plan_id)\n   623\t            self._finish_execution(\n   624\t                uow,\n   625\t                unit,\n   626\t                ExecutionAttemptStatus.ABANDONED,\n   627\t                ExecutionRunStatus.ABANDONED,\n   628\t            )\n   629\t            task = self._unit_task(plan, unit)\n   630\t            if (\n   631\t                (\n   632\t                    plan.phase != PlanPhase.RUNNING\n   633\t                    or plan.status != PlanStatus.RUNNING\n   634\t                    or (\n   635\t                        unit.cycle_id is not None\n   636\t                        and (plan.active_cycle is None or plan.active_cycle.id != unit.cycle_id)\n   637\t                    )\n   638\t                )\n   639\t                and task.status == Status.RUNNING\n   640\t                and task.revision == unit.task_revision\n   641\t                and task.attempt == unit.attempt\n   642\t            ):\n   643\t                plan.abandon_execution_task(unit.cycle_id, unit.goal_id, unit.task_id)\n   644\t                plan.bump_version()\n   645\t                uow.outbox.add(\n  1045\t            return Signal.NOT_READY\n  1046\t        # Half-open probe: one invocation may proceed after the persisted window.\n  1047\t        # Keep the record until success so a failed probe increments the durable\n  1048\t        # failure count instead of silently resetting the circuit.\n  1049\t        return None\n  1050\t\n  1051\t    # ---- finalize transactions (each opens its own txn) ----\n  1052\t\n  1053\t    def _abandoned_task_status(self, plan: Plan, unit: _Unit) -> Task | None:\n  1054\t        \"\"\"If the plan left RUNNING (mid-flight replan), return the task for the\n  1055\t        tolerant-finalize checks; None means the normal path applies.\"\"\"\n  1056\t        cycle_superseded = unit.cycle_id is not None and (\n  1057\t            plan.active_cycle is None or plan.active_cycle.id != unit.cycle_id\n  1058\t        )\n  1059\t        if (\n  1060\t            plan.phase == PlanPhase.RUNNING\n  1061\t            and plan.status == PlanStatus.RUNNING\n  1062\t            and not cycle_superseded\n  1063\t        ):\n  1064\t            return None\n  1065\t        return self._unit_task(plan, unit)\n  1066\t\n  1067\t    def _finish_execution(\n  1068\t        self,\n  1069\t        uow: UnitOfWork,\n  1070\t        unit: _Unit,\n  1071\t        attempt_status: ExecutionAttemptStatus,\n  1072\t        run_status: ExecutionRunStatus,\n  1073\t        *,\n  1074\t        failure: RuntimeFailure | None = None,\n  1075\t        retry_at: datetime | None = None,\n    35\t_PLANNING_PHASES = frozenset(\n    36\t    {\n    37\t        PlanPhase.DISCOVERY,\n    38\t        PlanPhase.ARCHITECTURE,\n    39\t        PlanPhase.ENRICHING,\n    40\t        PlanPhase.REPLANNING,\n    41\t    }\n    42\t)\n    43\t_GATE_PHASES = frozenset({PlanPhase.AWAITING_REVIEW, PlanPhase.REVIEW})\n    44\t_TERMINAL_PHASES = frozenset({PlanPhase.DONE, PlanPhase.FAILED})\n    45\t\n    46\t\n    47\tclass PlanDispatcher:\n    48\t    \"\"\"Owns the handler wiring and the phase->handler routing.\"\"\"\n    49\t\n    50\t    def __init__(\n    51\t        self,\n    52\t        runner: AgentRunner,\n    53\t        agents: AgentRepository,\n    54\t        workspace: Workspace,\n    55\t        event_sink: AgentEventSink,\n    56\t        clock: Clock,\n    57\t        planning_handler: PhaseHandler | None = None,\n    58\t        verifier: VerificationExecutor | None = None,\n    59\t    ) -> None:\n    60\t        self._execution = ExecutionHandler(runner, agents, workspace, event_sink, clock, verifier)\n    61\t        self._gate = GateHandler()\n    62\t        self._planning = planning_handler  # injected when the reasoner exists (Phase 2.5)\n    63\t\n    64\t    async def advance(self, plan_id: str, uow: UnitOfWork) -> Signal:\n    65\t        with uow:\n    66\t            plan: Plan = uow.plans.get(plan_id)\n    67\t            phase = plan.phase\n    68\t\n    69\t        if plan.active_cycle is not None:\n    70\t            if plan.status.value != \"running\" or plan.pause_requested:\n    71\t                return Signal.PAUSED\n    72\t            head = min(\n    73\t                (goal for goal in plan.execution_goals if not goal.is_terminal),\n    74\t                key=lambda goal: goal.position,\n    75\t                default=None,\n    76\t            )\n    77\t            if head is not None and not head.tasks:\n    78\t                if self._planning is None:\n    79\t                    return Signal.PAUSED\n    80\t                return await self._planning.handle(plan_id, plan, uow)\n    81\t            return await self._execution.handle(plan_id, plan, uow)\n    82\t\n    83\t        if (\n    84\t            plan.status.value == \"running\"\n    85\t            and plan.intent_proposal is not None\n    86\t            and plan.intent_proposal.approved_at is not None\n    87\t            and plan.cycle_draft is None\n    88\t        ):\n    89\t            if self._planning is None:\n    90\t                return Signal.PAUSED\n    91\t            return await self._planning.handle(plan_id, plan, uow)\n    92\t\n    93\t        if phase in _TERMINAL_PHASES:\n    94\t            return Signal.DONE if phase == PlanPhase.DONE else Signal.FAILED\n    95\t\n    96\t        if plan.paused:\n    97\t            # Pause gate armed (the claim predicate normally filters these; this\n    98\t            # covers a pause landing after the claim): release without dispatching.\n    99\t            return Signal.PAUSED\n   100\t\n   101\t        if phase == PlanPhase.RUNNING:\n   102\t            return await self._execution.handle(plan_id, plan, uow)\n   103\t\n   104\t        if phase in _GATE_PHASES:\n   105\t            return await self._gate.handle(plan_id, plan, uow)\n   106\t\n   107\t        if phase in _PLANNING_PHASES:\n   108\t            if self._planning is None:\n   109\t                # Seam not yet wired (pre-Phase-2.5): pause rather than spin.\n   110\t                return await self._gate.handle(plan_id, plan, uow)\n   200\t    assert operation.status.value == \"failed\"\n   201\t    assert operation.failure_kind == \"reasoner_crash\"\n   202\t\n   203\t\n   204\tdef test_message_in_wrong_phase_rejected(env_factory):\n   205\t    env = env_factory()\n   206\t    env.seed(plan_in(PlanPhase.RUNNING, [goal(\"g1\", 0, [task(\"t1\")])]))\n   207\t    chat = InMemoryChatStore()\n   208\t\n   209\t    with pytest.raises(InvalidEditError):\n   210\t        turn(env, chat, ScriptedReasoner(), \"hello\")\n   211\t    assert chat.list(\"p1\") == []  # rejected before anything was persisted\n   212\t\n   213\t\n   214\tdef test_replanning_commit_proposes_replan_intent_without_mutating_cycle(env_factory):\n   215\t    env = env_factory()\n   216\t    done_task = task(\"t1\")\n   217\t    done_task.start()\n   218\t    done_task.complete(TaskResult(status=\"success\", output=\"ok\"))\n   219\t    done_goal = goal(\"g1\", 0, [done_task])\n   220\t    done_goal.start()\n   221\t    done_goal.complete()\n   222\t    plan = plan_in(PlanPhase.REPLANNING)\n   223\t    plan.status = PlanStatus.PAUSED\n   224\t    plan.cycles = [\n   225\t        Cycle(\n   226\t            id=\"cycle-1\",\n   227\t            intent_proposal_id=\"intent-old\",\n   228\t            draft_id=\"draft-old\",\n   229\t            status=CycleStatus.ACTIVE,\n   230\t            goals=[done_goal],\n   231\t            started_at=env.clock.now(),\n   232\t        )\n   233\t    ]\n   234\t    env.seed(plan)\n   235\t    chat = InMemoryChatStore()\n   236\t    reasoner = ScriptedReasoner(\n   237\t        replies=[\n   238\t            ReasonerReply(\n   239\t                message=\"replan intent\",\n   240\t                intent=IntentCandidate(\n   241\t                    normalized_brief=\"Harden the service.\",\n   242\t                    objective=\"Harden the completed service\",\n   243\t                ),\n   244\t            )\n   245\t        ]\n   246\t    )\n   247\t\n   248\t    result = turn(env, chat, reasoner, \"now harden it\", replanning=True)\n   249\t\n   250\t    assert (result.committed, result.phase) == (True, PlanPhase.REPLANNING)\n   251\t    stored = env.stored(\"p1\")\n   252\t    assert stored.iteration == 1\n   253\t    assert stored.active_cycle is not None\n   254\t    assert [g.id for g in stored.active_cycle.goals] == [\"g1\"]\n   255\t    assert stored.intent_proposal is not None\n   256\t    assert stored.intent_proposal.source_cycle_id == \"cycle-1\"\n   257\t    assert reasoner.converse_calls[0][0] == \"replanning\"\n   258\t\n   259\t\n   260\tdef test_replan_from_blocked_cycle_settles_work_before_message(env_factory):\n   261\t    env = env_factory()\n   262\t    failed = task(\"failed\")\n   263\t    failed.fail(\"terminal failure\")\n   264\t    pending = task(\"pending\", 1)\n   265\t    running_goal = goal(\"g1\", 0, [failed, pending])\n   266\t    running_goal.start()\n   267\t    cycle = Cycle(\n   268\t        id=\"cycle-1\",\n   269\t        intent_proposal_id=\"intent-old\",\n   270\t        draft_id=\"draft-old\",\n   271\t        goals=[running_goal],\n   272\t        started_at=env.clock.now(),\n   273\t    )\n   274\t    plan = plan_in(PlanPhase.RUNNING)\n   275\t    plan.status = PlanStatus.BLOCKED\n   276\t    plan.cycles = [cycle]\n   277\t    plan.block = PlanBlock(\n   278\t        id=\"block-1\",\n   279\t        kind=\"execution_failure\",\n   280\t        explanation=\"terminal failure\",\n   281\t        stage=\"implementation\",\n   282\t        goal_id=\"g1\",\n   283\t        task_id=\"failed\",\n   284\t        legal_resolutions=[\"retry_stage\", \"edit_task\", \"start_replan\"],\n   285\t        created_at=env.clock.now(),\n   286\t    )\n   287\t    env.seed(plan)\n   288\t    request_replan(\"p1\", env.uow)\n   289\t\n   290\t    settled = env.stored(\"p1\")\n   291\t    assert settled.phase == PlanPhase.REPLANNING\n   292\t    assert settled.status == PlanStatus.PAUSED\n   293\t    assert settled.block is not None and settled.block.resolution == \"start_replan\"\n   294\t    assert all(item.status == Status.SKIPPED for item in settled.active_cycle.goals[0].tasks)\n   295\t\n   296\t    chat = InMemoryChatStore()\n   297\t    reasoner = ScriptedReasoner(\n   298\t        replies=[\n   299\t            ReasonerReply(\n   300\t                message=\"replan intent\",\n   301\t                intent=IntentCandidate(\n   302\t                    normalized_brief=\"Harden the service.\",\n   303\t                    objective=\"Harden the service\",\n   304\t                ),\n   305\t            )\n   306\t        ]\n   307\t    )\n   308\t    result = turn(env, chat, reasoner, \"harden it\", replanning=True)\n   309\t    assert result.committed is True\n   310\t    assert result.phase == PlanPhase.REPLANNING\n   311\t\n   312\t\n   313\t# ---------------------------------------------------------------------------\n   314\t# ARCHITECTURE — the no-LLM passthrough\n   315\t# ---------------------------------------------------------------------------\n   316\t\n   317\t\n   318\tdef test_architecture_passthrough_advances_without_reasoner(env_factory):\n   319\t    env = env_factory()\n   320\t    goals = [goal(\"g1\", 0, [task(\"t1\")])]\n   321\t    env.seed(plan_in(PlanPhase.ARCHITECTURE, goals))\n   322\t    reasoner = ScriptedReasoner()  # any reasoner call would pop an empty script\n   323\t\n   324\t    signal = asyncio.run(handler(reasoner, env).handle(\"p1\", env.stored(\"p1\"), env.uow))\n   325\t\n   326\t    assert signal == Signal.CONTINUE\n   327\t    stored = env.stored(\"p1\")\n   328\t    assert stored.phase == PlanPhase.ENRICHING\n   329\t    assert [g.id for g in stored.goals] == [\"g1\"]  # the goal set is untouched\n   330\t    assert stored.goals[0].tasks[0].id == \"t1\"\n     1\tfrom __future__ import annotations\n     2\t\n     3\tfrom datetime import datetime, timezone\n     4\t\n     5\timport pytest\n     6\t\n     7\tfrom src.domain.aggregates.planner_orchestrator import Plan, PlanPhase\n     8\tfrom src.domain.entities.planning_artifacts import Cycle, PlanStatus\n     9\tfrom src.domain.errors.tasks_errors import InvalidTransitionError\n    10\t\n    11\tNOW = datetime(2026, 7, 14, tzinfo=timezone.utc)\n    12\t\n    13\t\n    14\tdef cyclic_plan_with_replanning_legacy_phase() -> Plan:\n    15\t    plan = Plan(id=\"plan-1\", project_id=\"project-1\", brief=\"brief\")\n    16\t    plan.cycles = [\n    17\t        Cycle(\n    18\t            id=\"cycle-1\",\n    19\t            intent_proposal_id=\"intent-1\",\n    20\t            draft_id=\"draft-1\",\n    21\t            started_at=NOW,\n    22\t            goals=[],\n    23\t        )\n    24\t    ]\n    25\t    plan._set_phase(PlanPhase.REPLANNING)\n    26\t    plan.status = PlanStatus.RUNNING\n    27\t    return plan\n    28\t\n    29\t\n    30\tdef test_cyclic_running_plan_can_pause_with_replanning_legacy_phase() -> None:\n    31\t    plan = cyclic_plan_with_replanning_legacy_phase()\n    32\t\n    33\t    plan.request_pause(active_action=False)\n    34\t\n    35\t    assert plan.paused\n    36\t    assert plan.status == PlanStatus.PAUSED\n    37\t\n    38\t\n    39\tdef test_cyclic_plan_can_begin_replanning_with_replanning_legacy_phase() -> None:\n    40\t    plan = cyclic_plan_with_replanning_legacy_phase()\n    41\t\n    42\t    plan.begin_replanning()\n    43\t\n    44\t    assert plan.phase == PlanPhase.REPLANNING\n    45\t\n    46\t\n    47\tdef test_legacy_plan_cannot_begin_replanning_from_replanning() -> None:\n    48\t    plan = Plan(id=\"plan-1\", brief=\"brief\", phase=PlanPhase.REPLANNING)\n    49\t\n    50\t    with pytest.raises(InvalidTransitionError):\n    51\t        plan.begin_replanning()\n    52\t\n    53\t\n    54\tdef test_legacy_plan_cannot_pause_from_non_claimable_phase() -> None:\n    55\t    plan = Plan(id=\"plan-1\", brief=\"brief\", phase=PlanPhase.REPLANNING)\n    56\t\n    57\t    with pytest.raises(InvalidTransitionError):\n    58\t        plan.pause()\n     1\t\"\"\"The human pause gate + the manual retry (un-freeze #3), on both backends via\n     2\tenv_factory: the claim predicate must skip a paused plan identically on the fake\n     3\tand the real SQLite, the auto-pause must land in the same transaction as the\n     4\tterminal task failure, while resume and targeted retry remain separate commands.\n     5\tA human retry bypasses should_retry and starts a fresh policy cycle for one task.\n     6\t\"\"\"\n     7\t\n     8\tfrom __future__ import annotations\n     9\t\n    10\timport asyncio\n    11\tfrom datetime import timedelta\n    12\t\n    13\timport pytest\n    14\t\n    15\tfrom src.domain.aggregates.planner_orchestrator import Plan, PlanPhase\n    16\tfrom src.domain.entities.goal import Goal\n    17\tfrom src.domain.entities.planning_artifacts import (\n    18\t    Cycle,\n    19\t    PlanBlock,\n    20\t    PlanStatus,\n    21\t)\n    22\tfrom src.domain.entities.task import Task\n    23\tfrom src.domain.errors.tasks_errors import InvalidTransitionError\n    24\tfrom src.domain.policies.retry_policies import RetryPolicy\n    25\tfrom src.domain.value_objects.lifecycle import FailureKind, Status\n    26\t\n    27\tfrom src.app.execution_records import RuntimeCircuit\n    28\tfrom src.app.testing.fakes import DummyBehavior, InMemoryCapabilityRepository\n    29\tfrom src.app.use_cases.apply_edit import UpdateTask, apply_edit\n    30\tfrom src.app.use_cases.advance_plan import advance_plan\n    31\tfrom src.app.use_cases.control import finish_review\n    32\tfrom src.app.use_cases.pause_resume import (\n    33\t    pause_plan,\n    34\t    resume_plan,\n    35\t    retry_planning_stage,\n    36\t    retry_task,\n    37\t)\n    38\t\n    39\t\n    40\tdef task(tid: str, position: int, **kwargs) -> Task:\n    41\t    return Task(id=tid, name=tid, position=position, description=\"\", agent_id=\"a1\", **kwargs)\n    42\t\n    43\t\n    44\tdef running_plan(tasks: list[Task] | None = None, retry_max: int = 3) -> Plan:\n    45\t    return Plan(\n    46\t        project_id=\"project-1\",\n    47\t        id=\"p1\",\n    48\t        brief=\"b\",\n    49\t        phase=PlanPhase.RUNNING,\n    50\t        retry_policy=RetryPolicy(max_attempts=retry_max),\n    51\t        goals=[\n    52\t            Goal(\n    53\t                id=\"g1\",\n    54\t                name=\"g1\",\n    55\t                position=0,\n    56\t                description=\"\",\n    57\t                tasks=tasks if tasks is not None else [task(\"t0\", 0)],\n    58\t            )\n    59\t        ],\n    60\t    )\n    61\t\n    62\t\n    63\tasync def drive(env, max_steps: int = 50) -> str:\n    64\t    signal = \"continue\"\n    65\t    steps = 0\n    66\t    while signal in (\"continue\", \"not_ready\") and steps < max_steps:\n    67\t        signal = await advance_plan(\"p1\", *env.args)\n    68\t        if signal == \"not_ready\":\n    69\t            env.clock.advance(120)\n    70\t        steps += 1\n    71\t    return signal\n    72\t\n    73\t\n    74\t# ---- the claim gate ----\n    75\tdef test_paused_plan_is_never_claimed(env_factory):\n    76\t    env = env_factory()\n    77\t    env.seed(running_plan())\n    78\t    pause_plan(\"p1\", env.uow, \"operator pause\")\n    79\t\n    80\t    assert env.uow.plans.claim_one_unit(\"w1\", lease_seconds=60) is None\n    81\t\n    82\t\n    83\tdef test_pause_survives_lease_expiry_and_time(env_factory):\n    84\t    \"\"\"The pause gate is durable state, not a lease: no amount of clock advance\n    85\t    (dead worker, restart) makes a paused plan claimable.\"\"\"\n    86\t    env = env_factory()\n    87\t    env.seed(running_plan())\n    88\t    pause_plan(\"p1\", env.uow, None)\n    89\t\n    90\t    env.clock.advance(3600)\n    91\t    assert env.uow.plans.claim_one_unit(\"w1\", lease_seconds=60) is None\n    92\t\n    93\t    resume_plan(\"p1\", env.uow)\n    94\t    claimed = env.uow.plans.claim_one_unit(\"w1\", lease_seconds=60)\n    95\t    assert claimed is not None and claimed.id == \"p1\"\n    96\t\n    97\t\n    98\tdef test_advance_on_paused_plan_dispatches_nothing(env_factory):\n    99\t    env = env_factory()\n   100\t    env.seed(running_plan())\n   101\t    pause_plan(\"p1\", env.uow, None)\n   102\t\n   103\t    signal = asyncio.run(advance_plan(\"p1\", *env.args))\n   104\t\n   105\t    assert signal == \"paused\"\n   106\t    assert env.runner.calls == {}  # no task ran\n   107\t\n   108\t\n   109\t# ---- pause command semantics ----\n   110\tdef test_pause_rejected_outside_worker_claimable_phases(env_factory):\n   111\t    env = env_factory()\n   112\t    plan = running_plan()\n   113\t    plan.phase = PlanPhase.AWAITING_REVIEW  # gates are already paused by design\n   114\t    env.seed(plan)\n   115\t\n   116\t    with pytest.raises(InvalidTransitionError):\n   117\t        pause_plan(\"p1\", env.uow, None)\n   118\t\n   119\t\n   120\tdef test_pause_is_idempotent(env_factory):\n   121\t    env = env_factory()\n   122\t    env.seed(running_plan())\n   123\t    pause_plan(\"p1\", env.uow, \"first\")\n   124\t    pause_plan(\"p1\", env.uow, \"second\")  # no-op: no bump, no second event\n   125\t\n   126\t    assert env.outbox_types().count(\"PlanPaused\") == 1\n   127\t    assert env.stored(\"p1\").paused\n   128\t\n   129\t\n   130\tdef test_resume_unpaused_raises_invalid_transition(env_factory):\n","exit_code":0,"status":"completed"}}
{"type":"item.started","item":{"id":"item_9","type":"command_execution","command":"/bin/bash -lc \"rg -n \\\"ADR-003|discovery.*WAITING|replanning.*WAITING|legacy.*mapping|PlanStatus\\\" . --glob '*.md' --glob '*.py' | head -200; rg -n \\\"class IntentProposal|class ReviewGate|class PlanStatus\\\" backend/src/domain/entities/planning_artifacts.py; nl -ba backend/src/domain/entities/planning_artifacts.py | sed -n '1,180p'; nl -ba backend/tests/unit/orchestration/test_replan_loop.py | sed -n '60,160p'; nl -ba backend/tests/unit/orchestration/test_cyclic_project_plan.py | sed -n '80,150p'\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
{"type":"item.completed","item":{"id":"item_9","type":"command_execution","command":"/bin/bash -lc \"rg -n \\\"ADR-003|discovery.*WAITING|replanning.*WAITING|legacy.*mapping|PlanStatus\\\" . --glob '*.md' --glob '*.py' | head -200; rg -n \\\"class IntentProposal|class ReviewGate|class PlanStatus\\\" backend/src/domain/entities/planning_artifacts.py; nl -ba backend/src/domain/entities/planning_artifacts.py | sed -n '1,180p'; nl -ba backend/tests/unit/orchestration/test_replan_loop.py | sed -n '60,160p'; nl -ba backend/tests/unit/orchestration/test_cyclic_project_plan.py | sed -n '80,150p'\"","aggregated_output":"./README.md:334:The system is a **working prototype past its core-integration milestone**: the current architecture is the cyclic `ProjectPlan` lifecycle (`ProjectPlan → IntentProposal → CycleDraft → GoalContract`, per [ADR-003](docs/decisions/adr-003-cyclic-project-plan-lifecycle.md)) — the conversational reasoner (stub + OpenAI-compatible LLM), catalog-driven runtime resolution, the git-worktree workspace, live SSE, and the full-cycle test walk are all in place, with `mypy` at zero errors and the truth-test suite green. The legacy nine-phase `PlanPhase` machine remains only as a compatibility projection for migrated plans and existing clients (see [`docs/architecture/known-issues.md`](docs/architecture/known-issues.md)). Known operational defects (verified, with reproduction notes) are tracked in [`docs/architecture/known-issues.md`](docs/architecture/known-issues.md) and scheduled in [`ROADMAP.md`](ROADMAP.md) — the two most important: the default lease/timeout combination permits double execution of long tasks under multiple workers, and a poisoned plan can starve a single-worker deployment.\n./CLAUDE.md:40:   - 🔒 The domain is FROZEN (roadmap Phase 0). Additions require a deliberate, decision-logged un-freeze — the full, authoritative list lives in [`docs/decisions/decision-log.md`](docs/decisions/decision-log.md) and currently runs through **un-freeze #9** (decision 49, 2026-07-20). The pivotal one is **#4 — [ADR-003](docs/decisions/adr-003-cyclic-project-plan-lifecycle.md) (decision 43, 2026-07-14): the cyclic `ProjectPlan` lifecycle**, which superseded the terminal nine-phase machine (see Key Concepts below). Earlier un-freezes: **#1** agent-registry runtime resolution (2026-07-05); **#2** the planning backoff gate (2026-07-08); **#3** the pause gate + recoverable auto-pause + editable-while-paused (2026-07-09). Do not re-summarize the whole list here — link the decision log.\n./CLAUDE.md:43:5. **The lease replaces the reconciler**: `claim_one_unit` / `heartbeat` / `release` on the plan row. A plan is claimable when its root `PlanStatus` is `running` and it is bound to a project, not paused, and unclaimed-or-lease-expired (`_CLAIM_SQL`: `status='running' AND project_id IS NOT NULL AND paused=0 AND pause_requested=0`); a dead worker's lease expires and any worker reclaims from persisted state. Mid-action heartbeats renew the lease; the worker tick reports *progress*, not claiming (no-progress → sleep). Startup reconciliation closes stale RUNNING attempt rows only when the plan has no live claim — it never invents task outcomes.\n./CLAUDE.md:49:**The cyclic project-plan lifecycle** is the current authority ([ADR-003](docs/decisions/adr-003-cyclic-project-plan-lifecycle.md) / decision 43, un-freeze #4, accepted 2026-07-14; full detail in [`docs/architecture/plan-lifecycle.md`](docs/architecture/plan-lifecycle.md)). A `ProjectDefinition` owns exactly one long-lived `Plan` (the root aggregate — the class is still named `Plan` in `planner_orchestrator.py`) bound to an immutable `project_id`. **The root is never terminal.** Its only persisted lifecycle status is `PlanStatus` = `running | paused | waiting | blocked | idle`; `activity` is **derived** (open intent/draft/gate/block, active cycle, earliest non-terminal goal, current task), never a second stored enum or cursor. The API also serves `status_reason` + `legal_actions`; the frontend renders those facts rather than rebuilding transition rules.\n./docs/history/planning/2026-07-14-cyclic-project-plan-implementation.md:6:verification used for ADR-003. It supersedes the lifecycle-freeze instruction\n./docs/history/planning/2026-07-14-cyclic-project-plan-implementation.md:22:| Documentation | decision log and architecture guides | ADR-003 unfreeze, cyclic lifecycle guide, current compatibility debt |\n./docs/history/planning/2026-07-14-cyclic-project-plan-implementation.md:32:   API, and frontend behavior; recorded ADR-003 and decision 43.\n./docs/history/planning/2026-07-14-cyclic-project-plan-implementation.md:35:2. Added PlanStatus, Cycle, IntentProposal, CycleDraft, ReviewGate, PlanBlock,\n./docs/history/planning/2026-07-14-cyclic-project-plan-implementation.md:38:   fake/SQLite parity, migration 0009, and deterministic legacy mapping tests.\n./docs/architecture/overview.md:89:Domain contracts change only through a recorded unfreeze. ADR-003 deliberately\n./docs/architecture/known-issues.md:11:  by `PlanStatus` plus open artifacts and active-cycle state, but deleting\n./docs/architecture/plan-lifecycle.md:24:`PlanStatus` is the only persisted root lifecycle status:\n./docs/decisions/decision-log.md:5:and [ADR-003](adr-003-cyclic-project-plan-lifecycle.md).*\n./docs/decisions/decision-log.md:76:    - **Reopen-discovery.** New guarded `reopen_discovery()` (`AWAITING_REVIEW → DISCOVERY`, clears pause) for \"request changes\" at the pre-execution gate. The next commit flows through `set_iteration_goals`, which **replaces** the un-executed roadmap (terminal history kept) — distinct from REPLANNING, whose commit appends and bumps `iteration`.\n./docs/decisions/decision-log.md:87:43. **Domain unfreeze #4 (2026-07-14): cyclic ProjectPlan + deterministic TDD execution.** [ADR-003](adr-003-cyclic-project-plan-lifecycle.md) deliberately supersedes the terminal nine-phase lifecycle and the incompatible parts of decisions 1-9, 13, 17-18, 22, 24-25, 34-35, and unfreezes 2-3. One immutable project owns one long-lived plan; root status is `running | paused | waiting | blocked | idle`; finite work lives in cycles; intent, architecture, and publication are exact-revision review gates; pause and retry are separate; runs are monotonic and leased; task completion requires protected, independently verified executable evidence; and verified task-to-goal-to-cycle staging produces one recorded output disposition per cycle. Legacy rows are preserved through the explicit mapping and project-binding quarantine in ADR-003; ownership and approval/publication history are never fabricated.\n./docs/decisions/decision-log.md:94:46. **Domain unfreeze #6 (2026-07-16): executable recovery and source-preserving replan review.** Structured block actions are now commands rather than display-only strings: execution blocks target one failed task; provider-capacity retry clears only the evidence-linked runtime/provider/model circuit; reasoner blocks retry their current planning stage; and `edit_task` permits a semantic correction of only the blocked target before resolving that block. Resume remains availability-only, absolute attempt identity and unrelated gates/tasks are preserved, and block resolution plus aggregate state plus outbox event commit in one UoW/CAS transaction. Plan detail now exports typed cycles, proposal, draft, gate, and block artifacts. The console renders retry/edit controls, explicit replan intent, locked source-cycle history, and a side-by-side editable CycleDraft. Replan reasoner context includes source-cycle results and unfinished work and explicitly forbids recreating DONE work. No root status or phase transition was added; this deliberately unfreezes only recovery guards, recovery commands, and replan context/review presentation under ADR-003.\n./docs/decisions/decision-log.md:117:cyclic plan's advertised `legal_actions` derive from root `PlanStatus` + open\n./docs/decisions/adr-003-cyclic-project-plan-lifecycle.md:1:# ADR-003: Cyclic project-plan lifecycle and deterministic execution\n./backend/tests/integration/test_default_cyclic_execution.py:19:    PlanStatus,\n./backend/tests/integration/test_default_cyclic_execution.py:80:        status=PlanStatus.IDLE,\n./backend/tests/integration/test_default_cyclic_execution.py:148:    assert completed.status == PlanStatus.WAITING\n./backend/tests/integration/test_full_cycle_llm.py:25:from src.domain.entities.planning_artifacts import PlanStatus\n./backend/tests/integration/test_full_cycle_llm.py:168:    assert plan.status == PlanStatus.WAITING\n./backend/tests/integration/test_tdd_execution.py:29:from src.domain.entities.planning_artifacts import Cycle, PlanStatus\n./backend/tests/integration/test_tdd_execution.py:145:        status=PlanStatus.RUNNING,\n./backend/tests/integration/test_tdd_execution.py:185:        assert after_impl.status == PlanStatus.BLOCKED\n./backend/tests/integration/test_tdd_execution.py:272:        status=PlanStatus.RUNNING,\n./backend/tests/integration/test_tdd_execution.py:378:        status=PlanStatus.RUNNING,\n./backend/tests/integration/test_tdd_execution.py:410:    assert blocked.status == PlanStatus.BLOCKED\n./backend/tests/unit/execution/test_execution_safety.py:34:    PlanStatus,\n./backend/tests/unit/execution/test_execution_safety.py:80:        status=PlanStatus.RUNNING,\n./backend/tests/unit/execution/test_execution_safety.py:338:    assert stored.status == PlanStatus.BLOCKED\n./backend/tests/integration/test_api.py:46:    from src.domain.entities.planning_artifacts import PlanBlock, PlanStatus\n./backend/tests/integration/test_api.py:55:        status=PlanStatus.BLOCKED,\n./backend/tests/integration/test_api.py:56:        legacy_mapped_status=PlanStatus.RUNNING,\n./backend/tests/integration/test_api.py:78:    assert rebound.status == PlanStatus.RUNNING\n./backend/tests/integration/test_api.py:1050:    from src.domain.entities.planning_artifacts import PlanStatus\n./backend/tests/int