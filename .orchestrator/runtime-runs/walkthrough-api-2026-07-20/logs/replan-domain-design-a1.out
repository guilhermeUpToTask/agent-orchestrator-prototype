G or plan.status != PlanStatus.RUNNING:\n./backend/src/app/handlers/execution_handler.py:573:            if plan.phase != PlanPhase.RUNNING or plan.status != PlanStatus.RUNNING:\n./backend/src/app/handlers/execution_handler.py:633:                    or plan.status != PlanStatus.RUNNING\n./backend/src/app/handlers/execution_handler.py:1061:            and plan.status == PlanStatus.RUNNING\n./backend/src/app/use_cases/conversation.py:31:    PlanStatus,\n./backend/src/app/use_cases/conversation.py:101:            PlanStatus.IDLE,\n./backend/src/app/use_cases/conversation.py:102:            PlanStatus.WAITING,\n./backend/src/app/use_cases/conversation.py:106:            PlanStatus.PAUSED,\n./backend/src/app/use_cases/conversation.py:107:            PlanStatus.BLOCKED,\n./backend/src/app/use_cases/conversation.py:108:            PlanStatus.IDLE,\n./backend/src/app/use_cases/conversation.py:114:            if not (plan.status == PlanStatus.WAITING and settled):\n13:class PlanStatus(str, Enum):\n53:class ReviewGate(BaseModel):\n99:class IntentProposal(BaseModel):\n     1\t\"\"\"Versioned planning, review, block, and cycle domain objects.\"\"\"\n     2\t\n     3\tfrom __future__ import annotations\n     4\t\n     5\tfrom datetime import datetime\n     6\tfrom enum import Enum\n     7\t\n     8\tfrom pydantic import BaseModel, Field, model_validator\n     9\t\n    10\tfrom src.domain.entities.goal import Goal\n    11\t\n    12\t\n    13\tclass PlanStatus(str, Enum):\n    14\t    RUNNING = \"running\"\n    15\t    PAUSED = \"paused\"\n    16\t    WAITING = \"waiting\"\n    17\t    BLOCKED = \"blocked\"\n    18\t    IDLE = \"idle\"\n    19\t\n    20\t\n    21\tclass CycleStatus(str, Enum):\n    22\t    ACTIVE = \"active\"\n    23\t    COMPLETED = \"completed\"\n    24\t    SUPERSEDED = \"superseded\"\n    25\t    CANCELLED = \"cancelled\"\n    26\t\n    27\t\n    28\tclass ProposalKind(str, Enum):\n    29\t    INITIAL = \"initial\"\n    30\t    REPLAN = \"replan\"\n    31\t\n    32\t\n    33\tclass OutputDisposition(str, Enum):\n    34\t    OPEN_PR = \"open_pr\"\n    35\t    MERGE = \"merge\"\n    36\t    RETAIN_BRANCH = \"retain_branch\"\n    37\t    DISCARD = \"discard\"\n    38\t\n    39\t\n    40\tclass ReviewSubjectType(str, Enum):\n    41\t    INTENT = \"intent\"\n    42\t    CYCLE_DRAFT = \"cycle_draft\"\n    43\t    CYCLE_COMPLETION = \"cycle_completion\"\n    44\t\n    45\t\n    46\tclass ReviewResolution(BaseModel):\n    47\t    decision: str\n    48\t    resolved_at: datetime\n    49\t    resolved_by: str | None = None\n    50\t    note: str | None = None\n    51\t\n    52\t\n    53\tclass ReviewGate(BaseModel):\n    54\t    id: str\n    55\t    subject_type: ReviewSubjectType\n    56\t    subject_id: str\n    57\t    subject_revision: int\n    58\t    allowed_decisions: list[str]\n    59\t    continuation: str\n    60\t    resolution: ReviewResolution | None = None\n    61\t    invalidated_at: datetime | None = None\n    62\t\n    63\t    @property\n    64\t    def unresolved(self) -> bool:\n    65\t        return self.resolution is None and self.invalidated_at is None\n    66\t\n    67\t\n    68\tclass PlanBlock(BaseModel):\n    69\t    id: str\n    70\t    kind: str\n    71\t    explanation: str\n    72\t    stage: str\n    73\t    goal_id: str | None = None\n    74\t    task_id: str | None = None\n    75\t    task_revision: int | None = None\n    76\t    run_id: str | None = None\n    77\t    evidence_refs: list[str] = Field(default_factory=list)\n    78\t    legal_resolutions: list[str] = Field(default_factory=list)\n    79\t    created_at: datetime\n    80\t    resolved_at: datetime | None = None\n    81\t    resolution: str | None = None\n    82\t\n    83\t    @model_validator(mode=\"after\")\n    84\t    def add_agent_binding_retry_for_legacy_blocks(self) -> \"PlanBlock\":\n    85\t        \"\"\"Older agent-capability blocks predate executable registry recovery.\"\"\"\n    86\t        if (\n    87\t            self.kind == \"agent_capability\"\n    88\t            and self.active\n    89\t            and \"retry_stage\" not in self.legal_resolutions\n    90\t        ):\n    91\t            self.legal_resolutions = [\"retry_stage\", *self.legal_resolutions]\n    92\t        return self\n    93\t\n    94\t    @property\n    95\t    def active(self) -> bool:\n    96\t        return self.resolved_at is None\n    97\t\n    98\t\n    99\tclass IntentProposal(BaseModel):\n   100\t    id: str\n   101\t    kind: ProposalKind\n   102\t    base_plan_version: int\n   103\t    source_cycle_id: str | None = None\n   104\t    objective: str\n   105\t    scope: list[str] = Field(default_factory=list)\n   106\t    constraints: list[str] = Field(default_factory=list)\n   107\t    exclusions: list[str] = Field(default_factory=list)\n   108\t    revision: int = 1\n   109\t    planner_session_ref: str | None = None\n   110\t    approved_at: datetime | None = None\n   111\t    cancelled_at: datetime | None = None\n   112\t\n   113\t\n   114\tclass GoalOutline(BaseModel):\n   115\t    key: str\n   116\t    name: str\n   117\t    objective: str\n   118\t    position: int\n   119\t    depends_on: list[str] = Field(default_factory=list)\n   120\t\n   121\t\n   122\tclass CycleDraft(BaseModel):\n   123\t    id: str\n   124\t    intent_proposal_id: str\n   125\t    base_plan_version: int\n   126\t    source_cycle_id: str | None = None\n   127\t    goals: list[GoalOutline]\n   128\t    revision: int = 1\n   129\t    unfinished_source_treatment: str | None = None\n   130\t    approved_at: datetime | None = None\n   131\t    cancelled_at: datetime | None = None\n   132\t\n   133\t    @model_validator(mode=\"after\")\n   134\t    def validate_dependencies(self) -> \"CycleDraft\":\n   135\t        keys = [goal.key for goal in self.goals]\n   136\t        if len(keys) != len(set(keys)):\n   137\t            raise ValueError(\"cycle draft goal keys must be unique\")\n   138\t        known = set(keys)\n   139\t        positions = {goal.key: goal.position for goal in self.goals}\n   140\t        graph: dict[str, list[str]] = {}\n   141\t        for goal in self.goals:\n   142\t            if goal.key in goal.depends_on:\n   143\t                raise ValueError(f\"goal '{goal.key}' cannot depend on itself\")\n   144\t            unknown = sorted(set(goal.depends_on) - known)\n   145\t            if unknown:\n   146\t                raise ValueError(f\"goal '{goal.key}' has unknown dependencies: {unknown}\")\n   147\t            later = sorted(\n   148\t                dependency\n   149\t                for dependency in goal.depends_on\n   150\t                if positions[dependency] >= goal.position\n   151\t            )\n   152\t            if later:\n   153\t                raise ValueError(f\"goal '{goal.key}' dependencies must precede it: {later}\")\n   154\t            graph[goal.key] = list(goal.depends_on)\n   155\t\n   156\t        visiting: set[str] = set()\n   157\t        visited: set[str] = set()\n   158\t\n   159\t        def visit(key: str) -> None:\n   160\t            if key in visiting:\n   161\t                raise ValueError(\"cycle draft dependencies must be acyclic\")\n   162\t            if key in visited:\n   163\t                return\n   164\t            visiting.add(key)\n   165\t            for dependency in graph[key]:\n   166\t                visit(dependency)\n   167\t            visiting.remove(key)\n   168\t            visited.add(key)\n   169\t\n   170\t        for key in keys:\n   171\t            visit(key)\n   172\t        return self\n   173\t\n   174\t\n   175\tclass Cycle(BaseModel):\n   176\t    id: str\n   177\t    intent_proposal_id: str\n   178\t    draft_id: str\n   179\t    status: CycleStatus = CycleStatus.ACTIVE\n   180\t    goals: list[Goal] = Field(default_factory=list)\n    60\t    clock = FakeClock()\n    61\t    repo = InMemoryPlanRepository(clock)\n    62\t    repo.add(plan)\n    63\t    outbox = InMemoryOutbox()\n    64\t    uow = InMemoryUnitOfWork(repo, outbox)\n    65\t    runner = DummyAgentRunner(script or {})\n    66\t    agents = InMemoryAgentRepository([agent()], default_id=\"a1\")\n    67\t    return repo, outbox, uow, runner, agents, NoOpWorkspace(), CollectingEventSink(), clock\n    68\t\n    69\t\n    70\t# ===== entering REPLANNING =====\n    71\tdef test_request_replan_mid_running_skips_pending_work():\n    72\t    \"\"\"Skip place ONE: at request time every PENDING goal (and PENDING tasks of a\n    73\t    RUNNING goal) is skipped; the in-flight RUNNING task is left to finalize.\"\"\"\n    74\t    running_goal = goal(\n    75\t        \"g1\",\n    76\t        0,\n    77\t        [task(\"g1t0\", 0, Status.DONE), task(\"g1t1\", 1, Status.RUNNING), task(\"g1t2\", 2)],\n    78\t        status=Status.RUNNING,\n    79\t    )\n    80\t    pending_goal = goal(\"g2\", 1, [task(\"g2t0\", 0)])\n    81\t    plan = Plan(\n    82\t        project_id=\"project-1\",\n    83\t        id=\"p1\",\n    84\t        brief=\"b\",\n    85\t        phase=PlanPhase.RUNNING,\n    86\t        goals=[running_goal, pending_goal],\n    87\t    )\n    88\t    repo, outbox, uow, *_ = harness(plan)\n    89\t\n    90\t    request_replan(\"p1\", uow)\n    91\t    saved = repo.get(\"p1\")\n    92\t    assert saved.phase == PlanPhase.REPLANNING\n    93\t    assert saved.goals[1].status == Status.SKIPPED  # pending goal skipped\n    94\t    assert saved.goals[1].tasks[0].status == Status.SKIPPED\n    95\t    assert saved.goals[0].status == Status.RUNNING  # active goal left for finalize\n    96\t    assert saved.goals[0].tasks[1].status == Status.RUNNING  # in-flight untouched\n    97\t    assert saved.goals[0].tasks[2].status == Status.SKIPPED  # its pending work skipped\n    98\t    assert \"ReplanRequested\" in outbox.types()\n    99\t\n   100\t\n   101\tdef test_review_replan_enters_replanning_from_review():\n   102\t    plan = Plan(\n   103\t        project_id=\"project-1\",\n   104\t        id=\"p1\",\n   105\t        brief=\"b\",\n   106\t        phase=PlanPhase.REVIEW,\n   107\t        goals=[goal(\"g1\", 0, [task(\"t0\", 0, Status.DONE)], Status.DONE)],\n   108\t    )\n   109\t    repo, outbox, uow, *_ = harness(plan)\n   110\t    review_replan(\"p1\", uow)\n   111\t    assert repo.get(\"p1\").phase == PlanPhase.REPLANNING\n   112\t    assert repo.get(\"p1\").goals[0].status == Status.DONE  # history untouched\n   113\t\n   114\t\n   115\t@pytest.mark.parametrize(\n   116\t    \"phase\",\n   117\t    [\n   118\t        PlanPhase.DISCOVERY,\n   119\t        PlanPhase.ARCHITECTURE,\n   120\t        PlanPhase.ENRICHING,\n   121\t        PlanPhase.AWAITING_REVIEW,\n   122\t        PlanPhase.REPLANNING,\n   123\t    ],\n   124\t)\n   125\tdef test_replan_only_from_running_or_review(phase):\n   126\t    plan = Plan(project_id=\"project-1\", id=\"p1\", brief=\"b\", phase=phase)\n   127\t    repo, outbox, uow, *_ = harness(plan)\n   128\t    with pytest.raises(InvalidTransitionError):\n   129\t        request_replan(\"p1\", uow)\n   130\t\n   131\t\n   132\t# ===== committing the new goal set =====\n   133\tdef test_commit_replanned_goals_appends_bumps_iteration_and_flows_to_architecture():\n   134\t    done_goal = goal(\"g1\", 0, [task(\"g1t0\", 0, Status.DONE)], Status.DONE)\n   135\t    plan = Plan(\n   136\t        project_id=\"project-1\", id=\"p1\", brief=\"b\", phase=PlanPhase.REVIEW, goals=[done_goal]\n   137\t    )\n   138\t    repo, outbox, uow, *_ = harness(plan)\n   139\t    review_replan(\"p1\", uow)\n   140\t\n   141\t    new_goals = [\n   142\t        Goal(id=\"n1\", name=\"n1\", position=0, description=\"\"),\n   143\t        Goal(id=\"n2\", name=\"n2\", position=1, description=\"\"),\n   144\t    ]\n   145\t    with uow:\n   146\t        p = uow.plans.get(\"p1\")\n   147\t        p.commit_replanned_goals(new_goals)\n   148\t        p.bump_version()\n   149\t        uow.plans.save(p)\n   150\t\n   151\t    saved = repo.get(\"p1\")\n   152\t    assert saved.phase == PlanPhase.ARCHITECTURE\n   153\t    assert saved.iteration == 2\n   154\t    assert [g.id for g in saved.goals] == [\"g1\", \"n1\", \"n2\"]  # append-only\n   155\t    assert [g.position for g in saved.goals] == [0, 1, 2]  # positions continue\n   156\t    assert saved.goals[0].status == Status.DONE  # prior DONE goals are history\n   157\t\n   158\t\n   159\tdef test_finalize_abandon_closes_leftover_nonterminal_goals():\n   160\t    \"\"\"Skip place TWO (the resurrection fix): commit closes whatever the prior\n    80\t\n    81\t\n    82\tdef cycle(proposal: IntentProposal, item: CycleDraft, cycle_id: str = \"cycle-1\") -> Cycle:\n    83\t    return Cycle(\n    84\t        id=cycle_id,\n    85\t        intent_proposal_id=proposal.id,\n    86\t        draft_id=item.id,\n    87\t        started_at=NOW,\n    88\t        goals=[\n    89\t            Goal(id=\"goal-1\", name=\"Foundation\", position=0, description=\"base\"),\n    90\t            Goal(\n    91\t                id=\"goal-2\",\n    92\t                name=\"Delivery\",\n    93\t                position=1,\n    94\t                description=\"finish\",\n    95\t                depends_on=[\"goal-1\"],\n    96\t            ),\n    97\t        ],\n    98\t    )\n    99\t\n   100\t\n   101\tdef test_initial_intent_draft_activation_and_completion_return_to_idle():\n   102\t    plan = Plan(id=\"plan-1\", project_id=\"project-1\", brief=\"brief\")\n   103\t    proposal = intent(plan)\n   104\t    plan.propose_intent(\n   105\t        proposal,\n   106\t        gate(\"gate-intent\", ReviewSubjectType.INTENT, proposal.id, proposal.revision),\n   107\t    )\n   108\t    assert plan.status == PlanStatus.WAITING\n   109\t    assert plan.activity == \"review:intent\"\n   110\t\n   111\t    plan.approve_intent(\"gate-intent\", 1, NOW)\n   112\t    item = draft(proposal)\n   113\t    plan.submit_cycle_draft(\n   114\t        item,\n   115\t        gate(\"gate-draft\", ReviewSubjectType.CYCLE_DRAFT, item.id, item.revision),\n   116\t    )\n   117\t    plan.bump_version()\n   118\t    active = cycle(proposal, item)\n   119\t    plan.activate_cycle(\"gate-draft\", 1, active, NOW)\n   120\t\n   121\t    assert plan.status == PlanStatus.RUNNING\n   122\t    assert plan.active_cycle is active\n   123\t    assert len([c for c in plan.cycles if c.status == CycleStatus.ACTIVE]) == 1\n   124\t\n   125\t    completion = gate(\n   126\t        \"gate-complete\",\n   127\t        ReviewSubjectType.CYCLE_COMPLETION,\n   128\t        active.id,\n   129\t        1,\n   130\t        [item.value for item in OutputDisposition],\n   131\t    )\n   132\t    plan.open_completion_gate(completion, [\"evidence://cycle-1\"])\n   133\t    plan.record_output_disposition(\n   134\t        \"gate-complete\",\n   135\t        1,\n   136\t        OutputDisposition.RETAIN_BRANCH,\n   137\t        \"refs/heads/cycle/cycle-1\",\n   138\t        NOW,\n   139\t    )\n   140\t\n   141\t    assert plan.status == PlanStatus.IDLE\n   142\t    assert plan.active_cycle is None\n   143\t    assert active.status == CycleStatus.COMPLETED\n   144\t\n   145\t\n   146\tdef test_replan_activation_atomically_supersedes_active_cycle():\n   147\t    plan = Plan(id=\"plan-1\", project_id=\"project-1\", brief=\"brief\")\n   148\t    initial = intent(plan)\n   149\t    initial_draft = draft(initial)\n   150\t    old = cycle(initial, initial_draft)\n","exit_code":0,"status":"completed"}}
{"type":"item.started","item":{"id":"item_10","type":"command_execution","command":"/bin/bash -lc \"nl -ba docs/decisions/adr-003-cyclic-project-plan-lifecycle.md | sed -n '35,155p'; nl -ba docs/architecture/plan-lifecycle.md | sed -n '18,105p'; nl -ba docs/architecture/known-issues.md | sed -n '1,55p'; nl -ba docs/decisions/decision-log.md | sed -n '108,125p'\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
{"type":"item.completed","item":{"id":"item_10","type":"command_execution","command":"/bin/bash -lc \"nl -ba docs/decisions/adr-003-cyclic-project-plan-lifecycle.md | sed -n '35,155p'; nl -ba docs/architecture/plan-lifecycle.md | sed -n '18,105p'; nl -ba docs/architecture/known-issues.md | sed -n '1,55p'; nl -ba docs/decisions/decision-log.md | sed -n '108,125p'\"","aggregated_output":"    35\t- JIT enrichment freezes a `GoalContract` and ordered `TaskContract`s. Every\n    36\t  task declares `tdd`, `characterization`, or `executable_check` verification.\n    37\t  Agent output is a candidate only; protected tests, commands, scope, branch\n    38\t  integrity, and evidence are independently verified before integration.\n    39\t- The existing agent catalog resolves `TEST_AUTHOR`, `IMPLEMENTER`, and optional\n    40\t  `VERIFIER` roles by capability. The existing reasoner loop is reused with\n    41\t  purpose-specific read/submission tool profiles. Submission tools produce DTOs\n    42\t  and never mutate repositories.\n    43\t- Pause is graceful. `pause_requested` blocks new claims immediately; an active\n    44\t  atomic run may finalize, after which the root becomes `paused`. `resume`\n    45\t  removes only a manual pause. Retry/block resolution/edit/replan are explicit,\n    46\t  targeted commands.\n    47\t- Every run has a globally unique `run_id`, monotonic absolute attempt number,\n    48\t  and separate retry-cycle policy counter. Long actions renew the plan lease.\n    49\t  Finalization revalidates claim/run/version/task revision before any merge.\n    50\t- Git staging is project main -> cycle -> goal -> task/run. Verified work alone\n    51\t  moves upward. One output disposition is recorded per cycle.\n    52\t- State plus domain facts commit through the existing UoW/outbox. Operational\n    53\t  observations remain best-effort and bounded outside aggregate JSON.\n    54\t\n    55\t## Legacy migration\n    56\t\n    57\tRevision 0009 migrates released phase rows without inventing ownership or\n    58\tapproval history:\n    59\t\n    60\t| Legacy phase | Root status | Migrated activity |\n    61\t|---|---|---|\n    62\t| `done` | `idle` | immutable completed legacy cycle; publication recorded as unknown legacy disposition |\n    63\t| `failed` | `blocked` | legacy failure block retaining available failure context |\n    64\t| `running` | `running` | active migrated cycle containing existing goals/tasks |\n    65\t| `review` | `waiting` | cycle-completion review gate |\n    66\t| `awaiting_review` | `waiting` | cycle-draft architecture review gate |\n    67\t| `enriching` | `running` | active migrated cycle at goal-enrichment activity |\n    68\t| `architecture` | `running` | pending architecture work |\n    69\t| `discovery` / `replanning` | `blocked` when unbound, otherwise `waiting` | compatible proposal state requiring explicit review |\n    70\t\n    71\tAll existing goal/task JSON is retained. A legacy plan is bound only when an\n    72\tauthoritative project reference already exists or the database has exactly one\n    73\tproject and the operator selected deterministic single-project migration.\n    74\tOtherwise it remains readable but non-claimable with a `project_binding` block.\n    75\tNo global repository or fabricated project is used as a fallback.\n    76\t\n    77\t## Consequences\n    78\t\n    79\tThis is a deliberate breaking domain migration. Phase-based endpoints, UI,\n    80\ttests, and documentation must move to backend-provided status, activity, legal\n    81\tactions, gates, and blocks. Released Alembic revisions remain immutable; the\n    82\tnew model extends the current 0008 head. Fake and SQLite semantics continue to\n    83\tshare the same truth tests. Paid LLM verification remains opt-in.\n    18\t  `backend/src/app/use_cases/cyclic_planning.py`\n    19\t- worker routing:\n    20\t  `backend/src/app/use_cases/advance_plan.py`\n    21\t\n    22\t## Root status\n    23\t\n    24\t`PlanStatus` is the only persisted root lifecycle status:\n    25\t\n    26\t| Status | Meaning |\n    27\t|---|---|\n    28\t| `running` | autonomous work may claim and advance one atomic action |\n    29\t| `paused` | a human pause is fully settled |\n    30\t| `waiting` | intent, architecture, or publication review is required |\n    31\t| `blocked` | a structured exhausted/permanent failure needs resolution |\n    32\t| `idle` | no active cycle or open proposal needs work |\n    33\t\n    34\t`activity` is derived from the open intent, CycleDraft, gate, block, active\n    35\tcycle, earliest nonterminal goal, and current task. It is not stored as a\n    36\tsecond workflow enum. The API also supplies `status_reason` and\n    37\t`legal_actions`; the frontend renders those facts instead of rebuilding\n    38\ttransition rules.\n    39\t\n    40\t## Versioned planning artifacts\n    41\t\n    42\tPlanning proceeds through three versioned subjects, in order:\n    43\t\n    44\t**`IntentProposal` → `CycleDraft` → active `Cycle`.**\n    45\t\n    46\t### IntentProposal\n    47\t\n    48\t`IntentProposal` is a **domain entity**\n    49\t(`backend/src/domain/entities/planning_artifacts.py`), not a dedicated API\n    50\tDTO. It carries the human-reviewed objective, scope, constraints, exclusions,\n    51\tproposal kind (`initial` | `replan`), `base_plan_version`, optional replan\n    52\t`source_cycle_id`, and a `revision` counter. The plan detail response field\n    53\t`intent_proposal` on `PlanDetailResponse`\n    54\t(`backend/src/api/routers/plans.py`) surfaces this domain model directly as\n    55\tthe OpenAPI schema.\n    56\t\n    57\t`revision` **starts at 1**. The Plan aggregate is the only mutator\n    58\t(`backend/src/domain/aggregates/planner_orchestrator.py`):\n    59\t\n    60\t- `revise_intent` requires the replacement's `revision` to equal\n    61\t  `current.revision + 1` (monotonic +1 only). Any other step raises\n    62\t  `InvalidEditError`.\n    63\t- `approve_intent` requires the caller-supplied revision to match the open\n    64\t  proposal exactly. A missing proposal or stale revision raises\n    65\t  `InvalidEditError`.\n    66\t\n    67\tThat exact-revision check is the optimistic-concurrency mechanism for the\n    68\t**human intent review gate** (paired with the open `ReviewGate`'s\n    69\t`subject_revision`). It is distinct from `Plan.version` CAS, which guards\n    70\tworker-vs-edit races on the plan document as a whole (see\n    71\t[data-model.md](data-model.md#the-version-cas-optimistic-concurrency)).\n    72\t\n    73\t### Cycle path\n    74\t\n    75\t1. Conversation and project/repository context produce an `IntentProposal`.\n    76\t2. An exact-revision `ReviewGate` allows approve, edit, or cancel.\n    77\t3. Approval makes architecture worker-claimable.\n    78\t4. The architecture reasoner submits an ordered `CycleDraft` with stable\n    79\t   local goal keys and real dependency keys. Every dependency must precede its\n    80\t   dependent by stable position; forward edges are rejected before activation\n    81\t   because position is the scheduling barrier.\n    82\t5. A second exact-revision gate allows approve, edit, or cancel.\n    83\t6. Approval validates the base plan version, maps local dependency keys to\n    84\t   generated goal ids, and atomically activates a finite `Cycle`.\n    85\t\n    86\tEditing a subject invalidates its old gate and opens a replacement gate for\n    87\tthe incremented revision. A stale gate id or subject revision is rejected.\n    88\tReplan drafts keep accepted work unchanged until approval; activation\n    89\tsupersedes the source cycle atomically.\n    90\t\n    91\t## Execution and verification\n    92\t\n    93\tOnly the earliest nonterminal goal by stable position can advance. A failed\n    94\tor backing-off head task, an incomplete dependency, a gate, a block, or a\n    95\tpause request prevents later goals from running.\n    96\t\n    97\tJIT enrichment freezes a `GoalContract` and ordered `TaskContract` objects.\n    98\tEach task declares stable criteria, goal-criterion mappings, scope,\n    99\tcapabilities, commands, and one of `tdd`, `characterization`, or\n   100\t`executable_check`. TestBundle and VerificationEvidence are revision-bound;\n   101\tsemantic edits increment the task revision and invalidate both.\n   102\t\n   103\tPurpose-specific reasoner sessions expose shared read tools plus exactly one\n   104\tsubmission tool:\n   105\t\n     1\t# Known issues and compatibility debt\n     2\t\n     3\tVerified against the refactored code on 2026-07-14; re-verified 2026-07-20\n     4\tagainst merged PRs through #29. Fixed entries are removed; regressions live in\n     5\ttests rather than remaining as warnings here.\n     6\t\n     7\t## Lifecycle compatibility\n     8\t\n     9\t- `PlanPhase`, the legacy conversation/control routes, and root `goals`\n    10\t  remain for readable migrated plans and existing clients. Cyclic plans route\n    11\t  by `PlanStatus` plus open artifacts and active-cycle state, but deleting\n    12\t  the compatibility surface requires a separately versioned API removal.\n    13\t- Some secondary frontend panels still display legacy phase history. The main\n    14\t  status/control surface is status/gate/block/TDD-driven and explicitly\n    15\t  distinguishes RUNNING, pause requested, PAUSED, WAITING, BLOCKED, and IDLE.\n    16\t\n    17\t## Verification and publication\n    18\t\n    19\t- The repository has `ProjectDefinition` but no richer persisted\n    20\t  `ProjectSpec` containing canonical full-suite/build/type/lint/migration\n    21\t  commands. Task verification executes frozen TaskContract commands and goal\n    22\t  promotion requires accepted task evidence; cycle-wide verification can only\n    23\t  aggregate those evidence references until ProjectSpec gains those commands.\n    24\t- `open_pr` and `merge` publication dispositions record the reference of an\n    25\t  operation completed by an external/operator adapter. This repository has no\n    26\t  authenticated GitHub/forge publication port, and this refactor deliberately\n    27\t  did not invent provider-specific push/PR behavior or perform an unauthorized\n    28\t  external write.\n    29\t- Execution attempts have global UUIDs and monotonic absolute numbers, but the\n    30\t  execution ledger does not yet promote `run_kind` as a dedicated SQL column.\n    31\t  Role identity is present in the orchestration path and separate invocations,\n    32\t  prompts/specs, worktrees, run ids, and evidence.\n    33\t\n    34\t## Operational visibility\n    35\t\n    36\t- Lease heartbeat now runs during long actions, but the plan detail read model\n    37\t  exposes the active run start rather than the promoted lease deadline and last\n    38\t  heartbeat. Operational telemetry records liveness; a richer query DTO remains.\n    39\t- A malformed plan that raises before any save can still be reclaimed first by\n    40\t  oldest `updated_at` on a single worker. A dead-letter/operator quarantine\n    41\t  policy is still needed for repeated unexpected application exceptions.\n    42\t- SSE is bounded and non-durable for clients; reconnect relies on refetch.\n    43\t  Relay and event-table retention remain operational work.\n    44\t\n    45\t## Git/process cleanup\n    46\t\n    47\t- Owned process groups are terminated and reaped on success, failure, timeout,\n    48\t  discard, and stale results. A host crash can still leave Git worktree metadata;\n    49\t  periodic `git worktree prune` is not yet automated.\n    50\t- Authoritative test checkpoint branch refs are retained after implementation\n    51\t  forks from their immutable commit. They preserve auditability but need a\n    52\t  retention policy for long-running repositories.\n    53\t\n    54\t## Invariants to preserve\n    55\t\n   108\trepository's actual default branch and cache by current repository identity, so\n   109\tconfiguration changes cannot strand work on `main` assumptions or a stale\n   110\trepository. The unimplemented active `cancel_cycle` advertisement is removed;\n   111\tcycle cancellation remains an explicit publication disposition or draft\n   112\tcancellation, never a display-only command.\n   113\t\n   114\t49. **Domain unfreeze #9 (2026-07-20): cyclic-aware pause & replan guards.**\n   115\t`Plan.request_pause`, `Plan.pause`, and `Plan.begin_replanning` guarded on the\n   116\tlegacy `PlanPhase` (`WORKER_CLAIMABLE_PHASES` / `{RUNNING, REVIEW}`), but a\n   117\tcyclic plan's advertised `legal_actions` derive from root `PlanStatus` + open\n   118\tartifacts. A running or blocked cyclic plan whose legacy phase projection is\n   119\t`REPLANNING` therefore advertised `pause` / `start_replan` while the domain\n   120\ttransition rejected them (`INVALID_TRANSITION`) — wedging plans with no working\n   121\trecovery, surfaced by the 2026-07-20 API walkthrough (findings #2/#5). The\n   122\tguards now consult the cyclic authority exactly as `resume()` already did: pause\n   123\tis legal when `status == RUNNING` and (`active_cycle is not None` or the legacy\n   124\tphase is claimable); `begin_replanning` skips the legacy phase guard when\n   125\t`active_cycle is not None`. Legacy (pre-cyclic) plans keep the phase guards\n","exit_code":0,"status":"completed"}}
{"type":"item.started","item":{"id":"item_11","type":"command_execution","command":"/bin/bash -lc \"rg -n \\\"resolve_block\\\\(\\\" backend/src backend/tests | head -100; rg -n \\\"def resolve_|resolution ==|start_replan\\\" backend/src/app/use_cases backend/src/api/routers/plans.py | head -160; nl -ba backend/src/app/use_cases/pause_resume.py | sed -n '1,260p'\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
{"type":"item.completed","item":{"id":"item_11","type":"command_execution","command":"/bin/bash -lc \"rg -n \\\"resolve_block\\\\(\\\" backend/src backend/tests | head -100; rg -n \\\"def resolve_|resolution ==|start_replan\\\" backend/src/app/use_cases backend/src/api/routers/plans.py | head -160; nl -ba backend/src/app/use_cases/pause_resume.py | sed -n '1,260p'\"","aggregated_output":"backend/src/domain/aggregates/planner_orchestrator.py:833:    def resolve_block(self, resolution: str, resolved_at: datetime) -> None:\nbackend/src/app/use_cases/request_replan.py:42:            plan.resolve_block(\"start_replan\", block.created_at)\nbackend/src/app/use_cases/pause_resume.py:56:        if resolution == \"wait_and_retry\":\nbackend/src/app/use_cases/request_replan.py:42:            plan.resolve_block(\"start_replan\", block.created_at)\nbackend/src/app/use_cases/request_replan.py:47:                    resolution=\"start_replan\",\n     1\t\"\"\"Manual availability controls and targeted retry.\"\"\"\n     2\t\n     3\tfrom __future__ import annotations\n     4\t\n     5\tfrom src.domain.errors.planning_errors import InvalidEditError\n     6\tfrom src.domain.repositories.agent_repo import AgentRepository\n     7\tfrom src.domain.services.agent_role_resolution import resolve_task_role_agents\n     8\tfrom src.domain.events.outbox import (\n     9\t    BlockResolved,\n    10\t    PauseRequested,\n    11\t    PlanPaused,\n    12\t    PlanResumed,\n    13\t    TaskRetried,\n    14\t)\n    15\t\n    16\tfrom src.app.ports import Clock, UnitOfWork\n    17\t\n    18\t\n    19\tdef pause_plan(plan_id: str, uow: UnitOfWork, reason: str | None = None) -> None:\n    20\t    with uow:\n    21\t        plan = uow.plans.get(plan_id)\n    22\t        if plan.paused or plan.pause_requested:\n    23\t            return\n    24\t        active_action = bool(uow.executions.list_open_attempts(plan_id))\n    25\t        plan.request_pause(active_action, reason)\n    26\t        plan.bump_version()\n    27\t        if active_action:\n    28\t            uow.outbox.add(PauseRequested(plan_id=plan_id, reason=reason))\n    29\t        else:\n    30\t            uow.outbox.add(PlanPaused(plan_id=plan_id, reason=reason, auto=False))\n    31\t        uow.plans.save(plan)\n    32\t\n    33\t\n    34\tdef resume_plan(plan_id: str, uow: UnitOfWork) -> None:\n    35\t    \"\"\"Remove only the manual pause; retry/backoff state is untouched.\"\"\"\n    36\t    with uow:\n    37\t        plan = uow.plans.get(plan_id)\n    38\t        plan.resume()\n    39\t        plan.bump_version()\n    40\t        uow.outbox.add(PlanResumed(plan_id=plan_id, retried_task_ids=[]))\n    41\t        uow.plans.save(plan)\n    42\t\n    43\t\n    44\tdef retry_task(\n    45\t    plan_id: str,\n    46\t    goal_id: str,\n    47\t    task_id: str,\n    48\t    uow: UnitOfWork,\n    49\t    clock: Clock,\n    50\t) -> None:\n    51\t    \"\"\"Reset policy budget only for the selected failed task.\"\"\"\n    52\t    with uow:\n    53\t        plan = uow.plans.get(plan_id)\n    54\t        block = plan.block if plan.block is not None and plan.block.active else None\n    55\t        resolution = plan.retry_task(goal_id, task_id, clock.now())\n    56\t        if resolution == \"wait_and_retry\":\n    57\t            circuit_ref = next(\n    58\t                (\n    59\t                    ref.removeprefix(\"runtime-circuit://\")\n    60\t                    for ref in (block.evidence_refs if block is not None else [])\n    61\t                    if ref.startswith(\"runtime-circuit://\")\n    62\t                ),\n    63\t                None,\n    64\t            )\n    65\t            if circuit_ref is None:\n    66\t                raise InvalidEditError(\"provider retry is missing its runtime circuit reference\")\n    67\t            try:\n    68\t                runtime, provider_id, model_id = circuit_ref.split(\"/\", 2)\n    69\t            except ValueError as exc:\n    70\t                raise InvalidEditError(\n    71\t                    \"provider retry has an invalid runtime circuit reference\"\n    72\t                ) from exc\n    73\t            uow.executions.clear_runtime_circuit(runtime, provider_id, model_id)\n    74\t        plan.bump_version()\n    75\t        task = plan._task(plan._goal(goal_id), task_id)\n    76\t        if resolution != \"edit_task\":\n    77\t            uow.outbox.add(\n    78\t                TaskRetried(\n    79\t                    plan_id=plan_id,\n    80\t                    goal_id=goal_id,\n    81\t                    task_id=task_id,\n    82\t                    retry_cycle=task.retry_cycle,\n    83\t                    next_attempt_number=task.attempt + 1,\n    84\t                )\n    85\t            )\n    86\t        if block is not None and resolution is not None:\n    87\t            uow.outbox.add(BlockResolved(plan_id=plan_id, block_id=block.id, resolution=resolution))\n    88\t        uow.plans.save(plan)\n    89\t\n    90\t\n    91\tdef retry_planning_stage(\n    92\t    plan_id: str,\n    93\t    uow: UnitOfWork,\n    94\t    clock: Clock,\n    95\t    agents: AgentRepository,\n    96\t) -> None:\n    97\t    \"\"\"Retry a reasoner stage or rebind frozen tasks from the repaired registry.\"\"\"\n    98\t    with uow:\n    99\t        plan = uow.plans.get(plan_id)\n   100\t        if plan.block is None or not plan.block.active:\n   101\t            raise InvalidEditError(\"plan has no active block\")\n   102\t        if plan.block.kind == \"reasoner_failure\":\n   103\t            block_id = plan.block.id\n   104\t            plan.retry_planning_stage(clock.now())\n   105\t            plan.bump_version()\n   106\t            uow.outbox.add(\n   107\t                BlockResolved(\n   108\t                    plan_id=plan_id,\n   109\t                    block_id=block_id,\n   110\t                    resolution=\"retry_stage\",\n   111\t                )\n   112\t            )\n   113\t            uow.plans.save(plan)\n   114\t            return\n   115\t        if plan.block.kind != \"agent_capability\" or plan.block.goal_id is None:\n   116\t            raise InvalidEditError(\"plan is not blocked on a retryable planning stage\")\n   117\t        block_id = plan.block.id\n   118\t        goal_id = plan.block.goal_id\n   119\t        version = plan.version\n   120\t        requirements = {\n   121\t            task.id: list(task.required_capabilities) for task in plan._goal(goal_id).tasks\n   122\t        }\n   123\t\n   124\t    role_agent_ids_by_task = {\n   125\t        task_id: resolve_task_role_agents(required, agents)\n   126\t        for task_id, required in requirements.items()\n   127\t    }\n   128\t\n   129\t    with uow:\n   130\t        plan = uow.plans.get(plan_id)\n   131\t        if (\n   132\t            plan.version != version\n   133\t            or plan.block is None\n   134\t            or not plan.block.active\n   135\t            or plan.block.id != block_id\n   136\t        ):\n   137\t            raise InvalidEditError(\"plan changed while agent bindings were being resolved\")\n   138\t        plan.retry_agent_binding(goal_id, role_agent_ids_by_task, clock.now())\n   139\t        plan.bump_version()\n   140\t        uow.outbox.add(\n   141\t            BlockResolved(\n   142\t                plan_id=plan_id,\n   143\t                block_id=block_id,\n   144\t                resolution=\"retry_stage\",\n   145\t            )\n   146\t        )\n   147\t        uow.plans.save(plan)\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_12","type":"agent_message","text":"## Design analysis\n\nADR-003 makes `PlanStatus` the root lifecycle authority: `running` is worker-claimable, `paused` means a settled human pause, and `waiting` means conversational planning or human review is required ([plan-lifecycle.md:22](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/docs/architecture/plan-lifecycle.md:22)). Its migration table explicitly maps a bound legacy `discovery`/`replanning` plan to `WAITING` ([adr-003-cyclic-project-plan-lifecycle.md:55](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/docs/decisions/adr-003-cyclic-project-plan-lifecycle.md:55)).\n\nFinding #12 is therefore an invalid state, not a legitimate kind of pause:\n\n```text\nstatus=PAUSED\npaused=False\nphase=REPLANNING\nactive_cycle=<active>\n```\n\n`legal_actions` advertises `resume` solely from `status == PAUSED` ([planner_orchestrator.py:595](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/src/domain/aggregates/planner_orchestrator.py:595)), while `resume()` authorizes the transition solely from `paused` ([planner_orchestrator.py:302](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/src/domain/aggregates/planner_orchestrator.py:302)). The SQL worker predicate independently requires `status='running'`, `paused=0`, and `pause_requested=0` ([plan_repository.py:42](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/src/infra/db/plan_repository.py:42)). Thus neither the API nor worker can advance the plan.\n\nThe immediate cause is ordering. `begin_replanning()` calls `_set_phase(REPLANNING)`, temporarily mapping the status to `WAITING` ([planner_orchestrator.py:469](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/src/domain/aggregates/planner_orchestrator.py:469)), but `request_replan()` subsequently resolves the block ([request_replan.py:22](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/src/app/use_cases/request_replan.py:22)). Generic `resolve_block()` then overwrites the status with `PAUSED` merely because an active cycle exists, without setting `paused=True` ([planner_orchestrator.py:833](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/src/domain/aggregates/planner_orchestrator.py:833)).\n\nFinding #13 is the artifact counterpart. `begin_replanning()` clears the manual pause and changes the legacy phase, but does not retire the current `intent_proposal`, `cycle_draft`, or `review_gate` slots ([planner_orchestrator.py:469](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/src/domain/aggregates/planner_orchestrator.py:469)). An approved proposal is particularly harmful:\n\n- `activity` derives `cycle_architecture` from an approved proposal with no draft ([planner_orchestrator.py:621](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/src/domain/aggregates/planner_orchestrator.py:621)).\n- `propose_intent()` rejects every non-cancelled existing proposal, including an approved one ([planner_orchestrator.py:683](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/src/domain/aggregates/planner_orchestrator.py:683)).\n- The conversation guard now correctly permits an approved prior intent, but the eventual commit still calls `fresh.propose_intent(...)` and therefore fails ([conversation.py:83](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/src/app/use_cases/conversation.py:83), [conversation.py:271](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/src/app/use_cases/conversation.py:271)).\n\n### Required conversational-replan invariant\n\nBefore the reasoner has produced a candidate, a cyclic plan in conversational replan should hold:\n\n```text\nstatus             = WAITING\npaused             = False\npause_requested    = False\nphase              = REPLANNING       # compatibility projection only\nactive_cycle       = existing source cycle\nintent_proposal    = None             # active planning slot is empty\ncycle_draft        = None\nreview_gate        = None\nblock              = resolved/inactive\nactivity           = replan_discovery\nworker claimable   = false\nlegal action       = continue/start replan conversation, never resume\n```\n\nOnce the reasoner produces a candidate, the tuple becomes:\n\n```text\nstatus             = WAITING\npaused             = False\nphase              = REPLANNING\nactive_cycle       = unchanged source cycle\nintent_proposal    = fresh, unapproved ProposalKind.REPLAN\nreview_gate        = unresolved INTENT gate for that exact revision\nactivity           = review:intent\n```\n\n`WAITING` is the correct status. Conversational discovery is not autonomous worker work, so `RUNNING` would cause the repository to claim it. `PAUSED` is also wrong because ADR-003 reserves that status for a settled manual pause.\n\n`begin_replanning()` should not fabricate an empty `IntentProposal`: the entity requires an objective and other reasoner-derived content ([planning_artifacts.py:99](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/src/domain/entities/planning_artifacts.py:99)). It should open the *slot* for a fresh proposal by clearing stale current-artifact pointers. The conversation use case should continue constructing the actual `ProposalKind.REPLAN`, binding it to `active_cycle.id`, and opening its exact-revision gate when a candidate exists ([conversation.py:271](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/src/app/use_cases/conversation.py:271)).\n\nApproved source intent history remains represented by the active cycle’s `intent_proposal_id`; cyclic activation already clears the aggregate’s current proposal/draft/gate slots ([planner_orchestrator.py:783](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/src/domain/aggregates/planner_orchestrator.py:783)). Clearing stale current pointers during replan is therefore consistent with existing lifecycle semantics rather than destroying the source cycle.\n\n## Legacy `PlanPhase` side-effect audit\n\nThe following are active legacy dependencies that can diverge from cyclic authority.\n\n1. `_set_phase()` mutates both the compatibility projection and authoritative root status ([planner_orchestrator.py:144](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/src/domain/aggregates/planner_orchestrator.py:144)). This is the central dual-authority hazard. Any cyclic compatibility update can silently overwrite a carefully selected status. It happens in `begin_replanning`, `retry_agent_binding`, planning enrichment, and activation.\n\n2. `activate_cycle()` first establishes cyclic state and `RUNNING`, after which the application calls `_set_phase(ENRICHING)` ([cyclic_planning.py:277](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/src/app/use_cases/cyclic_planning.py:277)). Today both happen to map to `RUNNING`, but a compatibility write still has authority over status. A future phase projection change could make a freshly activated cycle non-claimable.\n\n3. Cyclic enrichment calls `_set_phase(RUNNING)` after enriching a goal ([planning_handler.py:322](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/src/app/handlers/planning_handler.py:322)). It currently restores `RUNNING`, but can overwrite a status selected from cyclic artifacts or a concurrent lifecycle transition if the surrounding revalidation misses it.\n\n4. `retry_agent_binding()` calls `_set_phase(RUNNING)` ([planner_orchestrator.py:373](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/src/domain/aggregates/planner_orchestrator.py:373)). For a cyclic block, this phase write also changes root status, instead of the block-resolution command explicitly selecting the cyclic continuation.\n\n5. `_assert_not_terminal()` reads `phase` and can declare the cyclic root terminal even though ADR-003 says the root is never terminal ([planner_orchestrator.py:162](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/src/domain/aggregates/planner_orchestrator.py:162)). A cyclic row retaining `DONE` or `FAILED` as a stale projection can reject task finalization and recovery mutations regardless of active cycle/status.\n\n6. Pause guards retain `WORKER_CLAIMABLE_PHASES` for legacy plans ([planner_orchestrator.py:264](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/src/domain/aggregates/planner_orchestrator.py:264), [planner_orchestrator.py:286](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/src/domain/aggregates/planner_orchestrator.py:286)). The active-cycle exception added by unfreeze #9 protects cyclic plans, but this remains fragile: any cyclic state temporarily lacking an active cycle, such as approved-intent architecture, falls back to phase authority even though it can be worker-claimable from status/artifacts.\n\n7. `resume()` correctly recognizes an active cycle, but computes `RUNNING` whenever one exists, independent of gates, blocks, or a conversational replan ([planner_orchestrator.py:302](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/src/domain/aggregates/planner_orchestrator.py:302)). If an inconsistent `paused=True` leaks into a waiting cyclic state, resume can bypass the artifact-driven wait and make it claimable.\n\n8. `begin_replanning()` still sets root status indirectly through `_set_phase(REPLANNING)` ([planner_orchestrator.py:469](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/src/domain/aggregates/planner_orchestrator.py:469)). Finding #12 demonstrates why relying on that incidental mapping is unsafe.\n\n9. `commit_replanned_goals()` is guarded and advanced entirely by `PlanPhase`, writes legacy root `goals`, increments legacy `iteration`, and calls `_set_phase(ARCHITECTURE)` ([planner_orchestrator.py:517](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/src/domain/aggregates/planner_orchestrator.py:517)). It is valid only for the legacy loop. Calling it from the cyclic conversation path would bypass `IntentProposal → ReviewGate → CycleDraft → ReviewGate → Cycle` and make the plan prematurely worker-claimable.\n\n10. The cyclic planning handler has phase-based fallback branches after its artifact-based branches ([planning_handler.py:151](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/src/app/handlers/planning_handler.py:151)). A malformed cyclic plan without the expected active artifact can fall through and be routed according to stale phase rather than stopping on an inconsistent cyclic state.\n\n11. Execution candidate validation and tolerant finalization require both `phase == RUNNING` and `status == RUNNING` ([execution_handler.py:539](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/src/app/handlers/execution_handler.py:539), [execution_handler.py:569](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/src/app/handlers/execution_handler.py:569), [execution_handler.py:1053](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/src/app/handlers/execution_handler.py:1053)). A cyclic plan that is legitimately running but retains `REPLANNING` as its projection can have valid results treated as stale/abandoned. Conversely, phase changes can force tolerant abandonment even if cyclic status/artifacts still authorize the run.\n\n12. `PlanDispatcher` captures `phase` and uses it for all non-active-cycle fallback routing and terminal decisions ([advance_plan.py:64](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/src/app/use_cases/advance_plan.py:64)). Active cycles are routed cyclically first, which limits current exposure, but approved-intent architecture and malformed/intermediate cyclic states can still fall into legacy routing.\n\n13. Conversation response DTOs continue returning `plan.phase` ([conversation.py:213](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/src/app/use_cases/conversation.py:213), [conversation.py:263](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/src/app/use_cases/conversation.py:263), [conversation.py:342](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/src/app/use_cases/conversation.py:342)). This is compatibility-only presentation, but clients can mistakenly treat it as current authority and reconstruct the retired state machine.\n\n14. The repository persists both `status` and `phase` as independently queryable columns ([plan_repository.py:19](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/src/infra/db/plan_repository.py:19)). Claiming correctly uses only status and pause fields, but every `_set_phase()` side effect is copied into the authoritative status column. Divergence between JSON, columns, or phase/status update paths directly affects worker eligibility.\n\n## Minimal, safe design plan\n\n1. Deliberately record a narrow domain unfreeze for the cyclic replan consistency invariant. Scope it only to `begin_replanning`, `request_replan`, derived activity/actions, and regression tests. Do not use this fix as an opportunity to remove `PlanPhase` globally.\n\n2. Split `Plan.begin_replanning()` behavior by lifecycle family at [planner_orchestrator.py:469](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/src/domain/aggregates/planner_orchestrator.py:469):\n\n   - Preserve the existing legacy branch byte-for-byte when `active_cycle is None`: retain the `{RUNNING, REVIEW}` phase guard, legacy root-goal skipping, pause clearing, and `_set_phase(REPLANNING)`.\n   - For `active_cycle is not None`, make the cyclic postcondition explicit: clear manual pause fields and `pause_requested`; set the compatibility `phase` to `REPLANNING`; set `status=WAITING` directly; clear the current `intent_proposal`, `cycle_draft`, and `review_gate` slots; retain the active source cycle.\n   - Do not create an `IntentProposal` here. The method has no candidate content and must not fabricate review history.\n   - Either avoid applying the legacy `self.goals` abandonment loop to cyclic plans or document it as compatibility-only; cyclic task settlement belongs to the active cycle and is already handled by `request_replan()`.\n\n   Risk: clearing stale artifact pointers changes observable plan detail, but only on an explicit cyclic replan. It is required to prevent approved intent/draft state from masquerading as current planning work.\n\n3. Recompose `request_replan()` at [request_replan.py:22](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/src/app/use_cases/request_replan.py:22):\n\n   - Capture the legacy `from_phase`.\n   - If an active block exists, validate and resolve `start_replan` first and emit `BlockResolved`.\n   - Invoke `begin_replanning()` after block resolution so its explicit `WAITING` postcondition is the transaction’s final lifecycle decision.\n   - Settle failed/pending/running tasks in the active cycle as today.\n   - Bump once, emit `ReplanRequested`, and save once.\n\n   This ordering prevents generic block resolution from overwriting the replan state. The transaction remains atomic, so no intermediate `PAUSED` state is externally visible.\n\n4. Do not broaden `resolve_block()` in this patch. Its generic active-cycle fallback at [planner_orchestrator.py:833](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/src/domain/aggregates/planner_orchestrator.py:833) is questionable because it can produce `PAUSED + paused=False`, but `request_replan` is its only current caller. A global semantic change would have unnecessary domain blast radius. Record the broader invariant violation as compatibility debt or a separately decision-logged cleanup.\n\n5. Align pause action advertisement with the pause transition guard at [planner_orchestrator.py:595](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/src/domain/aggregates/planner_orchestrator.py:595):\n\n   - Preserve `resume()` as a manual-pause operation keyed on `paused`; it must not become a generic transition from any `status=PAUSED`.\n   - Advertise `resume` only when the manual pause flag is actually set, ideally requiring both `status == PAUSED` and `paused`.\n   - Treat `status == PAUSED && paused == False` as inconsistent state, not as resumable state.\n   - Preserve legacy resume behavior for genuinely paused non-cyclic plans.\n\n6. Extend derived cyclic presentation:\n\n   - In `activity` at [planner_orchestrator.py:621](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/src/domain/aggregates/planner_orchestrator.py:621), recognize `status=WAITING`, active cycle, `phase=REPLANNING`, and no current planning artifacts as `replan_discovery` before falling through to active-cycle execution activity.\n   - In `legal_actions`, do not expose `resume` for this tuple. Expose the existing replan-conversation entry action, preferably `start_replan`; avoid returning `start_intent`, which implies initial planning. If API action naming cannot change in this frozen patch, returning no command while the dedicated replan-message endpoint remains usable is safer than advertising the wrong transition.\n\n7. Keep cyclic conversation proposal creation where it is. `_conversation_turn()` should continue creating a fresh `ProposalKind.REPLAN` from the reasoner candidate, setting `source_cycle_id` from the still-active source cycle, and opening a new intent review gate atomically ([conversation.py:271](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/src/app/use_cases/conversation.py:271)). No call to legacy `commit_replanned_goals()` should be introduced.\n\n8. Update the truth tests:\n\n   - Change `test_replan_from_blocked_cycle_settles_work_before_message` to expect `WAITING`, `paused=False`, resolved block, cleared stale proposal/draft/gate, non-claimability, no `resume`, and successful subsequent proposal commit ([test_conversation_and_planning.py:260](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/tests/unit/orchestration/test_conversation_and_planning.py:260)).\n   - Extend `test_cyclic_plan_can_begin_replanning_with_replanning_legacy_phase` with the complete tuple invariant and stale approved-intent fixture ([test_cyclic_pause_replan_phase_guards.py:39](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/tests/unit/orchestration/test_cyclic_pause_replan_phase_guards.py:39)).\n   - Retain the legacy rejection tests at [test_cyclic_pause_replan_phase_guards.py:47](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/tests/unit/orchestration/test_cyclic_pause_replan_phase_guards.py:47) and legacy replan-loop tests at [test_replan_loop.py:70](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/tests/unit/orchestration/test_replan_loop.py:70) to prove the `active_cycle is None` path remains unchanged.\n   - Add fake/SQLite parity coverage beside the existing claim truth tests at [test_pause_resume.py:74](/workspaces/agent-orchestrator/.orchestrator/worktrees/domain-analysis/backend/tests/unit/orchestration/test_pause_resume.py:74): conversational replan is not claimable because it is `WAITING`, and becomes claimable only after intent approval advances it to `RUNNING`.\n   - Add an API assertion around the existing replan walkthrough coverage that plan detail reports `WAITING`, `replan_discovery`, no `resume`, and accepts the next replan conversation turn.\n\nThe smallest safe correction is therefore: make cyclic `begin_replanning()` explicitly establish the `WAITING` conversational tuple, resolve a block before establishing that tuple, clear stale current planning artifacts without fabricating a proposal, and ensure the derived UI contract never advertises manual resume unless the manual pause flag is truly armed."}}
