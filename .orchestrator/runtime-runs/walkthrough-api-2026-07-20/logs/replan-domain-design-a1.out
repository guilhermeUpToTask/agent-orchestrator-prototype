{"type":"item.completed","item":{"id":"item_4","type":"command_execution","command":"/bin/bash -lc \"nl -ba backend/src/domain/aggregates/planner_orchestrator.py | sed -n '1,220p'; nl -ba backend/src/domain/aggregates/planner_orchestrator.py | sed -n '220,570p'; nl -ba backend/src/domain/aggregates/planner_orchestrator.py | sed -n '570,900p'\"","aggregated_output":"     1\tfrom __future__ import annotations\n     2\t\n     3\tfrom datetime import datetime, timezone\n     4\tfrom enum import Enum\n     5\t\n     6\tfrom pydantic import BaseModel, model_validator\n     7\t\n     8\tfrom src.domain.entities.agent_spec import AgentSpec\n     9\tfrom src.domain.entities.goal import Goal\n    10\tfrom src.domain.entities.planning_artifacts import (\n    11\t    Cycle,\n    12\t    CycleDraft,\n    13\t    CycleStatus,\n    14\t    IntentProposal,\n    15\t    OutputDisposition,\n    16\t    PlanBlock,\n    17\t    PlanStatus,\n    18\t    ProposalKind,\n    19\t    ReviewGate,\n    20\t    ReviewResolution,\n    21\t)\n    22\tfrom src.domain.entities.task import Task\n    23\tfrom src.domain.errors.planning_errors import InvalidEditError, PlanAlreadyTerminalError\n    24\tfrom src.domain.errors.tasks_errors import InvalidTransitionError\n    25\tfrom src.domain.policies.retry_policies import RetryPolicy\n    26\tfrom src.domain.services.capability_matching import match_agent\n    27\tfrom src.domain.services.lookups import find_goal, find_task\n    28\tfrom src.domain.services.navigation import next_action, NextAction\n    29\tfrom src.domain.value_objects.lifecycle import FailureKind, Status\n    30\tfrom src.domain.value_objects.tasks_vos import TaskResult\n    31\t\n    32\t\n    33\tclass PlanPhase(str, Enum):\n    34\t    \"\"\"The nine-phase machine (see MASTER_ROADMAP_FINAL.md):\n    35\t\n    36\t    DISCOVERY    — the first plan, reasoned from the brief (conversational, iter 1).\n    37\t    REPLANNING   — conversational re-plan WITH the user, using prior iteration's\n    38\t                   DONE results + chat. Reached from REVIEW (\"replan\") and from\n    39\t                   mid-RUNNING chat (request_replan). Flows into ARCHITECTURE.\n    40\t    ARCHITECTURE — structure the plan into an ordered roadmap of goals (worker).\n    41\t    ENRICHING    — fill goal/task detail (worker; separate phase for crash-recovery\n    42\t                   granularity).\n    43\t    AWAITING_REVIEW — human gate BEFORE execution (approve / edit / send back).\n    44\t    RUNNING      — execute the iteration's goals sequentially (the pull-scan core).\n    45\t    REVIEW       — human gate AFTER execution: finish (-> DONE) or replan.\n    46\t    DONE/FAILED  — terminal. DONE is reached ONLY from REVIEW \"finish\".\n    47\t    \"\"\"\n    48\t\n    49\t    DISCOVERY = \"discovery\"\n    50\t    REPLANNING = \"replanning\"\n    51\t    ARCHITECTURE = \"architecture\"\n    52\t    ENRICHING = \"enriching\"\n    53\t    AWAITING_REVIEW = \"awaiting_review\"\n    54\t    RUNNING = \"running\"\n    55\t    REVIEW = \"review\"\n    56\t    DONE = \"done\"\n    57\t    FAILED = \"failed\"\n    58\t\n    59\t\n    60\tTERMINAL_PHASES: frozenset[PlanPhase] = frozenset({PlanPhase.DONE, PlanPhase.FAILED})\n    61\t\n    62\t# Driver model (roadmap r2): who advances each phase. Conversational phases are\n    63\t# chat/API-driven; gates are human-command-driven; only these are worker-claimable.\n    64\tWORKER_CLAIMABLE_PHASES: frozenset[PlanPhase] = frozenset(\n    65\t    {PlanPhase.ARCHITECTURE, PlanPhase.ENRICHING, PlanPhase.RUNNING}\n    66\t)\n    67\t\n    68\t# The worker-driven planning phases where the reasoner runs. A permanent reasoner\n    69\t# failure (or an exhausted retry budget) fails the plan FROM one of these.\n    70\tWORKER_PLANNING_PHASES: frozenset[PlanPhase] = frozenset(\n    71\t    {PlanPhase.ARCHITECTURE, PlanPhase.ENRICHING}\n    72\t)\n    73\t\n    74\t\n    75\tclass Plan(BaseModel):\n    76\t    \"\"\"Aggregate root: owns the goal/task tree and is the ONLY caller of the\n    77\t    entities' transition methods, so all invariants are enforced in one place.\n    78\t    `version` is the optimistic lock. Navigation is delegated to the pure\n    79\t    next_action scan — no stored cursor.\n    80\t\n    81\t    The loop is append-only: each iteration's new goals are appended; prior DONE\n    82\t    goals stay as history AND as context for the next re-plan. `iteration`\n    83\t    distinguishes iteration N's goals; it increments when REPLANNING commits its\n    84\t    new goal set (one defined point, not at request time).\"\"\"\n    85\t\n    86\t    id: str\n    87\t    # Long-lived project ownership and cyclic lifecycle.\n    88\t    project_id: str | None = None\n    89\t    status: PlanStatus = PlanStatus.WAITING\n    90\t    cycles: list[Cycle] = []\n    91\t    intent_proposal: IntentProposal | None = None\n    92\t    cycle_draft: CycleDraft | None = None\n    93\t    review_gate: ReviewGate | None = None\n    94\t    block: PlanBlock | None = None\n    95\t    pause_requested: bool = False\n    96\t    # Durable check-to-merge reservation. While set, pause requests may land,\n    97\t    # but lifecycle/artifact mutations that could supersede the candidate may not.\n    98\t    promotion_reservation: str | None = None\n    99\t    legacy_phase: str | None = None\n   100\t    legacy_mapped_status: PlanStatus | None = None\n   101\t    version: int = 0\n   102\t    brief: str\n   103\t    phase: PlanPhase = PlanPhase.DISCOVERY\n   104\t    iteration: int = 1\n   105\t    retry_policy: RetryPolicy = RetryPolicy()\n   106\t    goals: list[Goal] = []\n   107\t\n   108\t    # Durable backoff gate for the worker-driven planning phases (the planning-phase\n   109\t    # analog of a Task's retry_not_before + attempt). Armed on a TRANSIENT reasoner\n   110\t    # failure and honored by the claim predicate, so a rate-limited provider makes\n   111\t    # the worker back off instead of hot-looping it. planning_attempts is the\n   112\t    # transient-failure counter; it resets when planning next progresses.\n   113\t    planning_retry_not_before: datetime | None = None\n   114\t    planning_attempts: int = 0\n   115\t\n   116\t    # Human pause gate (un-freeze #3): an availability flag on the claim predicate\n   117\t    # (the same durable-gate pattern as planning_retry_not_before), NOT a phase —\n   118\t    # the legacy phase projection remains unchanged. Armed by a human pause command;\n   119\t    # cleared by resume(), which is intentionally separate from targeted retry.\n   120\t    paused: bool = False\n   121\t    paused_reason: str | None = None\n   122\t\n   123\t    @model_validator(mode=\"before\")\n   124\t    @classmethod\n   125\t    def map_legacy_phase_status(cls, data: object) -> object:\n   126\t        if not isinstance(data, dict) or \"status\" in data:\n   127\t            return data\n   128\t        raw_phase = data.get(\"phase\", PlanPhase.DISCOVERY.value)\n   129\t        phase = raw_phase.value if isinstance(raw_phase, PlanPhase) else str(raw_phase)\n   130\t        mapped = {\n   131\t            PlanPhase.DISCOVERY.value: PlanStatus.WAITING,\n   132\t            PlanPhase.REPLANNING.value: PlanStatus.WAITING,\n   133\t            PlanPhase.ARCHITECTURE.value: PlanStatus.RUNNING,\n   134\t            PlanPhase.ENRICHING.value: PlanStatus.RUNNING,\n   135\t            PlanPhase.AWAITING_REVIEW.value: PlanStatus.WAITING,\n   136\t            PlanPhase.RUNNING.value: PlanStatus.RUNNING,\n   137\t            PlanPhase.REVIEW.value: PlanStatus.WAITING,\n   138\t            PlanPhase.DONE.value: PlanStatus.IDLE,\n   139\t            PlanPhase.FAILED.value: PlanStatus.BLOCKED,\n   140\t        }\n   141\t        return {**data, \"status\": mapped.get(phase, PlanStatus.BLOCKED)}\n   142\t\n   143\t    # ---- helpers ----\n   144\t    def _set_phase(self, phase: PlanPhase) -> None:\n   145\t        \"\"\"Compatibility checkpoint while active behavior migrates to artifacts.\"\"\"\n   146\t        self.phase = phase\n   147\t        self.status = {\n   148\t            PlanPhase.DISCOVERY: PlanStatus.WAITING,\n   149\t            PlanPhase.REPLANNING: PlanStatus.WAITING,\n   150\t            PlanPhase.ARCHITECTURE: PlanStatus.RUNNING,\n   151\t            PlanPhase.ENRICHING: PlanStatus.RUNNING,\n   152\t            PlanPhase.AWAITING_REVIEW: PlanStatus.WAITING,\n   153\t            PlanPhase.RUNNING: PlanStatus.RUNNING,\n   154\t            PlanPhase.REVIEW: PlanStatus.WAITING,\n   155\t            PlanPhase.DONE: PlanStatus.IDLE,\n   156\t            PlanPhase.FAILED: PlanStatus.BLOCKED,\n   157\t        }[phase]\n   158\t\n   159\t    def bump_version(self) -> None:\n   160\t        self.version += 1\n   161\t\n   162\t    def _assert_not_terminal(self) -> None:\n   163\t        if self.phase in TERMINAL_PHASES:\n   164\t            raise PlanAlreadyTerminalError(self.id, self.phase.value)\n   165\t\n   166\t    def assert_lifecycle_mutation_allowed(self) -> None:\n   167\t        if self.promotion_reservation is not None:\n   168\t            raise InvalidEditError(\"a verified Git promotion is in progress\")\n   169\t\n   170\t    def reserve_promotion(self, reservation: str) -> None:\n   171\t        if self.promotion_reservation not in (None, reservation):\n   172\t            raise InvalidEditError(\"another verified Git promotion is in progress\")\n   173\t        self.promotion_reservation = reservation\n   174\t\n   175\t    def release_promotion(self, reservation: str) -> None:\n   176\t        if self.promotion_reservation == reservation:\n   177\t            self.promotion_reservation = None\n   178\t\n   179\t    def abandon_execution_task(\n   180\t        self,\n   181\t        cycle_id: str | None,\n   182\t        goal_id: str,\n   183\t        task_id: str,\n   184\t    ) -> None:\n   185\t        goals = self.goals\n   186\t        if cycle_id is not None:\n   187\t            cycle = next((item for item in self.cycles if item.id == cycle_id), None)\n   188\t            if cycle is None:\n   189\t                raise InvalidEditError(f\"cycle '{cycle_id}' not found\")\n   190\t            goals = cycle.goals\n   191\t        find_task(find_goal(goals, goal_id), task_id).abandon()\n   192\t\n   193\t    def _guard_phase(self, allowed_from: set[PlanPhase], to: PlanPhase) -> None:\n   194\t        if self.phase not in allowed_from:\n   195\t            raise InvalidTransitionError(\"Plan\", self.id, self.phase.value, to.value)\n   196\t\n   197\t    @property\n   198\t    def execution_goals(self) -> list[Goal]:\n   199\t        cycle = self.active_cycle\n   200\t        return cycle.goals if cycle is not None else self.goals\n   201\t\n   202\t    def _goal(self, goal_id: str) -> Goal:\n   203\t        return find_goal(self.execution_goals, goal_id)\n   204\t\n   205\t    def _task(self, goal: Goal, task_id: str) -> Task:\n   206\t        return find_task(goal, task_id)\n   207\t\n   208\t    # ---- navigation ----\n   209\t    def peek_next(self, now: datetime) -> NextAction:\n   210\t        return next_action(self.execution_goals, now)\n   211\t\n   212\t    # ---- task transitions (aggregate calls entity methods) ----\n   213\t    def start_task(self, goal_id: str, task_id: str) -> None:\n   214\t        self._assert_not_terminal()\n   215\t        goal = self._goal(goal_id)\n   216\t        task = self._task(goal, task_id)\n   217\t        if task.result is not None:\n   218\t            return  # idempotency: work already happened, do not restart\n   219\t        if goal.status == Status.PENDING:\n   220\t            goal.start()\n   220\t            goal.start()\n   221\t        task.start()\n   222\t\n   223\t    def complete_task(self, goal_id: str, task_id: str, result: TaskResult) -> None:\n   224\t        self._assert_not_terminal()\n   225\t        goal = self._goal(goal_id)\n   226\t        self._task(goal, task_id).complete(result)\n   227\t\n   228\t    def requeue_task(self, goal_id: str, task_id: str, not_before: datetime | None = None) -> None:\n   229\t        self._assert_not_terminal()\n   230\t        goal = self._goal(goal_id)\n   231\t        self._task(goal, task_id).requeue(not_before)\n   232\t\n   233\t    def fail_task(\n   234\t        self, goal_id: str, task_id: str, reason: str, kind: FailureKind | None = None\n   235\t    ) -> None:\n   236\t        self._assert_not_terminal()\n   237\t        goal = self._goal(goal_id)\n   238\t        self._task(goal, task_id).fail(reason, kind)\n   239\t\n   240\t    def abandon_task(self, goal_id: str, task_id: str) -> None:\n   241\t        \"\"\"Tolerant finalize: terminal-skip an in-flight task whose iteration was\n   242\t        abandoned by a replan — never requeue into an abandoned iteration.\"\"\"\n   243\t        self._assert_not_terminal()\n   244\t        goal = self._goal(goal_id)\n   245\t        self._task(goal, task_id).abandon()\n   246\t\n   247\t    def reopen_task(self, goal_id: str, task_id: str) -> None:\n   248\t        \"\"\"Human-driven redo of a DONE task (review gate). The invariant (only a\n   249\t        DONE task can be reopened) lives on Task.reopen(); exposing it here keeps\n   250\t        the aggregate the single mutation root.\"\"\"\n   251\t        self._assert_not_terminal()\n   252\t        goal = self._goal(goal_id)\n   253\t        self._task(goal, task_id).reopen()\n   254\t        # the goal may already be DONE; re-open it so the scan re-enters it\n   255\t        if goal.status == Status.DONE:\n   256\t            goal.reopen()\n   257\t\n   258\t    # ---- goal transitions ----\n   259\t    def complete_goal(self, goal_id: str) -> None:\n   260\t        self._assert_not_terminal()\n   261\t        self._goal(goal_id).complete()\n   262\t\n   263\t    # ---- graceful human pause gate ----\n   264\t    def request_pause(self, active_action: bool, reason: str | None = None) -> None:\n   265\t        \"\"\"Block new claims immediately; settle only after an active action finalizes.\"\"\"\n   266\t        if self.paused or self.pause_requested:\n   267\t            if reason is not None:\n   268\t                self.paused_reason = reason\n   269\t            return\n   270\t        if self.status != PlanStatus.RUNNING or (\n   271\t            self.active_cycle is None and self.phase not in WORKER_CLAIMABLE_PHASES\n   272\t        ):\n   273\t            raise InvalidTransitionError(\"Plan\", self.id, self.status.value, \"paused\")\n   274\t        self.paused_reason = reason\n   275\t        if active_action:\n   276\t            self.pause_requested = True\n   277\t            return\n   278\t        self.settle_pause()\n   279\t\n   280\t    def settle_pause(self) -> None:\n   281\t        \"\"\"Transition a requested pause at an atomic action boundary.\"\"\"\n   282\t        self.pause_requested = False\n   283\t        self.paused = True\n   284\t        self.status = PlanStatus.PAUSED\n   285\t\n   286\t    def pause(self, reason: str | None = None) -> None:\n   287\t        \"\"\"Arm the pause gate: the claim predicate skips a paused plan, so the\n   288\t        worker stops at the next unit boundary (an in-flight attempt finalizes\n   289\t        normally). Only meaningful in the worker-claimable phases — gates and\n   290\t        conversational phases are already paused by the driver model. Idempotent\n   291\t        when already paused (the reason may be refreshed).\"\"\"\n   292\t        if self.paused:\n   293\t            if reason is not None:\n   294\t                self.paused_reason = reason\n   295\t            return\n   296\t        if self.active_cycle is None and self.phase not in WORKER_CLAIMABLE_PHASES:\n   297\t            raise InvalidTransitionError(\"Plan\", self.id, self.phase.value, \"paused\")\n   298\t        self.paused = True\n   299\t        self.paused_reason = reason\n   300\t        self.status = PlanStatus.PAUSED\n   301\t\n   302\t    def resume(self) -> None:\n   303\t        \"\"\"Remove a manual pause without mutating retry or backoff state.\"\"\"\n   304\t        if not self.paused:\n   305\t            raise InvalidTransitionError(\"Plan\", self.id, self.phase.value, \"resumed\")\n   306\t        self.paused = False\n   307\t        self.pause_requested = False\n   308\t        self.paused_reason = None\n   309\t        self.status = (\n   310\t            PlanStatus.RUNNING\n   311\t            if self.active_cycle is not None or self.phase in WORKER_CLAIMABLE_PHASES\n   312\t            else PlanStatus.IDLE\n   313\t        )\n   314\t\n   315\t    def retry_task(self, goal_id: str, task_id: str, resolved_at: datetime) -> str | None:\n   316\t        \"\"\"Retry exactly one failed task; absolute attempt identity is preserved.\n   317\t\n   318\t        Return the block resolution when retrying from a structured block. A\n   319\t        legacy paused plan has no block and therefore returns None; callers must\n   320\t        still issue the separate resume command to release its pause gate.\n   321\t        \"\"\"\n   322\t        blocked = self.block is not None and self.block.active\n   323\t        if not self.paused and not blocked:\n   324\t            raise InvalidTransitionError(\"Plan\", self.id, self.status.value, \"retry\")\n   325\t        resolution: str | None = None\n   326\t        if blocked and (\n   327\t            self.block is None\n   328\t            or self.block.goal_id != goal_id\n   329\t            or self.block.task_id != task_id\n   330\t            or not {\"retry_stage\", \"wait_and_retry\"}.intersection(self.block.legal_resolutions)\n   331\t        ):\n   332\t            raise InvalidEditError(\"retry does not target the active plan block\")\n   333\t        if blocked:\n   334\t            assert self.block is not None\n   335\t            resolution = (\n   336\t                \"wait_and_retry\"\n   337\t                if \"wait_and_retry\" in self.block.legal_resolutions\n   338\t                else \"retry_stage\"\n   339\t            )\n   340\t        goal = self._goal(goal_id)\n   341\t        task = self._task(goal, task_id)\n   342\t        edited_pending = bool(\n   343\t            blocked\n   344\t            and task.status == Status.PENDING\n   345\t            and self.block is not None\n   346\t            and \"edit_task\" in self.block.legal_resolutions\n   347\t        )\n   348\t        if edited_pending:\n   349\t            resolution = \"edit_task\"\n   350\t        else:\n   351\t            task.retry()\n   352\t        if blocked:\n   353\t            assert self.block is not None\n   354\t            self.block.resolution = resolution\n   355\t            self.block.resolved_at = resolved_at\n   356\t            self.status = PlanStatus.RUNNING\n   357\t        return resolution\n   358\t\n   359\t    def retry_planning_stage(self, resolved_at: datetime) -> None:\n   360\t        \"\"\"Resolve a cyclic reasoner failure and requeue the same planning stage.\"\"\"\n   361\t        if (\n   362\t            self.block is None\n   363\t            or not self.block.active\n   364\t            or self.block.kind != \"reasoner_failure\"\n   365\t            or \"retry_stage\" not in self.block.legal_resolutions\n   366\t        ):\n   367\t            raise InvalidEditError(\"plan is not blocked on a retryable planning stage\")\n   368\t        self.block.resolution = \"retry_stage\"\n   369\t        self.block.resolved_at = resolved_at\n   370\t        self.clear_planning_retry()\n   371\t        self.status = PlanStatus.RUNNING\n   372\t\n   373\t    def retry_agent_binding(\n   374\t        self,\n   375\t        goal_id: str,\n   376\t        role_agent_ids_by_task: dict[str, dict[str, str]],\n   377\t        resolved_at: datetime,\n   378\t    ) -> None:\n   379\t        \"\"\"Atomically bind every frozen task after the user repairs the registry.\"\"\"\n   380\t        block = self.block\n   381\t        if (\n   382\t            block is None\n   383\t            or not block.active\n   384\t            or block.kind != \"agent_capability\"\n   385\t            or block.goal_id != goal_id\n   386\t            or \"retry_stage\" not in block.legal_resolutions\n   387\t        ):\n   388\t            raise InvalidEditError(\"plan is not blocked on retryable agent binding\")\n   389\t        goal = self._goal(goal_id)\n   390\t        expected_task_ids = {task.id for task in goal.tasks}\n   391\t        if not expected_task_ids or set(role_agent_ids_by_task) != expected_task_ids:\n   392\t            raise InvalidEditError(\"agent bindings must cover every frozen task\")\n   393\t        required_roles = {\"test_author\", \"implementer\"}\n   394\t        for task in goal.tasks:\n   395\t            binding = role_agent_ids_by_task[task.id]\n   396\t            if not required_roles.issubset(binding) or any(\n   397\t                not binding[role] for role in required_roles\n   398\t            ):\n   399\t                raise InvalidEditError(\"each task requires test-author and implementer bindings\")\n   400\t\n   401\t        for task in goal.tasks:\n   402\t            task.role_agent_ids = dict(role_agent_ids_by_task[task.id])\n   403\t            task.agent_id = task.role_agent_ids[\"implementer\"]\n   404\t        block.resolution = \"retry_stage\"\n   405\t        block.resolved_at = resolved_at\n   406\t        self.clear_planning_retry()\n   407\t        self._set_phase(PlanPhase.RUNNING)\n   408\t\n   409\t    # ---- worker-driven planning retry gate (un-freeze 2026-07-08) ----\n   410\t    def record_planning_retry(self, not_before: datetime | None) -> None:\n   411\t        \"\"\"A TRANSIENT reasoner failure in a worker-driven planning phase: bump the\n   412\t        attempt counter and arm the durable backoff gate. The claim predicate skips\n   413\t        an armed plan until `not_before`, so the worker backs off (durably, across\n   414\t        crashes) instead of re-hitting the provider every poll.\"\"\"\n   415\t        self._assert_not_terminal()\n   416\t        self.planning_attempts += 1\n   417\t        self.planning_retry_not_before = not_before\n   418\t\n   419\t    def clear_planning_retry(self) -> None:\n   420\t        \"\"\"Planning progressed — disarm the gate and reset the attempt counter.\"\"\"\n   421\t        self.planning_attempts = 0\n   422\t        self.planning_retry_not_before = None\n   423\t\n   424\t    def fail_plan(self) -> None:\n   425\t        \"\"\"Terminal reasoner failure from a worker-driven planning phase: the\n   426\t        planning LLM is permanently unavailable or its retry budget is exhausted.\n   427\t        ARCHITECTURE/ENRICHING -> FAILED. This is the ONLY remaining path to\n   428\t        FAILED: a terminal *task* failure auto-pauses instead (un-freeze #3), so\n   429\t        execution failures stay recoverable in-band.\"\"\"\n   430\t        self._guard_phase(set(WORKER_PLANNING_PHASES), PlanPhase.FAILED)\n   431\t        self._set_phase(PlanPhase.FAILED)\n   432\t\n   433\t    # ---- phase transitions ----\n   434\t    def advance_phase(self, to: PlanPhase) -> None:\n   435\t        \"\"\"Generic forward step used by the planning flow (DISCOVERY -> ARCHITECTURE\n   436\t        -> ENRICHING -> AWAITING_REVIEW). The gate/loop transitions below are the\n   437\t        guarded, named paths — prefer them wherever one exists.\"\"\"\n   438\t        self._assert_not_terminal()\n   439\t        self._set_phase(to)\n   440\t\n   441\t    def approve(self) -> None:\n   442\t        \"\"\"Human approval at the pre-execution gate: AWAITING_REVIEW -> RUNNING.\"\"\"\n   443\t        self._guard_phase({PlanPhase.AWAITING_REVIEW}, PlanPhase.RUNNING)\n   444\t        self._set_phase(PlanPhase.RUNNING)\n   445\t\n   446\t    def reopen_discovery(self) -> None:\n   447\t        \"\"\"Human \"request changes\" at the pre-execution gate: AWAITING_REVIEW ->\n   448\t        DISCOVERY. Re-opens the planning conversation; the next commit flows\n   449\t        through set_iteration_goals, which REPLACES the un-executed roadmap\n   450\t        (terminal history is kept). Distinct from REPLANNING, whose commit\n   451\t        appends and bumps the iteration — nothing has executed yet here, so\n   452\t        there is no history worth preserving.\"\"\"\n   453\t        self._guard_phase({PlanPhase.AWAITING_REVIEW}, PlanPhase.DISCOVERY)\n   454\t        self.paused = False\n   455\t        self.paused_reason = None\n   456\t        self._set_phase(PlanPhase.DISCOVERY)\n   457\t\n   458\t    def enter_review(self) -> None:\n   459\t        \"\"\"Execution exhausted the goal list: RUNNING -> REVIEW (the post-exec\n   460\t        gate). DONE is reached only from REVIEW via finish_review().\"\"\"\n   461\t        self._guard_phase({PlanPhase.RUNNING}, PlanPhase.REVIEW)\n   462\t        self._set_phase(PlanPhase.REVIEW)\n   463\t\n   464\t    def finish_review(self) -> None:\n   465\t        \"\"\"Human \"finish\" at the post-execution gate: REVIEW -> DONE.\"\"\"\n   466\t        self._guard_phase({PlanPhase.REVIEW}, PlanPhase.DONE)\n   467\t        self._set_phase(PlanPhase.DONE)\n   468\t\n   469\t    def begin_replanning(self) -> None:\n   470\t        \"\"\"Enter the conversational re-plan. Two entry points, one phase: from\n   471\t        REVIEW (\"replan next phase\") or mid-RUNNING (user chat). Abandons the\n   472\t        current iteration's remaining work: every PENDING goal (and any PENDING\n   473\t        task inside a still-RUNNING goal) is SKIPPED now; an in-flight RUNNING\n   474\t        task finalizes via tolerant finalize; whatever remains is closed by the\n   475\t        finalize-abandon in commit_replanned_goals(). A human replan supersedes\n   476\t        any pause: the gate clears so the committed roadmap can execute.\"\"\"\n   477\t        self.assert_lifecycle_mutation_allowed()\n   478\t        # Cyclic authority: a plan with an active cycle can always be replanned\n   479\t        # (start_replan is an advertised block/running resolution), regardless of\n   480\t        # the legacy PlanPhase projection — which for a replanned cycle is already\n   481\t        # REPLANNING and would otherwise reject \"replanning -> replanning\". Legacy\n   482\t        # (pre-cyclic) plans keep the RUNNING/REVIEW phase guard.\n   483\t        if self.active_cycle is None:\n   484\t            self._guard_phase({PlanPhase.RUNNING, PlanPhase.REVIEW}, PlanPhase.REPLANNING)\n   485\t        self.paused = False\n   486\t        self.paused_reason = None\n   487\t        for goal in self.goals:\n   488\t            if goal.status == Status.PENDING:\n   489\t                for task in goal.tasks:\n   490\t                    if task.status == Status.PENDING:\n   491\t                        task.skip()\n   492\t                goal.skip()\n   493\t            elif goal.status == Status.RUNNING:\n   494\t                for task in goal.tasks:\n   495\t                    if task.status == Status.PENDING:\n   496\t                        task.skip()\n   497\t                # leave the goal RUNNING: its in-flight task finalizes tolerantly\n   498\t        self._set_phase(PlanPhase.REPLANNING)\n   499\t\n   500\t    def set_iteration_goals(self, new_goals: list[Goal]) -> None:\n   501\t        \"\"\"The planning phases' write path (roadmap 2.5 driver): replace the\n   502\t        current iteration's non-terminal goals with the reasoner's new set —\n   503\t        DISCOVERY drafts them, ARCHITECTURE structures them, ENRICHING details\n   504\t        them. Terminal goals (prior-iteration history) are never touched; the\n   505\t        new set is renumbered to positions after them.\"\"\"\n   506\t        self.assert_lifecycle_mutation_allowed()\n   507\t        self._guard_phase(\n   508\t            {PlanPhase.DISCOVERY, PlanPhase.ARCHITECTURE, PlanPhase.ENRICHING},\n   509\t            self.phase,\n   510\t        )\n   511\t        kept = [g for g in self.goals if g.is_terminal]\n   512\t        base = max((g.position for g in kept), default=-1) + 1\n   513\t        for offset, goal in enumerate(new_goals):\n   514\t            goal.position = base + offset\n   515\t        self.goals = kept + list(new_goals)\n   516\t\n   517\t    def commit_replanned_goals(self, new_goals: list[Goal]) -> None:\n   518\t        \"\"\"The conversational re-plan produced a new goal set: finalize-abandon\n   519\t        whatever the prior iteration left non-terminal (closes the resurrection\n   520\t        hole — a stale goal must never be re-executed after the next iteration\n   521\t        starts), append the new goals (append-only history), bump the iteration,\n   522\t        and flow into ARCHITECTURE like DISCOVERY does.\"\"\"\n   523\t        self.assert_lifecycle_mutation_allowed()\n   524\t        self._guard_phase({PlanPhase.REPLANNING}, PlanPhase.ARCHITECTURE)\n   525\t        for goal in self.goals:\n   526\t            if goal.is_terminal:\n   527\t                continue\n   528\t            for task in goal.tasks:\n   529\t                if not task.is_terminal:\n   530\t                    task.abandon()\n   531\t            goal.skip()\n   532\t        base = max((g.position for g in self.goals), default=-1) + 1\n   533\t        for offset, goal in enumerate(new_goals):\n   534\t            goal.position = base + offset\n   535\t            self.goals.append(goal)\n   536\t        self.iteration += 1\n   537\t        self._set_phase(PlanPhase.ARCHITECTURE)\n   538\t\n   539\t    def bind_legacy_project(self, project_id: str, resolved_at: datetime) -> None:\n   540\t        \"\"\"Operator-only binding for quarantined legacy rows.\"\"\"\n   541\t        if self.project_id is not None:\n   542\t            if self.project_id == project_id:\n   543\t                return\n   544\t            raise InvalidEditError(\"project identity is immutable\")\n   545\t        if self.block is None or self.block.kind != \"project_binding\" or not self.block.active:\n   546\t            raise InvalidEditError(\"plan is not waiting for a project binding\")\n   547\t        self.project_id = project_id\n   548\t        self.block.resolution = \"bind_project\"\n   549\t        self.block.resolved_at = resolved_at\n   550\t        self.status = self.legacy_mapped_status or PlanStatus.IDLE\n   551\t\n   552\t    # ---- cyclic project-plan lifecycle (unfreeze #4) ----\n   553\t    @property\n   554\t    def active_cycle(self) -> Cycle | None:\n   555\t        return next(\n   556\t            (cycle for cycle in self.cycles if cycle.status == CycleStatus.ACTIVE),\n   557\t            None,\n   558\t        )\n   559\t\n   560\t    @property\n   561\t    def status_reason(self) -> dict[str, str | None]:\n   562\t        if self.promotion_reservation is not None:\n   563\t            return {\n   564\t                \"kind\": \"promotion\",\n   565\t                \"code\": \"git_promotion\",\n   566\t                \"message\": \"Promoting verified code at an atomic boundary.\",\n   567\t            }\n   568\t        if self.block is not None and self.block.active:\n   569\t            return {\n   570\t                \"kind\": \"block\",\n   570\t                \"kind\": \"block\",\n   571\t                \"code\": self.block.kind,\n   572\t                \"message\": self.block.explanation,\n   573\t            }\n   574\t        if self.review_gate is not None and self.review_gate.unresolved:\n   575\t            return {\n   576\t                \"kind\": \"review_gate\",\n   577\t                \"code\": self.review_gate.subject_type.value,\n   578\t                \"message\": self.review_gate.continuation,\n   579\t            }\n   580\t        if self.pause_requested:\n   581\t            return {\n   582\t                \"kind\": \"pause_requested\",\n   583\t                \"code\": \"active_action\",\n   584\t                \"message\": self.paused_reason or \"waiting for the current action\",\n   585\t            }\n   586\t        if self.paused:\n   587\t            return {\n   588\t                \"kind\": \"manual_pause\",\n   589\t                \"code\": \"paused\",\n   590\t                \"message\": self.paused_reason,\n   591\t            }\n   592\t        return {\"kind\": self.status.value, \"code\": None, \"message\": None}\n   593\t\n   594\t    @property\n   595\t    def legal_actions(self) -> list[str]:\n   596\t        if self.promotion_reservation is not None:\n   597\t            return [\"pause\"] if self.status == PlanStatus.RUNNING else []\n   598\t        if self.block is not None and self.block.active:\n   599\t            return list(self.block.legal_resolutions)\n   600\t        if self.review_gate is not None and self.review_gate.unresolved:\n   601\t            return [f\"review:{decision}\" for decision in self.review_gate.allowed_decisions]\n   602\t        if self.pause_requested:\n   603\t            return []\n   604\t        if self.status == PlanStatus.RUNNING:\n   605\t            return [\"pause\", \"start_replan\"]\n   606\t        if self.status == PlanStatus.PAUSED:\n   607\t            return [\n   608\t                \"resume\",\n   609\t                \"start_replan\",\n   610\t                \"edit_pending_work\",\n   611\t            ]\n   612\t        if self.status == PlanStatus.IDLE or (\n   613\t            self.status == PlanStatus.WAITING\n   614\t            and self.review_gate is None\n   615\t            and self.intent_proposal is None\n   616\t        ):\n   617\t            return [\"start_intent\"]\n   618\t        return []\n   619\t\n   620\t    @property\n   621\t    def activity(self) -> str:\n   622\t        \"\"\"Derived activity; never persisted as a second lifecycle enum.\"\"\"\n   623\t        if self.block is not None and self.block.active:\n   624\t            return f\"blocked:{self.block.stage}\"\n   625\t        if self.review_gate is not None and self.review_gate.unresolved:\n   626\t            return f\"review:{self.review_gate.subject_type.value}\"\n   627\t        if self.intent_proposal is not None and self.intent_proposal.approved_at is None:\n   628\t            return \"intent_discovery\"\n   629\t        if (\n   630\t            self.intent_proposal is not None\n   631\t            and self.intent_proposal.approved_at is not None\n   632\t            and self.cycle_draft is None\n   633\t        ):\n   634\t            return \"cycle_architecture\"\n   635\t        if self.cycle_draft is not None and self.cycle_draft.approved_at is None:\n   636\t            return \"cycle_architecture\"\n   637\t        cycle = self.active_cycle\n   638\t        if cycle is None:\n   639\t            return \"intent_discovery\" if self.status == PlanStatus.WAITING else \"idle\"\n   640\t        action = next_action(cycle.goals, datetime.max.replace(tzinfo=timezone.utc))\n   641\t        if isinstance(action, tuple):\n   642\t            goal, subject = action\n   643\t            if isinstance(subject, Task):\n   644\t                return f\"task:{goal.id}:{subject.id}\"\n   645\t            return f\"goal:{goal.id}\"\n   646\t        return \"cycle_verification\"\n   647\t\n   648\t    def _open_review_gate(self, gate: ReviewGate) -> None:\n   649\t        if self.review_gate is not None and self.review_gate.unresolved:\n   650\t            raise InvalidEditError(\"a blocking review gate is already open\")\n   651\t        self.review_gate = gate\n   652\t        self.status = PlanStatus.WAITING\n   653\t\n   654\t    def _resolve_review_gate(\n   655\t        self,\n   656\t        gate_id: str,\n   657\t        subject_revision: int,\n   658\t        decision: str,\n   659\t        resolved_at: datetime,\n   660\t        resolved_by: str | None = None,\n   661\t        note: str | None = None,\n   662\t    ) -> None:\n   663\t        gate = self.review_gate\n   664\t        if gate is None or gate.id != gate_id:\n   665\t            raise InvalidEditError(\"review gate not found\")\n   666\t        if gate.resolution is not None:\n   667\t            if gate.resolution.decision == decision:\n   668\t                return\n   669\t            raise InvalidEditError(\"review gate was already resolved differently\")\n   670\t        if gate.invalidated_at is not None:\n   671\t            raise InvalidEditError(\"review gate is invalidated\")\n   672\t        if gate.subject_revision != subject_revision:\n   673\t            raise InvalidEditError(\"review decision targets a stale subject revision\")\n   674\t        if decision not in gate.allowed_decisions:\n   675\t            raise InvalidEditError(f\"review decision '{decision}' is not legal\")\n   676\t        gate.resolution = ReviewResolution(\n   677\t            decision=decision,\n   678\t            resolved_at=resolved_at,\n   679\t            resolved_by=resolved_by,\n   680\t            note=note,\n   681\t        )\n   682\t\n   683\t    def propose_intent(self, proposal: IntentProposal, gate: ReviewGate) -> None:\n   684\t        self.assert_lifecycle_mutation_allowed()\n   685\t        if self.project_id is None:\n   686\t            raise InvalidEditError(\"project binding is required before intent planning\")\n   687\t        if self.intent_proposal is not None and self.intent_proposal.cancelled_at is None:\n   688\t            raise InvalidEditError(\"an intent proposal is already open\")\n   689\t        if proposal.base_plan_version != self.version:\n   690\t            raise InvalidEditError(\"intent proposal base version is stale\")\n   691\t        if proposal.kind == ProposalKind.REPLAN:\n   692\t            if proposal.source_cycle_id != (\n   693\t                self.active_cycle.id if self.active_cycle is not None else None\n   694\t            ):\n   695\t                raise InvalidEditError(\"replan source cycle is stale\")\n   696\t        self.intent_proposal = proposal\n   697\t        self.cycle_draft = None\n   698\t        self._open_review_gate(gate)\n   699\t\n   700\t    def revise_intent(\n   701\t        self,\n   702\t        proposal: IntentProposal,\n   703\t        replacement_gate: ReviewGate,\n   704\t        invalidated_at: datetime,\n   705\t    ) -> None:\n   706\t        self.assert_lifecycle_mutation_allowed()\n   707\t        current = self.intent_proposal\n   708\t        if current is None or current.id != proposal.id:\n   709\t            raise InvalidEditError(\"intent proposal not found\")\n   710\t        if proposal.revision != current.revision + 1:\n   711\t            raise InvalidEditError(\"intent proposal revision must increment by one\")\n   712\t        if proposal.base_plan_version != self.version:\n   713\t            raise InvalidEditError(\"intent proposal base version is stale\")\n   714\t        if proposal.kind != current.kind or proposal.source_cycle_id != current.source_cycle_id:\n   715\t            raise InvalidEditError(\"intent kind and replan source are immutable\")\n   716\t        if self.review_gate is not None and self.review_gate.unresolved:\n   717\t            self.review_gate.invalidated_at = invalidated_at\n   718\t        self.review_gate = None\n   719\t        self.intent_proposal = proposal\n   720\t        self._open_review_gate(replacement_gate)\n   721\t\n   722\t    def cancel_intent(self, cancelled_at: datetime) -> None:\n   723\t        self.assert_lifecycle_mutation_allowed()\n   724\t        proposal = self.intent_proposal\n   725\t        if proposal is None or proposal.approved_at is not None:\n   726\t            raise InvalidEditError(\"open intent proposal not found\")\n   727\t        proposal.cancelled_at = cancelled_at\n   728\t        if self.review_gate is not None and self.review_gate.unresolved:\n   729\t            self.review_gate.invalidated_at = cancelled_at\n   730\t        self.intent_proposal = None\n   731\t        self.review_gate = None\n   732\t        self.status = PlanStatus.PAUSED if self.active_cycle is not None else PlanStatus.IDLE\n   733\t\n   734\t    def approve_intent(self, gate_id: str, revision: int, resolved_at: datetime) -> None:\n   735\t        self.assert_lifecycle_mutation_allowed()\n   736\t        proposal = self.intent_proposal\n   737\t        if proposal is None or proposal.revision != revision:\n   738\t            raise InvalidEditError(\"intent proposal revision is stale\")\n   739\t        self._resolve_review_gate(gate_id, revision, \"approve\", resolved_at)\n   740\t        proposal.approved_at = resolved_at\n   741\t        self.status = PlanStatus.RUNNING\n   742\t\n   743\t    def submit_cycle_draft(self, draft: CycleDraft, gate: ReviewGate) -> None:\n   744\t        self.assert_lifecycle_mutation_allowed()\n   745\t        proposal = self.intent_proposal\n   746\t        if proposal is None or proposal.approved_at is None:\n   747\t            raise InvalidEditError(\"an approved intent is required\")\n   748\t        if draft.intent_proposal_id != proposal.id:\n   749\t            raise InvalidEditError(\"cycle draft references the wrong intent\")\n   750\t        if draft.base_plan_version != self.version:\n   751\t            raise InvalidEditError(\"cycle draft base version is stale\")\n   752\t        if draft.source_cycle_id != proposal.source_cycle_id:\n   753\t            raise InvalidEditError(\"cycle draft source cycle is stale\")\n   754\t        self.review_gate = None\n   755\t        self.cycle_draft = draft\n   756\t        self._open_review_gate(gate)\n   757\t\n   758\t    def revise_cycle_draft(\n   759\t        self,\n   760\t        draft: CycleDraft,\n   761\t        replacement_gate: ReviewGate,\n   762\t        invalidated_at: datetime,\n   763\t    ) -> None:\n   764\t        self.assert_lifecycle_mutation_allowed()\n   765\t        current = self.cycle_draft\n   766\t        if current is None or current.id != draft.id:\n   767\t            raise InvalidEditError(\"cycle draft not found\")\n   768\t        if draft.revision != current.revision + 1:\n   769\t            raise InvalidEditError(\"cycle draft revision must increment by one\")\n   770\t        if draft.base_plan_version != self.version:\n   771\t            raise InvalidEditError(\"cycle draft base version is stale\")\n   772\t        if (\n   773\t            draft.intent_proposal_id != current.intent_proposal_id\n   774\t            or draft.source_cycle_id != current.source_cycle_id\n   775\t        ):\n   776\t            raise InvalidEditError(\"cycle draft intent and source are immutable\")\n   777\t        if self.review_gate is not None and self.review_gate.unresolved:\n   778\t            self.review_gate.invalidated_at = invalidated_at\n   779\t        self.review_gate = None\n   780\t        self.cycle_draft = draft\n   781\t        self._open_review_gate(replacement_gate)\n   782\t\n   783\t    def activate_cycle(\n   784\t        self,\n   785\t        gate_id: str,\n   786\t        revision: int,\n   787\t        cycle: Cycle,\n   788\t        resolved_at: datetime,\n   789\t    ) -> None:\n   790\t        self.assert_lifecycle_mutation_allowed()\n   791\t        draft = self.cycle_draft\n   792\t        if draft is None or draft.revision != revision:\n   793\t            raise InvalidEditError(\"cycle draft revision is stale\")\n   794\t        if self.version != draft.base_plan_version + 1:\n   795\t            raise InvalidEditError(\"cycle draft base version is stale\")\n   796\t        if cycle.draft_id != draft.id or cycle.intent_proposal_id != draft.intent_proposal_id:\n   797\t            raise InvalidEditError(\"cycle does not match the approved draft\")\n   798\t        source = self.active_cycle\n   799\t        if draft.source_cycle_id is not None:\n   800\t            if source is None or source.id != draft.source_cycle_id:\n   801\t                raise InvalidEditError(\"active source cycle changed; regenerate the draft\")\n   802\t            source.status = CycleStatus.SUPERSEDED\n   803\t            source.superseded_at = resolved_at\n   804\t        elif source is not None:\n   805\t            raise InvalidEditError(\"only one active cycle is allowed\")\n   806\t        self._resolve_review_gate(gate_id, revision, \"approve\", resolved_at)\n   807\t        draft.approved_at = resolved_at\n   808\t        self.cycles.append(cycle)\n   809\t        self.intent_proposal = None\n   810\t        self.cycle_draft = None\n   811\t        self.review_gate = None\n   812\t        self.block = None\n   813\t        self.paused = False\n   814\t        self.pause_requested = False\n   815\t        self.status = PlanStatus.RUNNING\n   816\t\n   817\t    def cancel_cycle_draft(self, cancelled_at: datetime) -> None:\n   818\t        self.assert_lifecycle_mutation_allowed()\n   819\t        if self.cycle_draft is None:\n   820\t            raise InvalidEditError(\"cycle draft not found\")\n   821\t        self.cycle_draft.cancelled_at = cancelled_at\n   822\t        self.cycle_draft = None\n   823\t        self.intent_proposal = None\n   824\t        self.review_gate = None\n   825\t        self.status = PlanStatus.PAUSED if self.active_cycle is not None else PlanStatus.IDLE\n   826\t\n   827\t    def open_block(self, block: PlanBlock) -> None:\n   828\t        if self.block is not None and self.block.active:\n   829\t            raise InvalidEditError(\"a plan block is already active\")\n   830\t        self.block = block\n   831\t        self.status = PlanStatus.BLOCKED\n   832\t\n   833\t    def resolve_block(self, resolution: str, resolved_at: datetime) -> None:\n   834\t        if self.block is None or not self.block.active:\n   835\t            raise InvalidEditError(\"no active plan block\")\n   836\t        if resolution not in self.block.legal_resolutions:\n   837\t            raise InvalidEditError(f\"block resolution '{resolution}' is not legal\")\n   838\t        self.block.resolution = resolution\n   839\t        self.block.resolved_at = resolved_at\n   840\t        self.status = PlanStatus.PAUSED if self.active_cycle is not None else PlanStatus.IDLE\n   841\t\n   842\t    def open_completion_gate(self, gate: ReviewGate, evidence_refs: list[str]) -> None:\n   843\t        cycle = self.active_cycle\n   844\t        if cycle is None:\n   845\t            raise InvalidEditError(\"no active cycle to verify\")\n   846\t        cycle.evidence_refs = list(evidence_refs)\n   847\t        self._open_review_gate(gate)\n   848\t\n   849\t    def record_output_disposition(\n   850\t        self,\n   851\t        gate_id: str,\n   852\t        revision: int,\n   853\t        disposition: OutputDisposition,\n   854\t        output_reference: str | None,\n   855\t        resolved_at: datetime,\n   856\t    ) -> None:\n   857\t        cycle = self.active_cycle\n   858\t        if cycle is None:\n   859\t            raise InvalidEditError(\"no active cycle\")\n   860\t        if disposition != OutputDisposition.DISCARD and not output_reference:\n   861\t            raise InvalidEditError(\"successful output disposition requires a reference\")\n   862\t        self._resolve_review_gate(gate_id, revision, disposition.value, resolved_at)\n   863\t        cycle.output_disposition = disposition\n   864\t        cycle.output_reference = output_reference\n   865\t        cycle.completed_at = resolved_at\n   866\t        if disposition == OutputDisposition.DISCARD:\n   867\t            cycle.cancelled_at = resolved_at\n   868\t        cycle.status = (\n   869\t            CycleStatus.CANCELLED\n   870\t            if disposition == OutputDisposition.DISCARD\n   871\t            else CycleStatus.COMPLETED\n   872\t        )\n   873\t        self.review_gate = None\n   874\t        self.status = PlanStatus.IDLE\n   875\t\n   876\t    # ---- creation-time agent binding ----\n   877\t    def bind_agents(self, agents: list[AgentSpec], default_agent_id: str) -> list[str]:\n   878\t        \"\"\"Bind unbound tasks to agents by capability. Returns task ids that fell\n   879\t        back to the default (caller emits AgentFellBackToDefault events).\"\"\"\n   880\t        fell_back: list[str] = []\n   881\t        for goal in self.execution_goals:\n   882\t            for task in goal.tasks:\n   883\t                if task.agent_id is None:\n   884\t                    agent_id, used_default = match_agent(\n   885\t                        task.required_capabilities, agents, default_agent_id\n   886\t                    )\n   887\t                    task.agent_id = agent_id\n   888\t                    if used_default:\n   889\t                        fell_back.append(task.id)\n   890\t        return fell_back\n","exit_code":0,"status":"completed"}}
{"type":"item.started","item":{"id":"item_5","type":"command_execution","command":"/bin/bash -lc \"nl -ba backend/src/domain/aggregates/planner_orchestrator.py | sed -n '400,545p'; nl -ba backend/src/app/use_cases/request_replan.py; nl -ba backend/src/app/use_cases/cyclic_planning.py | sed -n '1,380p'; nl -ba backend/src/app/use_cases/conversation.py | sed -n '1,420p'\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
{"type":"item.completed","item":{"id":"item_5","type":"command_execution","command":"/bin/bash -lc \"nl -ba backend/src/domain/aggregates/planner_orchestrator.py | sed -n '400,545p'; nl -ba backend/src/app/use_cases/request_replan.py; nl -ba backend/src/app/use_cases/cyclic_planning.py | sed -n '1,380p'; nl -ba backend/src/app/use_cases/conversation.py | sed -n '1,420p'\"","aggregated_output":"   400\t\n   401\t        for task in goal.tasks:\n   402\t            task.role_agent_ids = dict(role_agent_ids_by_task[task.id])\n   403\t            task.agent_id = task.role_agent_ids[\"implementer\"]\n   404\t        block.resolution = \"retry_stage\"\n   405\t        block.resolved_at = resolved_at\n   406\t        self.clear_planning_retry()\n   407\t        self._set_phase(PlanPhase.RUNNING)\n   408\t\n   409\t    # ---- worker-driven planning retry gate (un-freeze 2026-07-08) ----\n   410\t    def record_planning_retry(self, not_before: datetime | None) -> None:\n   411\t        \"\"\"A TRANSIENT reasoner failure in a worker-driven planning phase: bump the\n   412\t        attempt counter and arm the durable backoff gate. The claim predicate skips\n   413\t        an armed plan until `not_before`, so the worker backs off (durably, across\n   414\t        crashes) instead of re-hitting the provider every poll.\"\"\"\n   415\t        self._assert_not_terminal()\n   416\t        self.planning_attempts += 1\n   417\t        self.planning_retry_not_before = not_before\n   418\t\n   419\t    def clear_planning_retry(self) -> None:\n   420\t        \"\"\"Planning progressed — disarm the gate and reset the attempt counter.\"\"\"\n   421\t        self.planning_attempts = 0\n   422\t        self.planning_retry_not_before = None\n   423\t\n   424\t    def fail_plan(self) -> None:\n   425\t        \"\"\"Terminal reasoner failure from a worker-driven planning phase: the\n   426\t        planning LLM is permanently unavailable or its retry budget is exhausted.\n   427\t        ARCHITECTURE/ENRICHING -> FAILED. This is the ONLY remaining path to\n   428\t        FAILED: a terminal *task* failure auto-pauses instead (un-freeze #3), so\n   429\t        execution failures stay recoverable in-band.\"\"\"\n   430\t        self._guard_phase(set(WORKER_PLANNING_PHASES), PlanPhase.FAILED)\n   431\t        self._set_phase(PlanPhase.FAILED)\n   432\t\n   433\t    # ---- phase transitions ----\n   434\t    def advance_phase(self, to: PlanPhase) -> None:\n   435\t        \"\"\"Generic forward step used by the planning flow (DISCOVERY -> ARCHITECTURE\n   436\t        -> ENRICHING -> AWAITING_REVIEW). The gate/loop transitions below are the\n   437\t        guarded, named paths — prefer them wherever one exists.\"\"\"\n   438\t        self._assert_not_terminal()\n   439\t        self._set_phase(to)\n   440\t\n   441\t    def approve(self) -> None:\n   442\t        \"\"\"Human approval at the pre-execution gate: AWAITING_REVIEW -> RUNNING.\"\"\"\n   443\t        self._guard_phase({PlanPhase.AWAITING_REVIEW}, PlanPhase.RUNNING)\n   444\t        self._set_phase(PlanPhase.RUNNING)\n   445\t\n   446\t    def reopen_discovery(self) -> None:\n   447\t        \"\"\"Human \"request changes\" at the pre-execution gate: AWAITING_REVIEW ->\n   448\t        DISCOVERY. Re-opens the planning conversation; the next commit flows\n   449\t        through set_iteration_goals, which REPLACES the un-executed roadmap\n   450\t        (terminal history is kept). Distinct from REPLANNING, whose commit\n   451\t        appends and bumps the iteration — nothing has executed yet here, so\n   452\t        there is no history worth preserving.\"\"\"\n   453\t        self._guard_phase({PlanPhase.AWAITING_REVIEW}, PlanPhase.DISCOVERY)\n   454\t        self.paused = False\n   455\t        self.paused_reason = None\n   456\t        self._set_phase(PlanPhase.DISCOVERY)\n   457\t\n   458\t    def enter_review(self) -> None:\n   459\t        \"\"\"Execution exhausted the goal list: RUNNING -> REVIEW (the post-exec\n   460\t        gate). DONE is reached only from REVIEW via finish_review().\"\"\"\n   461\t        self._guard_phase({PlanPhase.RUNNING}, PlanPhase.REVIEW)\n   462\t        self._set_phase(PlanPhase.REVIEW)\n   463\t\n   464\t    def finish_review(self) -> None:\n   465\t        \"\"\"Human \"finish\" at the post-execution gate: REVIEW -> DONE.\"\"\"\n   466\t        self._guard_phase({PlanPhase.REVIEW}, PlanPhase.DONE)\n   467\t        self._set_phase(PlanPhase.DONE)\n   468\t\n   469\t    def begin_replanning(self) -> None:\n   470\t        \"\"\"Enter the conversational re-plan. Two entry points, one phase: from\n   471\t        REVIEW (\"replan next phase\") or mid-RUNNING (user chat). Abandons the\n   472\t        current iteration's remaining work: every PENDING goal (and any PENDING\n   473\t        task inside a still-RUNNING goal) is SKIPPED now; an in-flight RUNNING\n   474\t        task finalizes via tolerant finalize; whatever remains is closed by the\n   475\t        finalize-abandon in commit_replanned_goals(). A human replan supersedes\n   476\t        any pause: the gate clears so the committed roadmap can execute.\"\"\"\n   477\t        self.assert_lifecycle_mutation_allowed()\n   478\t        # Cyclic authority: a plan with an active cycle can always be replanned\n   479\t        # (start_replan is an advertised block/running resolution), regardless of\n   480\t        # the legacy PlanPhase projection — which for a replanned cycle is already\n   481\t        # REPLANNING and would otherwise reject \"replanning -> replanning\". Legacy\n   482\t        # (pre-cyclic) plans keep the RUNNING/REVIEW phase guard.\n   483\t        if self.active_cycle is None:\n   484\t            self._guard_phase({PlanPhase.RUNNING, PlanPhase.REVIEW}, PlanPhase.REPLANNING)\n   485\t        self.paused = False\n   486\t        self.paused_reason = None\n   487\t        for goal in self.goals:\n   488\t            if goal.status == Status.PENDING:\n   489\t                for task in goal.tasks:\n   490\t                    if task.status == Status.PENDING:\n   491\t                        task.skip()\n   492\t                goal.skip()\n   493\t            elif goal.status == Status.RUNNING:\n   494\t                for task in goal.tasks:\n   495\t                    if task.status == Status.PENDING:\n   496\t                        task.skip()\n   497\t                # leave the goal RUNNING: its in-flight task finalizes tolerantly\n   498\t        self._set_phase(PlanPhase.REPLANNING)\n   499\t\n   500\t    def set_iteration_goals(self, new_goals: list[Goal]) -> None:\n   501\t        \"\"\"The planning phases' write path (roadmap 2.5 driver): replace the\n   502\t        current iteration's non-terminal goals with the reasoner's new set —\n   503\t        DISCOVERY drafts them, ARCHITECTURE structures them, ENRICHING details\n   504\t        them. Terminal goals (prior-iteration history) are never touched; the\n   505\t        new set is renumbered to positions after them.\"\"\"\n   506\t        self.assert_lifecycle_mutation_allowed()\n   507\t        self._guard_phase(\n   508\t            {PlanPhase.DISCOVERY, PlanPhase.ARCHITECTURE, PlanPhase.ENRICHING},\n   509\t            self.phase,\n   510\t        )\n   511\t        kept = [g for g in self.goals if g.is_terminal]\n   512\t        base = max((g.position for g in kept), default=-1) + 1\n   513\t        for offset, goal in enumerate(new_goals):\n   514\t            goal.position = base + offset\n   515\t        self.goals = kept + list(new_goals)\n   516\t\n   517\t    def commit_replanned_goals(self, new_goals: list[Goal]) -> None:\n   518\t        \"\"\"The conversational re-plan produced a new goal set: finalize-abandon\n   519\t        whatever the prior iteration left non-terminal (closes the resurrection\n   520\t        hole — a stale goal must never be re-executed after the next iteration\n   521\t        starts), append the new goals (append-only history), bump the iteration,\n   522\t        and flow into ARCHITECTURE like DISCOVERY does.\"\"\"\n   523\t        self.assert_lifecycle_mutation_allowed()\n   524\t        self._guard_phase({PlanPhase.REPLANNING}, PlanPhase.ARCHITECTURE)\n   525\t        for goal in self.goals:\n   526\t            if goal.is_terminal:\n   527\t                continue\n   528\t            for task in goal.tasks:\n   529\t                if not task.is_terminal:\n   530\t                    task.abandon()\n   531\t            goal.skip()\n   532\t        base = max((g.position for g in self.goals), default=-1) + 1\n   533\t        for offset, goal in enumerate(new_goals):\n   534\t            goal.position = base + offset\n   535\t            self.goals.append(goal)\n   536\t        self.iteration += 1\n   537\t        self._set_phase(PlanPhase.ARCHITECTURE)\n   538\t\n   539\t    def bind_legacy_project(self, project_id: str, resolved_at: datetime) -> None:\n   540\t        \"\"\"Operator-only binding for quarantined legacy rows.\"\"\"\n   541\t        if self.project_id is not None:\n   542\t            if self.project_id == project_id:\n   543\t                return\n   544\t            raise InvalidEditError(\"project identity is immutable\")\n   545\t        if self.block is None or self.block.kind != \"project_binding\" or not self.block.active:\n     1\t\"\"\"request_replan — enter the conversational re-plan (state machinery only).\n     2\t\n     3\tTwo entry points, one phase: from REVIEW (\"replan next phase\") and from\n     4\tmid-RUNNING user chat (\"give me a new plan\"). Either way the aggregate skips the\n     5\tcurrent iteration's PENDING work now (an in-flight task finalizes via the\n     6\ttolerant finalize in ExecutionHandler) and the plan lands in REPLANNING — a\n     7\tconversational phase that is NOT worker-claimable; each user message advances it\n     8\tvia the conversation use cases (roadmap Phase 2.5 wires the reasoning content).\n     9\t\n    10\tThis is distinct from apply_edit: apply_edit is the surgical manual edit;\n    11\trequest_replan is the holistic conversational re-plan.\n    12\t\"\"\"\n    13\t\n    14\tfrom __future__ import annotations\n    15\t\n    16\tfrom src.domain.events.outbox import BlockResolved, ReplanRequested\n    17\tfrom src.domain.value_objects.lifecycle import Status\n    18\t\n    19\tfrom src.app.ports import UnitOfWork\n    20\t\n    21\t\n    22\tdef request_replan(plan_id: str, uow: UnitOfWork) -> None:\n    23\t    with uow:\n    24\t        plan = uow.plans.get(plan_id)\n    25\t        from_phase = plan.phase.value\n    26\t        plan.begin_replanning()\n    27\t\n    28\t        cycle = plan.active_cycle\n    29\t        if cycle is not None:\n    30\t            for goal in cycle.goals:\n    31\t                for task in goal.tasks:\n    32\t                    if task.status == Status.FAILED:\n    33\t                        # Requeue is the existing guarded transition that makes\n    34\t                        # a failed task eligible for the tolerant abandon path.\n    35\t                        plan.requeue_task(goal.id, task.id)\n    36\t                    if task.status in {Status.PENDING, Status.RUNNING}:\n    37\t                        plan.abandon_execution_task(cycle.id, goal.id, task.id)\n    38\t\n    39\t        block = plan.block\n    40\t        if block is not None and block.active:\n    41\t            block_id = block.id\n    42\t            plan.resolve_block(\"start_replan\", block.created_at)\n    43\t            uow.outbox.add(\n    44\t                BlockResolved(\n    45\t                    plan_id=plan_id,\n    46\t                    block_id=block_id,\n    47\t                    resolution=\"start_replan\",\n    48\t                )\n    49\t            )\n    50\t\n    51\t        plan.bump_version()\n    52\t        uow.outbox.add(ReplanRequested(plan_id=plan_id, from_phase=from_phase))\n    53\t        uow.plans.save(plan)\n     1\t\"\"\"Application transactions for versioned intent, cycle, review, and publication.\"\"\"\n     2\t\n     3\tfrom __future__ import annotations\n     4\t\n     5\tfrom src.app.ports import Clock, UnitOfWork\n     6\tfrom src.domain.aggregates.planner_orchestrator import PlanPhase\n     7\tfrom src.domain.entities.goal import Goal\n     8\tfrom src.domain.entities.planning_artifacts import (\n     9\t    Cycle,\n    10\t    CycleDraft,\n    11\t    GoalOutline,\n    12\t    IntentProposal,\n    13\t    OutputDisposition,\n    14\t    ProposalKind,\n    15\t    ReviewGate,\n    16\t    ReviewSubjectType,\n    17\t)\n    18\tfrom src.domain.events.outbox import (\n    19\t    CycleActivated,\n    20\t    CycleDrafted,\n    21\t    IntentApproved,\n    22\t    IntentProposed,\n    23\t    OutputDispositionRecorded,\n    24\t    ReviewGateOpened,\n    25\t)\n    26\tfrom src.domain.factories.identity import new_id\n    27\tfrom src.domain.errors.planning_errors import InvalidEditError\n    28\t\n    29\t\n    30\tdef propose_intent(\n    31\t    plan_id: str,\n    32\t    *,\n    33\t    objective: str,\n    34\t    scope: list[str],\n    35\t    constraints: list[str],\n    36\t    exclusions: list[str],\n    37\t    kind: ProposalKind,\n    38\t    planner_session_ref: str | None,\n    39\t    uow: UnitOfWork,\n    40\t    clock: Clock,\n    41\t) -> IntentProposal:\n    42\t    with uow:\n    43\t        plan = uow.plans.get(plan_id)\n    44\t        source_cycle_id = (\n    45\t            plan.active_cycle.id if kind == ProposalKind.REPLAN and plan.active_cycle else None\n    46\t        )\n    47\t        proposal = IntentProposal(\n    48\t            id=new_id(),\n    49\t            kind=kind,\n    50\t            base_plan_version=plan.version,\n    51\t            source_cycle_id=source_cycle_id,\n    52\t            objective=objective,\n    53\t            scope=scope,\n    54\t            constraints=constraints,\n    55\t            exclusions=exclusions,\n    56\t            planner_session_ref=planner_session_ref,\n    57\t        )\n    58\t        gate = ReviewGate(\n    59\t            id=new_id(),\n    60\t            subject_type=ReviewSubjectType.INTENT,\n    61\t            subject_id=proposal.id,\n    62\t            subject_revision=proposal.revision,\n    63\t            allowed_decisions=[\"approve\", \"edit\", \"cancel\"],\n    64\t            continuation=\"Approve the exact intent revision before cycle architecture.\",\n    65\t        )\n    66\t        plan.propose_intent(proposal, gate)\n    67\t        plan.bump_version()\n    68\t        uow.outbox.add(IntentProposed(plan_id=plan.id, proposal_id=proposal.id, revision=1))\n    69\t        uow.outbox.add(\n    70\t            ReviewGateOpened(\n    71\t                plan_id=plan.id,\n    72\t                gate_id=gate.id,\n    73\t                subject_type=gate.subject_type.value,\n    74\t                subject_id=proposal.id,\n    75\t                subject_revision=1,\n    76\t            )\n    77\t        )\n    78\t        uow.plans.save(plan)\n    79\t        return proposal\n    80\t\n    81\t\n    82\tdef approve_intent(\n    83\t    plan_id: str,\n    84\t    gate_id: str,\n    85\t    revision: int,\n    86\t    uow: UnitOfWork,\n    87\t    clock: Clock,\n    88\t) -> None:\n    89\t    with uow:\n    90\t        plan = uow.plans.get(plan_id)\n    91\t        proposal = plan.intent_proposal\n    92\t        plan.approve_intent(gate_id, revision, clock.now())\n    93\t        plan.bump_version()\n    94\t        assert proposal is not None\n    95\t        uow.outbox.add(IntentApproved(plan_id=plan.id, proposal_id=proposal.id, revision=revision))\n    96\t        uow.plans.save(plan)\n    97\t\n    98\t\n    99\tdef revise_intent(\n   100\t    plan_id: str,\n   101\t    *,\n   102\t    objective: str,\n   103\t    scope: list[str],\n   104\t    constraints: list[str],\n   105\t    exclusions: list[str],\n   106\t    planner_session_ref: str | None,\n   107\t    uow: UnitOfWork,\n   108\t    clock: Clock,\n   109\t) -> IntentProposal:\n   110\t    with uow:\n   111\t        plan = uow.plans.get(plan_id)\n   112\t        current = plan.intent_proposal\n   113\t        if current is None:\n   114\t            raise InvalidEditError(\"intent proposal not found\")\n   115\t        proposal = current.model_copy(\n   116\t            update={\n   117\t                \"base_plan_version\": plan.version,\n   118\t                \"objective\": objective,\n   119\t                \"scope\": scope,\n   120\t                \"constraints\": constraints,\n   121\t                \"exclusions\": exclusions,\n   122\t                \"revision\": current.revision + 1,\n   123\t                \"planner_session_ref\": planner_session_ref,\n   124\t                \"approved_at\": None,\n   125\t                \"cancelled_at\": None,\n   126\t            }\n   127\t        )\n   128\t        gate = ReviewGate(\n   129\t            id=new_id(),\n   130\t            subject_type=ReviewSubjectType.INTENT,\n   131\t            subject_id=proposal.id,\n   132\t            subject_revision=proposal.revision,\n   133\t            allowed_decisions=[\"approve\", \"edit\", \"cancel\"],\n   134\t            continuation=\"Approve the revised intent before cycle architecture.\",\n   135\t        )\n   136\t        plan.revise_intent(proposal, gate, clock.now())\n   137\t        plan.bump_version()\n   138\t        uow.outbox.add(\n   139\t            IntentProposed(\n   140\t                plan_id=plan.id,\n   141\t                proposal_id=proposal.id,\n   142\t                revision=proposal.revision,\n   143\t            )\n   144\t        )\n   145\t        uow.outbox.add(\n   146\t            ReviewGateOpened(\n   147\t                plan_id=plan.id,\n   148\t                gate_id=gate.id,\n   149\t                subject_type=gate.subject_type.value,\n   150\t                subject_id=proposal.id,\n   151\t                subject_revision=proposal.revision,\n   152\t            )\n   153\t        )\n   154\t        uow.plans.save(plan)\n   155\t        return proposal\n   156\t\n   157\t\n   158\tdef cancel_intent(\n   159\t    plan_id: str,\n   160\t    *,\n   161\t    uow: UnitOfWork,\n   162\t    clock: Clock,\n   163\t) -> None:\n   164\t    with uow:\n   165\t        plan = uow.plans.get(plan_id)\n   166\t        plan.cancel_intent(clock.now())\n   167\t        plan.bump_version()\n   168\t        uow.plans.save(plan)\n   169\t\n   170\t\n   171\tdef submit_cycle_draft(\n   172\t    plan_id: str,\n   173\t    *,\n   174\t    goals: list[GoalOutline],\n   175\t    unfinished_source_treatment: str | None,\n   176\t    uow: UnitOfWork,\n   177\t) -> CycleDraft:\n   178\t    with uow:\n   179\t        plan = uow.plans.get(plan_id)\n   180\t        proposal = plan.intent_proposal\n   181\t        if proposal is None:\n   182\t            raise InvalidEditError(\"approved intent is required\")\n   183\t        draft = CycleDraft(\n   184\t            id=new_id(),\n   185\t            intent_proposal_id=proposal.id,\n   186\t            base_plan_version=plan.version,\n   187\t            source_cycle_id=proposal.source_cycle_id,\n   188\t            goals=goals,\n   189\t            unfinished_source_treatment=unfinished_source_treatment,\n   190\t        )\n   191\t        gate = ReviewGate(\n   192\t            id=new_id(),\n   193\t            subject_type=ReviewSubjectType.CYCLE_DRAFT,\n   194\t            subject_id=draft.id,\n   195\t            subject_revision=draft.revision,\n   196\t            allowed_decisions=[\"approve\", \"edit\", \"cancel\"],\n   197\t            continuation=\"Approve the exact CycleDraft revision to activate execution.\",\n   198\t        )\n   199\t        plan.submit_cycle_draft(draft, gate)\n   200\t        plan.bump_version()\n   201\t        uow.outbox.add(CycleDrafted(plan_id=plan.id, draft_id=draft.id, revision=1))\n   202\t        uow.outbox.add(\n   203\t            ReviewGateOpened(\n   204\t                plan_id=plan.id,\n   205\t                gate_id=gate.id,\n   206\t                subject_type=gate.subject_type.value,\n   207\t                subject_id=draft.id,\n   208\t                subject_revision=1,\n   209\t            )\n   210\t        )\n   211\t        uow.plans.save(plan)\n   212\t        return draft\n   213\t\n   214\t\n   215\tdef revise_cycle_draft(\n   216\t    plan_id: str,\n   217\t    *,\n   218\t    goals: list[GoalOutline],\n   219\t    unfinished_source_treatment: str | None,\n   220\t    uow: UnitOfWork,\n   221\t    clock: Clock,\n   222\t) -> CycleDraft:\n   223\t    with uow:\n   224\t        plan = uow.plans.get(plan_id)\n   225\t        current = plan.cycle_draft\n   226\t        if current is None:\n   227\t            raise InvalidEditError(\"cycle draft not found\")\n   228\t        draft = current.model_copy(\n   229\t            update={\n   230\t                \"base_plan_version\": plan.version,\n   231\t                \"goals\": goals,\n   232\t                \"revision\": current.revision + 1,\n   233\t                \"unfinished_source_treatment\": unfinished_source_treatment,\n   234\t                \"approved_at\": None,\n   235\t                \"cancelled_at\": None,\n   236\t            }\n   237\t        )\n   238\t        # model_copy does not re-run Pydantic validators.\n   239\t        draft = CycleDraft.model_validate(draft.model_dump())\n   240\t        gate = ReviewGate(\n   241\t            id=new_id(),\n   242\t            subject_type=ReviewSubjectType.CYCLE_DRAFT,\n   243\t            subject_id=draft.id,\n   244\t            subject_revision=draft.revision,\n   245\t            allowed_decisions=[\"approve\", \"edit\", \"cancel\"],\n   246\t            continuation=\"Approve the revised CycleDraft to activate execution.\",\n   247\t        )\n   248\t        plan.revise_cycle_draft(draft, gate, clock.now())\n   249\t        plan.bump_version()\n   250\t        uow.outbox.add(CycleDrafted(plan_id=plan.id, draft_id=draft.id, revision=draft.revision))\n   251\t        uow.outbox.add(\n   252\t            ReviewGateOpened(\n   253\t                plan_id=plan.id,\n   254\t                gate_id=gate.id,\n   255\t                subject_type=gate.subject_type.value,\n   256\t                subject_id=draft.id,\n   257\t                subject_revision=draft.revision,\n   258\t            )\n   259\t        )\n   260\t        uow.plans.save(plan)\n   261\t        return draft\n   262\t\n   263\t\n   264\tdef cancel_cycle_draft(\n   265\t    plan_id: str,\n   266\t    *,\n   267\t    uow: UnitOfWork,\n   268\t    clock: Clock,\n   269\t) -> None:\n   270\t    with uow:\n   271\t        plan = uow.plans.get(plan_id)\n   272\t        plan.cancel_cycle_draft(clock.now())\n   273\t        plan.bump_version()\n   274\t        uow.plans.save(plan)\n   275\t\n   276\t\n   277\tdef activate_cycle(\n   278\t    plan_id: str,\n   279\t    gate_id: str,\n   280\t    revision: int,\n   281\t    uow: UnitOfWork,\n   282\t    clock: Clock,\n   283\t) -> Cycle:\n   284\t    with uow:\n   285\t        plan = uow.plans.get(plan_id)\n   286\t        draft = plan.cycle_draft\n   287\t        if draft is None:\n   288\t            raise InvalidEditError(\"cycle draft is required\")\n   289\t        goal_ids = {outline.key: new_id() for outline in draft.goals}\n   290\t        goals = [\n   291\t            Goal(\n   292\t                id=goal_ids[outline.key],\n   293\t                name=outline.name,\n   294\t                position=outline.position,\n   295\t                description=outline.objective,\n   296\t                depends_on=[goal_ids[key] for key in outline.depends_on],\n   297\t            )\n   298\t            for outline in sorted(draft.goals, key=lambda item: item.position)\n   299\t        ]\n   300\t        cycle = Cycle(\n   301\t            id=new_id(),\n   302\t            intent_proposal_id=draft.intent_proposal_id,\n   303\t            draft_id=draft.id,\n   304\t            goals=goals,\n   305\t            started_at=clock.now(),\n   306\t        )\n   307\t        plan.activate_cycle(gate_id, revision, cycle, clock.now())\n   308\t        # Compatibility projection only; cyclic navigation/status are authoritative.\n   309\t        plan._set_phase(PlanPhase.ENRICHING)\n   310\t        plan.bump_version()\n   311\t        uow.outbox.add(\n   312\t            CycleActivated(\n   313\t                plan_id=plan.id,\n   314\t                cycle_id=cycle.id,\n   315\t                draft_id=draft.id,\n   316\t            )\n   317\t        )\n   318\t        uow.plans.save(plan)\n   319\t        return cycle\n   320\t\n   321\t\n   322\tdef record_output_disposition(\n   323\t    plan_id: str,\n   324\t    gate_id: str,\n   325\t    revision: int,\n   326\t    disposition: OutputDisposition,\n   327\t    output_reference: str | None,\n   328\t    uow: UnitOfWork,\n   329\t    clock: Clock,\n   330\t) -> None:\n   331\t    with uow:\n   332\t        plan = uow.plans.get(plan_id)\n   333\t        cycle = plan.active_cycle\n   334\t        plan.record_output_disposition(\n   335\t            gate_id,\n   336\t            revision,\n   337\t            disposition,\n   338\t            output_reference,\n   339\t            clock.now(),\n   340\t        )\n   341\t        plan.bump_version()\n   342\t        assert cycle is not None\n   343\t        uow.outbox.add(\n   344\t            OutputDispositionRecorded(\n   345\t                plan_id=plan.id,\n   346\t                cycle_id=cycle.id,\n   347\t                disposition=disposition.value,\n   348\t                output_reference=output_reference,\n   349\t            )\n   350\t        )\n   351\t        uow.plans.save(plan)\n     1\t\"\"\"Synchronous, durable intent-discovery turns.\n     2\t\n     3\tThe submitted user message is persisted before the reasoner call. Operational\n     4\tstatus lives in the execution ledger, while an accepted IntentProposal and its\n     5\treview gate commit with domain events in the Plan transaction.\n     6\t\"\"\"\n     7\t\n     8\tfrom __future__ import annotations\n     9\t\n    10\tfrom dataclasses import replace\n    11\tfrom uuid import uuid4\n    12\t\n    13\tfrom pydantic import BaseModel\n    14\t\n    15\tfrom src.app.execution_records import (\n    16\t    PlanningOperation,\n    17\t    PlanningOperationStatus,\n    18\t)\n    19\tfrom src.app.ports import (\n    20\t    ChatMessage,\n    21\t    ChatStore,\n    22\t    Clock,\n    23\t    ConversationMode,\n    24\t    Reasoner,\n    25\t    ReasonerUnavailable,\n    26\t    UnitOfWork,\n    27\t)\n    28\tfrom src.domain.aggregates.planner_orchestrator import Plan, PlanPhase\n    29\tfrom src.domain.entities.planning_artifacts import (\n    30\t    IntentProposal,\n    31\t    PlanStatus,\n    32\t    ProposalKind,\n    33\t    ReviewGate,\n    34\t    ReviewSubjectType,\n    35\t)\n    36\tfrom src.domain.errors.planning_errors import InvalidEditError\n    37\tfrom src.domain.events.outbox import IntentProposed, ReviewGateOpened\n    38\tfrom src.domain.factories.identity import new_id\n    39\tfrom src.domain.ports.reasoner_port import IntentCandidate, ReasonerReply\n    40\t\n    41\t\n    42\tclass ConversationResult(BaseModel):\n    43\t    reply: str\n    44\t    committed: bool\n    45\t    phase: PlanPhase\n    46\t    operation_id: str\n    47\t    operation_status: PlanningOperationStatus\n    48\t    error: str | None = None\n    49\t\n    50\t\n    51\tasync def discovery_message(\n    52\t    plan_id: str,\n    53\t    message: str,\n    54\t    uow: UnitOfWork,\n    55\t    reasoner: Reasoner,\n    56\t    chat: ChatStore,\n    57\t    clock: Clock,\n    58\t) -> ConversationResult:\n    59\t    return await _conversation_turn(\n    60\t        plan_id, message, uow, reasoner, chat, clock, ProposalKind.INITIAL\n    61\t    )\n    62\t\n    63\t\n    64\tasync def replanning_message(\n    65\t    plan_id: str,\n    66\t    message: str,\n    67\t    uow: UnitOfWork,\n    68\t    reasoner: Reasoner,\n    69\t    chat: ChatStore,\n    70\t    clock: Clock,\n    71\t) -> ConversationResult:\n    72\t    return await _conversation_turn(\n    73\t        plan_id, message, uow, reasoner, chat, clock, ProposalKind.REPLAN\n    74\t    )\n    75\t\n    76\t\n    77\tdef _start_operation(\n    78\t    plan_id: str,\n    79\t    kind: ProposalKind,\n    80\t    uow: UnitOfWork,\n    81\t    clock: Clock,\n    82\t) -> tuple[Plan, PlanningOperation]:\n    83\t    now = clock.now()\n    84\t    with uow:\n    85\t        plan = uow.plans.get(plan_id)\n    86\t        if plan.project_id is None:\n    87\t            raise InvalidEditError(\"project binding is required before intent discovery\")\n    88\t        if (\n    89\t            plan.intent_proposal is not None and plan.intent_proposal.approved_at is None\n    90\t        ) or (plan.review_gate is not None and plan.review_gate.unresolved):\n    91\t            # Only an UNRESOLVED intent (or open review gate) is an in-progress\n    92\t            # planning review that must be finished/cancelled first. An APPROVED\n    93\t            # intent is the current cycle's source and must not block a REPLAN\n    94\t            # discovery from opening a new proposal over the active cycle.\n    95\t            raise InvalidEditError(\"finish or cancel the current planning review first\")\n    96\t        if kind == ProposalKind.REPLAN and plan.active_cycle is None:\n    97\t            raise InvalidEditError(\"replan discovery requires an active cycle\")\n    98\t        if kind == ProposalKind.INITIAL and plan.active_cycle is not None:\n    99\t            raise InvalidEditError(\"an active cycle requires replan discovery\")\n   100\t        if kind == ProposalKind.INITIAL and plan.status not in {\n   101\t            PlanStatus.IDLE,\n   102\t            PlanStatus.WAITING,\n   103\t        }:\n   104\t            raise InvalidEditError(\"initial discovery is not legal in the current state\")\n   105\t        if kind == ProposalKind.REPLAN and plan.status not in {\n   106\t            PlanStatus.PAUSED,\n   107\t            PlanStatus.BLOCKED,\n   108\t            PlanStatus.IDLE,\n   109\t        }:\n   110\t            cycle = plan.active_cycle\n   111\t            settled = cycle is not None and all(\n   112\t                task.is_terminal for goal in cycle.goals for task in goal.tasks\n   113\t            )\n   114\t            if not (plan.status == PlanStatus.WAITING and settled):\n   115\t                raise InvalidEditError(\"replan discovery requires settled active-cycle work\")\n   116\t\n   117\t        purpose = \"intent_discovery\" if kind == ProposalKind.INITIAL else \"replan_discovery\"\n   118\t        operation = uow.executions.find_active_planning_operation(plan_id, purpose)\n   119\t        if operation is None:\n   120\t            operation = PlanningOperation(\n   121\t                id=str(uuid4()),\n   122\t                plan_id=plan_id,\n   123\t                purpose=purpose,\n   124\t                status=PlanningOperationStatus.STARTED,\n   125\t                created_at=now,\n   126\t                updated_at=now,\n   127\t                started_at=now,\n   128\t                last_liveness_at=now,\n   129\t            )\n   130\t            uow.executions.add_planning_operation(operation)\n   131\t        else:\n   132\t            operation = replace(\n   133\t                operation,\n   134\t                status=PlanningOperationStatus.STARTED,\n   135\t                updated_at=now,\n   136\t                started_at=operation.started_at or now,\n   137\t                last_liveness_at=now,\n   138\t                completed_at=None,\n   139\t                failure_kind=None,\n   140\t                safe_message=None,\n   141\t            )\n   142\t            uow.executions.update_planning_operation(operation)\n   143\t        return plan, operation\n   144\t\n   145\t\n   146\tdef _candidate_from_legacy(reply: ReasonerReply, brief: str) -> IntentCandidate | None:\n   147\t    \"\"\"Temporary adapter for scripted Reasoners while clients migrate.\n   148\t\n   149\t    Legacy goal DTOs are collapsed into intent text; they are never persisted as\n   150\t    executable goals, so roadmap generation remains post-approval and canonical.\n   151\t    \"\"\"\n   152\t    if reply.intent is not None:\n   153\t        return reply.intent\n   154\t    if not reply.goals:\n   155\t        return None\n   156\t    return IntentCandidate(\n   157\t        normalized_brief=brief,\n   158\t        objective=\"\\n\".join(f\"{goal.name}: {goal.description}\".strip() for goal in reply.goals),\n   159\t    )\n   160\t\n   161\t\n   162\tasync def _conversation_turn(\n   163\t    plan_id: str,\n   164\t    message: str,\n   165\t    uow: UnitOfWork,\n   166\t    reasoner: Reasoner,\n   167\t    chat: ChatStore,\n   168\t    clock: Clock,\n   169\t    kind: ProposalKind,\n   170\t) -> ConversationResult:\n   171\t    plan, operation = _start_operation(plan_id, kind, uow, clock)\n   172\t    history = chat.list(plan_id)\n   173\t    chat.append(\n   174\t        plan_id,\n   175\t        ChatMessage(\n   176\t            role=\"user\",\n   177\t            content=message,\n   178\t            created_at=clock.now(),\n   179\t            meta={\"planning_operation_id\": operation.id, \"submitted_brief\": True},\n   180\t        ),\n   181\t    )\n   182\t\n   183\t    mode: ConversationMode = \"discovery\" if kind == ProposalKind.INITIAL else \"replanning\"\n   184\t    try:\n   185\t        reply = await reasoner.converse(plan, history, message, mode)\n   186\t    except ReasonerUnavailable as exc:\n   187\t        now = clock.now()\n   188\t        failed = replace(\n   189\t            operation,\n   190\t            status=PlanningOperationStatus.FAILED,\n   191\t            updated_at=now,\n   192\t            completed_at=now,\n   193\t            last_liveness_at=now,\n   194\t            failure_kind=\"reasoner_unavailable\",\n   195\t            safe_message=exc.reason[:500],\n   196\t        )\n   197\t        with uow:\n   198\t            uow.executions.update_planning_operation(failed)\n   199\t        assistant = f\"Discovery failed before an intent proposal was committed. {exc.reason[:500]}\"\n   200\t        chat.append(\n   201\t            plan_id,\n   202\t            ChatMessage(\n   203\t                role=\"assistant\",\n   204\t                content=assistant,\n   205\t                created_at=now,\n   206\t                meta={\n   207\t                    \"committed\": False,\n   208\t                    \"planning_operation_id\": operation.id,\n   209\t                    \"planning_status\": PlanningOperationStatus.FAILED.value,\n   210\t                },\n   211\t            ),\n   212\t        )\n   213\t        return ConversationResult(\n   214\t            reply=assistant,\n   215\t            committed=False,\n   216\t            phase=plan.phase,\n   217\t            operation_id=operation.id,\n   218\t            operation_status=PlanningOperationStatus.FAILED,\n   219\t            error=exc.reason[:500],\n   220\t        )\n   221\t    except Exception as exc:\n   222\t        now = clock.now()\n   223\t        with uow:\n   224\t            uow.executions.update_planning_operation(\n   225\t                replace(\n   226\t                    operation,\n   227\t                    status=PlanningOperationStatus.FAILED,\n   228\t                    updated_at=now,\n   229\t                    completed_at=now,\n   230\t                    last_liveness_at=now,\n   231\t                    failure_kind=\"reasoner_crash\",\n   232\t                    safe_message=str(exc)[:500],\n   233\t                )\n   234\t            )\n   235\t        raise\n   236\t\n   237\t    candidate = _candidate_from_legacy(reply, plan.brief)\n   238\t    now = clock.now()\n   239\t    if candidate is None:\n   240\t        waiting = replace(\n   241\t            operation,\n   242\t            status=PlanningOperationStatus.WAITING_FOR_USER,\n   243\t            updated_at=now,\n   244\t            last_liveness_at=now,\n   245\t            model_request_count=(operation.model_request_count + reply.model_request_count),\n   246\t            tool_turn_count=operation.tool_turn_count + reply.tool_turn_count,\n   247\t        )\n   248\t        with uow:\n   249\t            uow.executions.update_planning_operation(waiting)\n   250\t        chat.append(\n   251\t            plan_id,\n   252\t            ChatMessage(\n   253\t                role=\"assistant\",\n   254\t                content=reply.message,\n   255\t                created_at=now,\n   256\t                meta={\n   257\t                    \"committed\": False,\n   258\t                    \"planning_operation_id\": operation.id,\n   259\t                    \"planning_status\": PlanningOperationStatus.WAITING_FOR_USER.value,\n   260\t                },\n   261\t            ),\n   262\t        )\n   263\t        return ConversationResult(\n   264\t            reply=reply.message,\n   265\t            committed=False,\n   266\t            phase=plan.phase,\n   267\t            operation_id=operation.id,\n   268\t            operation_status=PlanningOperationStatus.WAITING_FOR_USER,\n   269\t        )\n   270\t\n   271\t    with uow:\n   272\t        fresh = uow.plans.get(plan_id)\n   273\t        proposal = IntentProposal(\n   274\t            id=new_id(),\n   275\t            kind=kind,\n   276\t            base_plan_version=fresh.version,\n   277\t            source_cycle_id=(\n   278\t                fresh.active_cycle.id\n   279\t                if kind == ProposalKind.REPLAN and fresh.active_cycle is not None\n   280\t                else None\n   281\t            ),\n   282\t            objective=candidate.objective,\n   283\t            scope=list(candidate.scope),\n   284\t            constraints=list(candidate.constraints),\n   285\t            exclusions=list(candidate.exclusions),\n   286\t            planner_session_ref=operation.id,\n   287\t        )\n   288\t        gate = ReviewGate(\n   289\t            id=new_id(),\n   290\t            subject_type=ReviewSubjectType.INTENT,\n   291\t            subject_id=proposal.id,\n   292\t            subject_revision=proposal.revision,\n   293\t            allowed_decisions=[\"approve\", \"edit\", \"cancel\"],\n   294\t            continuation=\"Approve the exact intent revision before roadmap generation.\",\n   295\t        )\n   296\t        fresh.propose_intent(proposal, gate)\n   297\t        fresh.bump_version()\n   298\t        uow.outbox.add(\n   299\t            IntentProposed(\n   300\t                plan_id=fresh.id,\n   301\t                proposal_id=proposal.id,\n   302\t                revision=proposal.revision,\n   303\t            )\n   304\t        )\n   305\t        uow.outbox.add(\n   306\t            ReviewGateOpened(\n   307\t                plan_id=fresh.id,\n   308\t                gate_id=gate.id,\n   309\t                subject_type=gate.subject_type.value,\n   310\t                subject_id=proposal.id,\n   311\t                subject_revision=proposal.revision,\n   312\t            )\n   313\t        )\n   314\t        committed = replace(\n   315\t            operation,\n   316\t            status=PlanningOperationStatus.COMMITTED,\n   317\t            updated_at=now,\n   318\t            completed_at=now,\n   319\t            last_liveness_at=now,\n   320\t            model_request_count=(operation.model_request_count + reply.model_request_count),\n   321\t            tool_turn_count=operation.tool_turn_count + reply.tool_turn_count,\n   322\t        )\n   323\t        uow.executions.update_planning_operation(committed)\n   324\t        uow.plans.save(fresh)\n   325\t\n   326\t    chat.append(\n   327\t        plan_id,\n   328\t        ChatMessage(\n   329\t            role=\"assistant\",\n   330\t            content=reply.message,\n   331\t            created_at=now,\n   332\t            meta={\n   333\t                \"committed\": True,\n   334\t                \"planning_operation_id\": operation.id,\n   335\t                \"planning_status\": PlanningOperationStatus.COMMITTED.value,\n   336\t                \"normalized_brief\": candidate.normalized_brief,\n   337\t                \"assumptions\": candidate.assumptions,\n   338\t                \"unresolved_questions\": candidate.unresolved_questions,\n   339\t            },\n   340\t        ),\n   341\t    )\n   342\t    return ConversationResult(\n   343\t        reply=reply.message,\n   344\t        committed=True,\n   345\t        phase=plan.phase,\n   346\t        operation_id=operation.id,\n   347\t        operation_status=PlanningOperationStatus.COMMITTED,\n   348\t    )\n","exit_code":0,"status":"completed"}}
{"type":"item.started","item":{"id":"item_6","type":"command_execution","command":"/bin/bash -lc \"rg -n \\\"_CLAIM_SQL|phase|status|paused|pause_requested\\\" backend/src/infra/db/plan_repository.py; nl -ba backend/src/infra/db/plan_repository.py | sed -n '1,210p'; rg --files backend/tests | rg 'orchestration|replan|cyclic|conversation|pause|claim|planner'; rg -n \\\"begin_replanning|request_replan|start_replan|commit_replanned_goals|legal_actions|intent_discovery|replan_discovery|WORKER_CLAIMABLE|PlanPhase.REPLANNING|PlanStatus.WAITING\\\" backend/tests\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
{"type":"item.completed","item":{"id":"item_6","type":"command_execution","command":"/bin/bash -lc \"rg -n \\\"_CLAIM_SQL|phase|status|paused|pause_requested\\\" backend/src/infra/db/plan_repository.py; nl -ba backend/src/infra/db/plan_repository.py | sed -n '1,210p'; rg --files backend/tests | rg 'orchestration|replan|cyclic|conversation|pause|claim|planner'; rg -n \\\"begin_replanning|request_replan|start_replan|commit_replanned_goals|legal_actions|intent_discovery|replan_discovery|WORKER_CLAIMABLE|PlanPhase.REPLANNING|PlanStatus.WAITING\\\" backend/tests\"","aggregated_output":"22:        (id, project_id, version, status, phase, iteration, data,\n23:         retry_not_before, paused, pause_requested, created_at, updated_at)\n25:        (:id, :project_id, :version, :status, :phase, :iteration, :data,\n26:         :retry_not_before, :paused, :pause_requested, :now, :now)\n30:        status = excluded.status,\n31:        phase = excluded.phase,\n35:        paused = excluded.paused,\n36:        pause_requested = excluded.pause_requested,\n42:_CLAIM_SQL = text(\n51:        WHERE status = 'running'\n55:          AND paused = 0\n56:          AND pause_requested = 0\n117:                \"status\": plan.status.value,\n118:                \"phase\": plan.phase.value,\n126:                \"paused\": int(plan.paused),\n127:                \"pause_requested\": int(plan.pause_requested),\n170:                _CLAIM_SQL,\n220:                    \"SELECT id, project_id, status, phase, iteration, version, \"\n221:                    \"claimed_by, updated_at, paused, pause_requested \"\n229:                \"status\": row[2],\n230:                \"phase\": row[3],\n235:                \"paused\": bool(row[8]),\n236:                \"pause_requested\": bool(row[9]),\n     1\t\"\"\"SQLite Plan repository with CAS, project ownership, and plan leases.\"\"\"\n     2\t\n     3\tfrom __future__ import annotations\n     4\t\n     5\timport json\n     6\tfrom typing import Any\n     7\t\n     8\tfrom sqlalchemy import text\n     9\tfrom sqlalchemy.engine import CursorResult\n    10\tfrom sqlalchemy.orm import Session, sessionmaker\n    11\t\n    12\tfrom src.app.ports import Clock\n    13\tfrom src.domain.aggregates.planner_orchestrator import Plan\n    14\tfrom src.domain.errors.planning_errors import PlanNotFoundError\n    15\tfrom src.domain.errors.tasks_errors import StaleVersionError\n    16\tfrom src.domain.factories.plan_factory import PlanFactory\n    17\tfrom src.infra.db._session import run_in_session\n    18\t\n    19\t_UPSERT_SQL = text(\n    20\t    \"\"\"\n    21\t    INSERT INTO plans\n    22\t        (id, project_id, version, status, phase, iteration, data,\n    23\t         retry_not_before, paused, pause_requested, created_at, updated_at)\n    24\t    VALUES\n    25\t        (:id, :project_id, :version, :status, :phase, :iteration, :data,\n    26\t         :retry_not_before, :paused, :pause_requested, :now, :now)\n    27\t    ON CONFLICT(id) DO UPDATE SET\n    28\t        project_id = excluded.project_id,\n    29\t        version = excluded.version,\n    30\t        status = excluded.status,\n    31\t        phase = excluded.phase,\n    32\t        iteration = excluded.iteration,\n    33\t        data = excluded.data,\n    34\t        retry_not_before = excluded.retry_not_before,\n    35\t        paused = excluded.paused,\n    36\t        pause_requested = excluded.pause_requested,\n    37\t        updated_at = excluded.updated_at\n    38\t    WHERE plans.version < excluded.version\n    39\t    \"\"\"\n    40\t)\n    41\t\n    42\t_CLAIM_SQL = text(\n    43\t    \"\"\"\n    44\t    UPDATE plans\n    45\t    SET claimed_by = :worker_id,\n    46\t        claimed_at = :now_epoch,\n    47\t        lease_expires_at = :expires_epoch,\n    48\t        lease_seconds = :lease_seconds\n    49\t    WHERE id = (\n    50\t        SELECT id FROM plans\n    51\t        WHERE status = 'running'\n    52\t          AND project_id IS NOT NULL\n    53\t          AND (claimed_by IS NULL OR lease_expires_at < :now_epoch)\n    54\t          AND (retry_not_before IS NULL OR retry_not_before < :now_epoch)\n    55\t          AND paused = 0\n    56\t          AND pause_requested = 0\n    57\t        ORDER BY updated_at\n    58\t        LIMIT 1\n    59\t    )\n    60\t    RETURNING data\n    61\t    \"\"\"\n    62\t)\n    63\t\n    64\t_HEARTBEAT_SQL = text(\n    65\t    \"\"\"\n    66\t    UPDATE plans\n    67\t    SET lease_expires_at = :now_epoch + lease_seconds\n    68\t    WHERE id = :plan_id AND claimed_by = :worker_id\n    69\t    \"\"\"\n    70\t)\n    71\t\n    72\t_RELEASE_SQL = text(\n    73\t    \"\"\"\n    74\t    UPDATE plans\n    75\t    SET claimed_by = NULL, claimed_at = NULL,\n    76\t        lease_expires_at = NULL, lease_seconds = NULL\n    77\t    WHERE id = :plan_id AND claimed_by = :worker_id\n    78\t    \"\"\"\n    79\t)\n    80\t\n    81\t\n    82\tclass SqlitePlanRepository:\n    83\t    def __init__(self, session_factory: sessionmaker[Session], clock: Clock) -> None:\n    84\t        self._session_factory = session_factory\n    85\t        self._clock = clock\n    86\t        self._session: Session | None = None\n    87\t\n    88\t    def bind(self, session: Session) -> None:\n    89\t        self._session = session\n    90\t\n    91\t    def unbind(self) -> None:\n    92\t        self._session = None\n    93\t\n    94\t    def _bound(self) -> Session:\n    95\t        if self._session is None:\n    96\t            raise RuntimeError(\"SqlitePlanRepository used outside a UnitOfWork transaction\")\n    97\t        return self._session\n    98\t\n    99\t    def get(self, plan_id: str) -> Plan:\n   100\t        row = (\n   101\t            self._bound()\n   102\t            .execute(text(\"SELECT data FROM plans WHERE id = :id\"), {\"id\": plan_id})\n   103\t            .one_or_none()\n   104\t        )\n   105\t        if row is None:\n   106\t            raise PlanNotFoundError(plan_id)\n   107\t        return PlanFactory.reconstruct(json.loads(row[0]))\n   108\t\n   109\t    def save(self, plan: Plan) -> None:\n   110\t        session = self._bound()\n   111\t        result: CursorResult[Any] = session.execute(  # type: ignore[assignment]\n   112\t            _UPSERT_SQL,\n   113\t            {\n   114\t                \"id\": plan.id,\n   115\t                \"project_id\": plan.project_id,\n   116\t                \"version\": plan.version,\n   117\t                \"status\": plan.status.value,\n   118\t                \"phase\": plan.phase.value,\n   119\t                \"iteration\": plan.iteration,\n   120\t                \"data\": plan.model_dump_json(),\n   121\t                \"retry_not_before\": (\n   122\t                    int(plan.planning_retry_not_before.timestamp())\n   123\t                    if plan.planning_retry_not_before is not None\n   124\t                    else None\n   125\t                ),\n   126\t                \"paused\": int(plan.paused),\n   127\t                \"pause_requested\": int(plan.pause_requested),\n   128\t                \"now\": self._clock.now().isoformat(),\n   129\t            },\n   130\t        )\n   131\t        if result.rowcount == 0:\n   132\t            stored = session.execute(\n   133\t                text(\"SELECT version FROM plans WHERE id = :id\"), {\"id\": plan.id}\n   134\t            ).scalar_one()\n   135\t            raise StaleVersionError(plan.id, plan.version, int(stored))\n   136\t\n   137\t    def find_by_project_id(self, project_id: str) -> str | None:\n   138\t        row = (\n   139\t            self._bound()\n   140\t            .execute(\n   141\t                text(\"SELECT id FROM plans WHERE project_id = :project_id\"),\n   142\t                {\"project_id\": project_id},\n   143\t            )\n   144\t            .one_or_none()\n   145\t        )\n   146\t        return None if row is None else str(row[0])\n   147\t\n   148\t    def find_by_request_id(self, request_id: str) -> str | None:\n   149\t        row = (\n   150\t            self._bound()\n   151\t            .execute(\n   152\t                text(\"SELECT plan_id FROM plan_requests WHERE request_id = :rid\"),\n   153\t                {\"rid\": request_id},\n   154\t            )\n   155\t            .one_or_none()\n   156\t        )\n   157\t        return None if row is None else str(row[0])\n   158\t\n   159\t    def bind_request_id(self, request_id: str, plan_id: str) -> None:\n   160\t        self._bound().execute(\n   161\t            text(\"INSERT OR IGNORE INTO plan_requests (request_id, plan_id) VALUES (:rid, :pid)\"),\n   162\t            {\"rid\": request_id, \"pid\": plan_id},\n   163\t        )\n   164\t\n   165\t    def claim_one_unit(self, worker_id: str, lease_seconds: int) -> Plan | None:\n   166\t        now_epoch = int(self._clock.now().timestamp())\n   167\t\n   168\t        def claim(session: Session) -> str | None:\n   169\t            row = session.execute(\n   170\t                _CLAIM_SQL,\n   171\t                {\n   172\t                    \"worker_id\": worker_id,\n   173\t                    \"now_epoch\": now_epoch,\n   174\t                    \"expires_epoch\": now_epoch + lease_seconds,\n   175\t                    \"lease_seconds\": lease_seconds,\n   176\t                },\n   177\t            ).one_or_none()\n   178\t            return None if row is None else str(row[0])\n   179\t\n   180\t        data = run_in_session(self._session_factory, claim)\n   181\t        return None if data is None else PlanFactory.reconstruct(json.loads(data))\n   182\t\n   183\t    def heartbeat(self, plan_id: str, worker_id: str) -> None:\n   184\t        now_epoch = int(self._clock.now().timestamp())\n   185\t        run_in_session(\n   186\t            self._session_factory,\n   187\t            lambda session: session.execute(\n   188\t                _HEARTBEAT_SQL,\n   189\t                {\"plan_id\": plan_id, \"worker_id\": worker_id, \"now_epoch\": now_epoch},\n   190\t            ),\n   191\t        )\n   192\t\n   193\t    def is_claim_live(self, plan_id: str) -> bool:\n   194\t        now_epoch = int(self._clock.now().timestamp())\n   195\t        row = (\n   196\t            self._bound()\n   197\t            .execute(\n   198\t                text(\n   199\t                    \"SELECT 1 FROM plans WHERE id = :plan_id \"\n   200\t                    \"AND claimed_by IS NOT NULL AND lease_expires_at > :now_epoch\"\n   201\t                ),\n   202\t                {\"plan_id\": plan_id, \"now_epoch\": now_epoch},\n   203\t            )\n   204\t            .one_or_none()\n   205\t        )\n   206\t        return row is not None\n   207\t\n   208\t    def release(self, plan_id: str, worker_id: str) -> None:\n   209\t        run_in_session(\n   210\t            self._session_factory,\nbackend/tests/integration/test_default_cyclic_execution.py\nbackend/tests/unit/orchestration/test_edge_cases.py\nbackend/tests/unit/orchestration/test_aggregate_navigation.py\nbackend/tests/unit/orchestration/test_reasoner_backoff.py\nbackend/tests/unit/orchestration/test_cyclic_worker.py\nbackend/tests/unit/orchestration/test_use_cases.py\nbackend/tests/unit/orchestration/test_cyclic_pause_replan_phase_guards.py\nbackend/tests/unit/orchestration/test_agent_binding_recovery.py\nbackend/tests/unit/orchestration/test_worker_loop.py\nbackend/tests/unit/orchestration/test_execution_records.py\nbackend/tests/unit/orchestration/conftest.py\nbackend/tests/unit/orchestration/test_pause_resume.py\nbackend/tests/unit/orchestration/test_advance_plan.py\nbackend/tests/unit/orchestration/test_conversation_and_planning.py\nbackend/tests/unit/orchestration/test_backoff_gate.py\nbackend/tests/unit/orchestration/test_execution_handler_unpromotable_goal.py\nbackend/tests/unit/orchestration/__init__.py\nbackend/tests/unit/orchestration/test_cyclic_project_plan.py\nbackend/tests/unit/orchestration/test_transitions.py\n