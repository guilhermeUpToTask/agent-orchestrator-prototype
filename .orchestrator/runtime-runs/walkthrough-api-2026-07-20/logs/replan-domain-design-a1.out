        # DISCOVERY / REPLANNING are conversational — never worker-driven.\n   166\t        return Signal.PAUSED\n   167\t\n   168\t    async def _architect_cycle(\n   169\t        self,\n   170\t        plan_id: str,\n   171\t        plan: Plan,\n   172\t        uow: UnitOfWork,\n   173\t    ) -> Signal:\n   174\t        proposal = plan.intent_proposal\n   175\t        assert proposal is not None\n   176\t        operation = self._start_operation(plan_id, \"cycle_architecture\", uow)\n   177\t        try:\n   178\t            outlines = await self._reasoner.architect_cycle(plan)\n   179\t            # This executes duplicate/unknown/self/cycle validation before any\n   180\t            # accepted plan state is mutated.\n   225\t            uow.outbox.add(\n   226\t                ReviewGateOpened(\n   227\t                    plan_id=plan_id,\n   228\t                    gate_id=gate.id,\n   229\t                    subject_type=gate.subject_type.value,\n   230\t                    subject_id=candidate.id,\n   231\t                    subject_revision=1,\n   232\t                )\n   233\t            )\n   234\t            self._finish_operation(uow, operation, PlanningOperationStatus.COMMITTED)\n   235\t            uow.plans.save(fresh)\n   236\t        return Signal.PAUSED\n   237\t\n   238\t    async def _architect(self, plan_id: str, plan: Plan, uow: UnitOfWork) -> Signal:\n   239\t        \"\"\"No-LLM passthrough (see module docstring): the conversation already\n   240\t        committed the roadmap; validate the phase and flow into ENRICHING.\"\"\"\n   241\t        with uow:\n   242\t            plan = uow.plans.get(plan_id)\n   243\t            if plan.phase != PlanPhase.ARCHITECTURE or plan.paused:\n   244\t                return Signal.PAUSED  # raced by a human command; theirs wins\n   245\t            plan.advance_phase(PlanPhase.ENRICHING)\n   246\t            plan.bump_version()\n   247\t            uow.outbox.add(\n   248\t                PhaseAdvanced(\n   249\t                    plan_id=plan_id,\n   250\t                    from_phase=PlanPhase.ARCHITECTURE.value,\n   251\t                    to_phase=PlanPhase.ENRICHING.value,\n   252\t                )\n   253\t            )\n   254\t            uow.plans.save(plan)\n   255\t        return Signal.CONTINUE\n   290\t        except ReasonerUnavailable as exc:\n   291\t            # The reasoner is down (rate limit / upstream error / bad config). Arm\n   292\t            # the durable backoff gate or fail the plan — and surface it (outbox ->\n   293\t            # SSE) instead of letting it propagate to a silent worker.tick_failed loop.\n   294\t            return self._handle_reasoner_failure(plan_id, exc, uow, operation)\n   295\t        with uow:\n   296\t            plan = uow.plans.get(plan_id)\n   297\t            cyclic = plan.active_cycle is not None\n   298\t            if plan.paused or plan.pause_requested:\n   299\t                self._finish_operation(\n   300\t                    uow,\n   301\t                    operation,\n   302\t                    PlanningOperationStatus.FAILED,\n   303\t                    failure_kind=\"planning_interrupted\",\n   304\t                    safe_message=\"Planning stopped because the plan was paused.\",\n   305\t                )\n   306\t                return Signal.PAUSED\n   307\t            if not cyclic and plan.phase != PlanPhase.ENRICHING:\n   308\t                self._finish_operation(\n   309\t                    uow,\n   310\t                    operation,\n   311\t                    PlanningOperationStatus.FAILED,\n   312\t                    failure_kind=\"stale_planning_state\",\n   313\t                    safe_message=\"Planning state changed before the goal contract could commit.\",\n   314\t                )\n   315\t                return Signal.PAUSED\n   316\t            fresh = next((g for g in plan.execution_goals if g.id == target.id), None)\n   317\t            if fresh is None or