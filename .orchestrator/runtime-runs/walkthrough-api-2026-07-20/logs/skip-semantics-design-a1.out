del):\nbackend/src/domain/entities/planning_artifacts.py:21:class CycleStatus(str, Enum):\nbackend/src/domain/entities/planning_artifacts.py:122:class CycleDraft(BaseModel):\nbackend/src/domain/entities/planning_artifacts.py:127:    goals: list[GoalOutline]\nbackend/src/domain/entities/planning_artifacts.py:141:        for goal in self.goals:\nbackend/src/domain/entities/planning_artifacts.py:175:class Cycle(BaseModel):\nbackend/src/domain/entities/planning_artifacts.py:180:    goals: list[Goal] = Field(default_factory=list)\nbackend/src/domain/aggregates/planner_orchestrator.py:106:    goals: list[Goal] = []\nbackend/src/domain/aggregates/planner_orchestrator.py:487:        for goal in self.goals:\nbackend/src/domain/aggregates/planner_orchestrator.py:513:    def set_iteration_goals(self, new_goals: list[Goal]) -> None:\nbackend/src/domain/aggregates/planner_orchestrator.py:530:    def commit_replanned_goals(self, new_goals: list[Goal]) -> None:\nbackend/src/domain/aggregates/planner_orchestrator.py:538:        for goal in self.goals:\nbackend/src/domain/aggregates/planner_orchestrator.py:910:        for goal in self.execution_goals:\nbackend/src/domain/services/lookups.py:16:def find_goal(goals: list[Goal], goal_id: str) -> Goal:\nbackend/src/domain/services/lookups.py:17:    for goal in goals:\nbackend/src/domain/ports/reasoner_port.py:62:    goals: list[Goal] | None = None\nbackend/src/domain/services/navigation.py:28:def next_action(goals: list[Goal], now: datetime) -> NextAction:\nbackend/src/domain/services/edit_service.py:55:def add_task(goals: list[Goal], goal_id: str, task: Task, *, paused: bool = False) -> None:\nbackend/src/domain/services/edit_service.py:66:def remove_task(goals: list[Goal], goal_id: str, task_id: str, *, paused: bool = False) -> None:\nbackend/src/domain/services/edit_service.py:81:    goals: list[Goal], goal_id: str, ordered_ids: list[str], *, paused: bool = False\nbackend/src/domain/services/edit_service.py:94:    goals: list[Goal],\nbackend/src/domain/services/edit_service.py:111:    goals: list[Goal],\nbackend/src/domain/services/edit_service.py:130:def _assert_acyclic(goals: list[Goal], goal_id: str, new_deps: list[str]) -> None:\nbackend/src/domain/services/edit_service.py:147:    goals: list[Goal],\nbackend/src/domain/services/edit_service.py:180:def remove_goal(goals: list[Goal], goal_id: str, *, paused: bool = False) -> None:\nbackend/src/domain/services/edit_service.py:189:    for other in goals:\n277:def activate_cycle(\n300:        cycle = Cycle(\n307:        plan.activate_cycle(gate_id, revision, cycle, clock.now())\n    revision: int,\n    uow: UnitOfWork,\n    clock: Clock,\n) -> Cycle:\n    with uow:\n        plan = uow.plans.get(plan_id)\n        draft = plan.cycle_draft\n        if draft is None:\n            raise InvalidEditError(\"cycle draft is required\")\n        goal_ids = {outline.key: new_id() for outline in draft.goals}\n        goals = [\n            Goal(\n                id=goal_ids[outline.key],\n                name=outline.name,\n                position=outline.position,\n                description=outline.objective,\n                depends_on=[goal_ids[key] for key in outline.depends_on],\n            )\n            for outline in sorted(draft.goals, key=lambda item: item.position)\n        ]\n        cycle = Cycle(\n            id=new_id(),\n            intent_proposal_id=draft.intent_proposal_id,\n            draft_id=draft.id,\n            goals=goals,\n            started_at=clock.now(),\n        )\n        plan.activate_cycle(gate_id, revision, cycle, clock.now())\n        # Compatibility projection only; cyclic navigation/status are authoritative.\n        plan._set_phase(PlanPhase.ENRICHING)\n        plan.bump_version()\n        uow.outbox.add(\n            CycleActivated(\n                plan_id=plan.id,\n                cycle_id=cycle.id,\n                draft_id=draft.id,\n            )\n        )\n        uow.plans.save(plan)\n        return cycle\n\n\ndef record_output_disposition(\n    plan_id: str,\n    gate_id: str,\n    revision: int,\n    disposition: OutputDisposition,\n    output_reference: str | None,\n    uow: UnitOfWork,\n    clock: Clock,\n) -> None:\n    with uow:\n        plan = uow.plans.get(plan_id)\n        cycle = plan.active_cycle\n        plan.record_output_disposition(\n            gate_id,\n            revision,\n            disposition,\n            output_reference,\n            clock.now(),\n        )\n        plan.bump_version()\n        assert cycle is not None\n        uow.outbox.add(\n            OutputDispositionRecorded(\n                plan_id=plan.id,\n                cycle_id=cycle.id,\n                disposition=disposition.value,\n                output_reference=output_reference,\n            )\n        )\n        uow.plans.save(plan)\n     1\tfrom __future__ import annotations\n     2\t\n     3\tfrom datetime import datetime\n     4\tfrom typing import Literal, Union\n     5\t\n     6\tfrom src.domain.entities.goal import Goal\n     7\tfrom src.domain.entities.task import Task\n     8\tfrom src.domain.value_objects.lifecycle import Status, TERMINAL\n     9\t\n    10\tGoalFailed = Literal[\"GOAL_FAILED\"]\n    11\tDependencyBlocked = Literal[\"DEPENDENCY_BLOCKED\"]\n    12\tNOT_READY: Literal[\"NOT_READY\"] = \"NOT_READY\"\n    13\t\n    14\tNextAction = Union[\n    15\t    tuple[Goal, Task],\n    16\t    tuple[Goal, None],\n    17\t    tuple[Goal, GoalFailed],\n    18\t    tuple[Goal, DependencyBlocked],\n    19\t    Literal[\"NOT_READY\"],\n    20\t    None,\n    21\t]\n    22\t\n    23\t\n    24\tdef _goal_ready(goal: Goal, done_goal_ids: set[str]) -> bool:\n    25\t    return all(dep in done_goal_ids for dep in goal.depends_on)\n    26\t\n    27\t\n    28\tdef next_action(goals: list[Goal], now: datetime) -> NextAction:\n    29\t    \"\"\"Return work for only the earliest non-terminal goal.\n    30\t\n    31\t    Position is the scheduling barrier; `depends_on` remains a correctness\n    32\t    relationship. Backoff, an unresolved failure, or an unmet dependency on the\n    33\t    head goal blocks every later goal. Navigation is a pure scan and stores no\n    34\t    cursor.\n    35\t    \"\"\"\n    36\t    ordered = sorted(goals, key=lambda g: g.position)\n    37\t    head_goal = next((goal for goal in ordered if goal.status not in TERMINAL), None)\n    38\t    if head_goal is None:\n    39\t        return None\n    40\t\n    41\t    done_goal_ids = {goal.id for goal in goals if goal.status == Status.DONE}\n    42\t    if not _goal_ready(head_goal, done_goal_ids):\n    43\t        return head_goal, \"DEPENDENCY_BLOCKED\"\n    44\t\n    45\t    head_task = next(\n    46\t        (\n    47\t            task\n    48\t            for task in sorted(head_goal.tasks, key=lambda task: task.position)\n    49\t            if task.status not in TERMINAL\n    50\t        ),\n    51\t        None,\n    52\t    )\n    53\t    if head_task is not None:\n    54\t        return (head_goal, head_task) if head_task.is_ready_at(now) else NOT_READY\n    55\t\n    56\t    if any(task.status == Status.FAILED for task in head_goal.tasks):\n    57\t        return head_goal, \"GOAL_FAILED\"\n    58\t    return head_goal, None\n   125\t        unit: _Unit | None = None\n   126\t        with uow:\n   127\t            plan = uow.plans.get(plan_id)\n   128\t            if plan.paused or plan.pause_requested:\n   129\t                return Signal.PAUSED  # pause gate armed while we were dispatched\n   130\t            action = plan.peek_next(self._clock.now())\n   131\t\n   132\t            if action is None:\n   133\t                return self._enter_review(plan_id, plan, uow)\n   134\t            if action == NOT_READY:\n   135\t                return Signal.NOT_READY\n   136\t\n   137\t            goal, second = action\n   138\t            if second is None:  # goal's tasks all terminal, none failed -> close it\n   139\t                if plan.active_cycle is None:\n   140\t                    return self._complete_legacy_goal(plan_id, plan, goal, uow)\n   141\t                try:\n   142\t                    goal_promotion = self._reserve_goal_promotion(plan, goal, uow)\n   143\t                except TaskFailed as failure:\n   144\t                    # Navigation selected this goal to close, but a task is not\n   145\t                    # DONE-with-accepted-evidence (e.g. a legacy/replan artifact).\n   146\t                    # Open a recoverable block — never let this escape to the\n   147\t                    # worker loop, which re-runs the reservation and hot-loops the\n   148\t                    # same TaskFailed every tick.\n   149\t                    return self._block_on_unpromotable_goal(\n   150\t                        plan_id, plan, goal, failure, uow\n   151\t                    )\n   152\t            else:\n   153\t                if second == \"GOAL_FAILED\":\n   154\t                    return self._pause_on_failed_goal(plan_id, plan, goal, uow)\n   155\t                if second == \"DEPENDENCY_BLOCKED\":\n   156\t                    return Signal.NOT_READY\n   157\t\n   158\t                task = second\n   159\t                # check-before-act: result already exists -> finalize without re-running.\n   160\t                if task.result is not None:\n   700\t    ) -> Signal:\n   701\t        plan.complete_goal(goal.id)\n   702\t        plan.bump_version()\n   703\t        uow.outbox.add(GoalCompleted(plan_id=plan_id, goal_id=goal.id))\n   704\t        uow.plans.save(plan)\n   705\t        return Signal.CONTINUE\n   706\t\n   707\t    def _block_on_unpromotable_goal(\n   708\t        self, plan_id: str, plan: Plan, goal: Goal, failure: TaskFailed, uow: UnitOfWork\n   709\t    ) -> Signal:\n   710\t        \"\"\"A goal navigation selected to close but that cannot merge (a task is\n   711\t        not DONE or has no accepted evidence — typically a legacy/replan artifact)\n   712\t        opens a structured block, mirroring `_pause_on_failed_goal`. Without this\n   713\t        the reservation's TaskFailed escapes `handle()` to the worker loop, which\n   714\t        re-dispatches and re-raises it every tick (a 1Hz poisoned-plan storm).\"\"\"\n   715\t        offending = next(\n   716\t            task\n   717\t            for task in goal.tasks\n   718\t            if task.status != Status.DONE or not task.verification_evidence\n   719\t        )\n   720\t        # Only advertise resolutions that can actually repair this block. `retry`\n   721\t        # requires a FAILED task (Task.retry rejects skipped/cancelled/terminal ->\n   722\t        # pending), so a goal wedged by a SKIPPED/evidence-less-DONE task is\n   723\t        # recoverable only via edit_task or start_replan — offering retry_stage\n   724\t        # there is a nominal-only resolution that 422s when the operator tries it.\n   725\t        resolutions = [\"edit_task\", \"start_replan\"]\n   726\t        if offending.status == Status.FAILED:\n   727\t            resolutions = [\"retry_stage\", *resolutions]\n   728\t        block = PlanBlock(\n   729\t            id=new_id(),\n   730\t            kind=\"execution_failure\",\n   731\t            explanation=str(failure),\n   732\t            stage=offending.tdd_stage,\n   733\t            goal_id=goal.id,\n   734\t            task_id=offending.id,\n   735\t            task_revision=offending.revision,\n   736\t            legal_resolutions=resolutions,\n   737\t            created_at=self._clock.now(),\n   738\t        )\n   739\t        plan.open_block(block)\n   740\t        uow.outbox.add(\n   741\t            PlanBlocked(\n   742\t                plan_id=plan_id,\n   743\t                block_id=block.id,\n   744\t                stage=block.stage,\n   745\t                goal_id=goal.id,\n   746\t                task_id=offending.id,\n   747\t                task_revision=offending.revision,\n   748\t            )\n   749\t        )\n   750\t        plan.bump_version()\n   751\t        uow.plans.save(plan)\n   752\t        return Signal.PAUSED\n   753\t\n   754\t    def _reserve_goal_promotion(\n   755\t        self,\n   756\t        plan: Plan,\n   757\t        goal: Goal,\n   758\t        uow: UnitOfWork,\n   759\t    ) -> tuple[str, str, str]:\n   760\t        cycle = plan.active_cycle\n   761\t        assert cycle is not None\n   762\t        if any(task.status != Status.DONE or not task.verification_evidence for task in goal.tasks):\n   763\t            raise TaskFailed(\n   764\t                \"goal cannot merge without accepted task evidence\",\n   765\t                FailureKind.VERIFICATION_ERROR,\n   766\t            )\n   767\t        reservation = f\"goal:{cycle.id}:{goal.id}\"\n   768\t        plan.reserve_promotion(reservation)\n   769\t        plan.bump_version()\n   770\t        uow.plans.save(plan)\n   771\t        return reservation, cycle.id, goal.id\n   772\t\n   773\t    async def _promote_goal(\n   774\t        self,\n   775\t        plan_id: str,\n   776\t        promotion: tuple[str, str, str],\n   777\t        uow: UnitOfWork,\n   778\t    ) -> Signal:\n   779\t        reservation, cycle_id, goal_id = promotion\n   780\t        try:\n   781\t            commit_sha = await self._workspace.merge_goal(plan_id, cycle_id, goal_id)\n   782\t        except Exception as exc:\n   783\t            with uow:\n   784\t                plan = uow.plans.get(plan_id)\n   785\t                if plan.promotion_reservation != reservation:\n   810\t        with uow:\n   811\t            plan = uow.plans.get(plan_id)\n   812\t            if plan.promotion_reservation != reservation:\n   813\t                return Signal.PAUSED\n   814\t            cycle = next(\n   815\t                (item for item in plan.cycles if item.id == cycle_id),\n   816\t                None,\n   817\t            )\n   818\t            if cycle is None or plan.active_cycle is None or plan.active_cycle.id != cycle_id:\n   819\t                raise TaskFailed(\n   820\t                    \"goal promotion targets a superseded cycle\",\n   821\t                    FailureKind.VERIFICATION_ERROR,\n   822\t                )\n   823\t            goal = find_goal(cycle.goals, goal_id)\n   824\t            if any(\n   825\t                task.status != Status.DONE or not task.verification_evidence for task in goal.tasks\n   826\t            ):\n   827\t                raise TaskFailed(\n   828\t                    \"goal evidence changed during promotion\",\n   829\t                    FailureKind.VERIFICATION_ERROR,\n   830\t                )\n   831\t            cycle.evidence_refs.append(f\"git:{commit_sha}\")\n   832\t            plan.complete_goal(goal_id)\n   833\t            plan.release_promotion(reservation)\n   834\t            plan.bump_version()\n   835\t            uow.outbox.add(GoalCompleted(plan_id=plan_id, goal_id=goal_id))\n   836\t            uow.plans.save(plan)\n   837\t        return Signal.CONTINUE\n   838\t\n   839\t    def _pause_on_failed_goal(\n   840\t        self, plan_id: str, plan: Plan, goal: Goal, uow: UnitOfWork\n   841\t    ) -> Signal:\n   842\t        \"\"\"Goal-failure backstop: a cyclic goal whose head task is FAILED opens a\n   843\t        structured block with executable retry, edit, and replan actions. Normally\n   844\t        finalization opens the block in the same transaction; this scan branch is\n   845\t        defensive recovery for persisted legacy/incomplete state.\"\"\"\n   465\t        \"\"\"Human \"finish\" at the post-execution gate: REVIEW -> DONE.\"\"\"\n   466\t        self._guard_phase({PlanPhase.REVIEW}, PlanPhase.DONE)\n   467\t        self._set_phase(PlanPhase.DONE)\n   468\t\n   469\t    def begin_replanning(self) -> None:\n   470\t        \"\"\"Enter the conversational re-plan. Two entry points, one phase: from\n   471\t        REVIEW (\"replan next phase\") or mid-RUNNING (user chat). Abandons the\n   472\t        current iteration's remaining work: every PENDING goal (and any PENDING\n   473\t        task inside a still-RUNNING goal) is SKIPPED now; an in-flight RUNNING\n   474\t        task finalizes via tolerant finalize; whatever remains is closed by the\n   475\t        finalize-abandon in commit_replanned_goals(). A human replan supersedes\n   476\t        any pause: the gate clears so the committed roadmap can execute.\"\"\"\n   477\t        self.assert_lifecycle_mutation_allowed()\n   478\t        # Cyclic authority: a plan with an active cycle can always be replanned\n   479\t        # (start_replan is an advertised block/running resolution), regardless of\n   480\t        # the legacy PlanPhase projection — which for a replanned cycle is already\n   481\t        # REPLANNING and would otherwise reject \"replanning -> replanning\". Legacy\n   482\t        # (pre-cyclic) plans keep the RUNNING/REVIEW phase guard.\n   483\t        if self.active_cycle is None:\n   484\t            self._guard_phase({PlanPhase.RUNNING, PlanPhase.REVIEW}, PlanPhase.REPLANNING)\n   485\t        self.paused = False\n   486\t        self.paused_reason = None\n   487\t        for goal in self.goals:\n   488\t            if goal.status == Status.PENDING:\n   489\t                for task in goal.tasks:\n   490\t                    if task.status == Status.PENDING:\n   491\t                        task.skip()\n   492\t                goal.skip()\n   493\t            elif goal.status == Status.RUNNING:\n   494\t                for task in goal.tasks:\n   495\t                    if task.status == Status.PENDING:\n   496\t                        task.skip()\n   497\t                # leave the goal RUNNING: its in-flight task finalizes tolerantly\n   498\t        self._set_phase(PlanPhase.REPLANNING)\n   499\t        self.pause_requested = False\n   500\t        if self.active_cycle is not None:\n   501\t            # Cyclic conversational replan (unfreeze #10): establish the coherent\n   502\t            # WAITING replan tuple. `_set_phase(REPLANNING)` already set\n   503\t            # status=WAITING; here we retire the stale current-planning artifacts\n   504\t            # so an approved source intent / draft / gate cannot masquerade as\n   505\t            # active planning work. The source Cycle is retained (its\n   506\t            # intent_proposal_id preserves history); the next reasoner turn opens\n   507\t            # a fresh REPLAN IntentProposal + review gate. Legacy (active_cycle is\n   508\t            # None) plans are unchanged.\n   509\t            self.intent_proposal = None\n   510\t            self.cycle_draft = None\n   511\t            self.review_gate = None\n   512\t\n   513\t    def set_iteration_goals(self, new_goals: list[Goal]) -> None:\n   514\t        \"\"\"The planning phases' write path (roadmap 2.5 driver): replace the\n   515\t        current iteration's non-terminal goals with the reasoner's new set —\n   516\t        DISCOVERY drafts them, ARCHITECTURE structures them, ENRICHING details\n   517\t        them. Terminal goals (prior-iteration history) are never touched; the\n   518\t        new set is renumbered to positions after them.\"\"\"\n   519\t        self.assert_lifecycle_mutation_allowed()\n   520\t        self._guard_phase(\n   521\t            {PlanPhase.DISCOVERY, PlanPhase.ARCHITECTURE, PlanPhase.ENRICHING},\n   522\t            self.phase,\n   523\t        )\n   524\t        kept = [g for g in self.goals if g.is_terminal]\n   525\t        base = max((g.position for g in kept), default=-1) + 1\n   526\t        for offset, goal in enumerate(new_goals):\n   527\t            goal.position = base + offset\n   528\t        self.goals = kept + list(new_goals)\n   529\t\n   530\t    def commit_replanned_goals(self, new_goals: list[Goal]) -> None:\n   531\t        \"\"\"The conversational re-plan produced a new goal set: finalize-abandon\n   532\t        whatever the prior iteration left non-terminal (closes the resurrection\n   533\t        hole — a stale goal must never be re-executed after the next iteration\n   534\t        starts), append the new goals (append-only history), bump the iteration,\n   535\t        and flow into ARCHITECTURE like DISCOVERY does.\"\"\"\n   536\t        self.assert_lifecycle_mutation_allowed()\n   537\t        self._guard_phase({PlanPhase.REPLANNING}, PlanPhase.ARCHITECTURE)\n   538\t        for goal in self.goals:\n   539\t            if goal.is_terminal:\n   540\t                continue\n   541\t            for task in goal.tasks:\n   542\t                if not task.is_terminal:\n   543\t                    task.abandon()\n   544\t            goal.skip()\n   545\t        base = max((g.position for g in self.goals), default=-1) + 1\n   546\t        for offset, goal in enumerate(new_goals):\n   547\t            goal.position = base + offset\n   548\t            self.goals.append(goal)\n   549\t        self.iteration += 1\n   550\t        self._set_phase(PlanPhase.ARCHITECTURE)\n   551\t\n   552\t    def bind_legacy_project(self, project_id: str, resolved_at: datetime) -> None:\n   553\t        \"\"\"Operator-only binding for quarantined legacy rows.\"\"\"\n   554\t        if self.project_id is not None:\n   555\t            if self.project_id == project_id:\n   815\t        revision: int,\n   816\t        cycle: Cycle,\n   817\t        resolved_at: datetime,\n   818\t    ) -> None:\n   819\t        self.assert_lifecycle_mutation_allowed()\n   820\t        draft = self.cycle_draft\n   821\t        if draft is None or draft.revision != revision:\n   822\t            raise InvalidEditError(\"cycle draft revision is stale\")\n   823\t        if self.version != draft.base_plan_version + 1:\n   824\t            raise InvalidEditError(\"cycle draft base version is stale\")\n   825\t        if cycle.draft_id != draft.id or cycle.intent_proposal_id != draft.intent_proposal_id:\n   826\t            raise InvalidEditError(\"cycle does not match the approved draft\")\n   827\t        source = self.active_cycle\n   828\t        if draft.source_cycle_id is not None:\n   829\t            if source is None or source.id != draft.source_cycle_id:\n   830\t                raise InvalidEditError(\"active source cycle changed; regenerate the draft\")\n   831\t            source.status = CycleStatus.SUPERSEDED\n   832\t            source.superseded_at = resolved_at\n   833\t        elif source is not None:\n   834\t            raise InvalidEditError(\"only one active cycle is allowed\")\n   835\t        self._resolve_review_gate(gate_id, revision, \"approve\", resolved_at)\n   836\t        draft.approved_at = resolved_at\n   837\t        self.cycles.append(cycle)\n   838\t        self.intent_proposal = None\n   839\t        self.cycle_draft = None\n   840\t        self.review_gate = None\n   841\t        self.block = None\n   842\t        self.paused = False\n   843\t        self.pause_requested = False\n   844\t        self.status = PlanStatus.RUNNING\n   845\t\n   846\t    def cancel_cycle_draft(self, cancelled_at: datetime) -> None:\n   847\t        self.assert_lifecycle_mutation_allowed()\n   848\t        if self.cycle_draft is None:\n   849\t            raise InvalidEditError(\"cycle draft not found\")\n   850\t        self.cycle_draft.cancelled_at = cancelled_at\n","exit_code":0,"status":"completed"}}
{"type":"item.started","item":{"id":"item_8","type":"command_execution","command":"/bin/bash -lc \"nl -ba backend/src/app/use_cases/request_replan.py | sed -n '1,90p'\nnl -ba backend/tests/unit/orchestration/test_execution_handler_unpromotable_goal.py | sed -n '1,180p'\nnl -ba backend/tests/unit/orchestration/test_replan_loop.py | sed -n '60,190p;210,325p'\nnl -ba backend/tests/unit/orchestration/test_transitions.py | sed -n '35,175p'\nnl -ba backend/src/domain/entities/task.py | sed -n '55,120p'\nnl -ba backend/src/domain/entities/goal.py | sed -n '25,70p'\nnl -ba backend/src/domain/value_objects/lifecycle.py | sed -n '10,32p'\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
{"type":"item.completed","item":{"id":"item_8","type":"command_execution","command":"/bin/bash -lc \"nl -ba backend/src/app/use_cases/request_replan.py | sed -n '1,90p'\nnl -ba backend/tests/unit/orchestration/test_execution_handler_unpromotable_goal.py | sed -n '1,180p'\nnl -ba backend/tests/unit/orchestration/test_replan_loop.py | sed -n '60,190p;210,325p'\nnl -ba backend/tests/unit/orchestration/test_transitions.py | sed -n '35,175p'\nnl -ba backend/src/domain/entities/task.py | sed -n '55,120p'\nnl -ba backend/src/domain/entities/goal.py | sed -n '25,70p'\nnl -ba backend/src/domain/value_objects/lifecycle.py | sed -n '10,32p'\"","aggregated_output":"     1\t\"\"\"request_replan — enter the conversational re-plan (state machinery only).\n     2\t\n     3\tTwo entry points, one phase: from REVIEW (\"replan next phase\") and from\n     4\tmid-RUNNING user chat (\"give me a new plan\"). Either way the aggregate skips the\n     5\tcurrent iteration's PENDING work now (an in-flight task finalizes via the\n     6\ttolerant finalize in ExecutionHandler) and the plan lands in REPLANNING — a\n     7\tconversational phase that is NOT worker-claimable; each user message advances it\n     8\tvia the conversation use cases (roadmap Phase 2.5 wires the reasoning content).\n     9\t\n    10\tThis is distinct from apply_edit: apply_edit is the surgical manual edit;\n    11\trequest_replan is the holistic conversational re-plan.\n    12\t\"\"\"\n    13\t\n    14\tfrom __future__ import annotations\n    15\t\n    16\tfrom src.domain.events.outbox import BlockResolved, ReplanRequested\n    17\tfrom src.domain.value_objects.lifecycle import Status\n    18\t\n    19\tfrom src.app.ports import UnitOfWork\n    20\t\n    21\t\n    22\tdef request_replan(plan_id: str, uow: UnitOfWork) -> None:\n    23\t    with uow:\n    24\t        plan = uow.plans.get(plan_id)\n    25\t        from_phase = plan.phase.value\n    26\t\n    27\t        # Resolve any active block FIRST (unfreeze #10): resolve_block's generic\n    28\t        # fallback sets status=PAUSED, so begin_replanning() must run AFTER it to\n    29\t        # make the coherent WAITING replan tuple the transaction's final lifecycle\n    30\t        # word. The whole thing commits atomically, so no PAUSED state is ever\n    31\t        # externally visible.\n    32\t        block = plan.block\n    33\t        if block is not None and block.active:\n    34\t            block_id = block.id\n    35\t            plan.resolve_block(\"start_replan\", block.created_at)\n    36\t            uow.outbox.add(\n    37\t                BlockResolved(\n    38\t                    plan_id=plan_id,\n    39\t                    block_id=block_id,\n    40\t                    resolution=\"start_replan\",\n    41\t                )\n    42\t            )\n    43\t\n    44\t        plan.begin_replanning()\n    45\t\n    46\t        cycle = plan.active_cycle\n    47\t        if cycle is not None:\n    48\t            for goal in cycle.goals:\n    49\t                for task in goal.tasks:\n    50\t                    if task.status == Status.FAILED:\n    51\t                        # Requeue is the existing guarded transition that makes\n    52\t                        # a failed task eligible for the tolerant abandon path.\n    53\t                        plan.requeue_task(goal.id, task.id)\n    54\t                    if task.status in {Status.PENDING, Status.RUNNING}:\n    55\t                        plan.abandon_execution_task(cycle.id, goal.id, task.id)\n    56\t\n    57\t        plan.bump_version()\n    58\t        uow.outbox.add(ReplanRequested(plan_id=plan_id, from_phase=from_phase))\n    59\t        uow.plans.save(plan)\n     1\t\"\"\"Regression lock for the unpromotable-goal hot loop.\n     2\t\n     3\tNavigation's pull-scan returns `(goal, None)` once every task in the earliest\n     4\tnon-terminal goal is terminal and none is FAILED — the \"close this goal\"\n     5\tsignal. `_reserve_goal_promotion` additionally requires every task be DONE\n     6\t*with* accepted verification evidence before it will reserve the Git merge. A\n     7\tDONE task with no evidence (a legacy/replan artifact) used to let that\n     8\t`TaskFailed` escape `ExecutionHandler.handle()`; the worker loop would then\n     9\tre-dispatch the same plan/goal forever, re-raising the same exception every\n    10\ttick. The fix catches it in `handle()` and opens a recoverable\n    11\t`execution_failure` block instead (`_block_on_unpromotable_goal`).\"\"\"\n    12\t\n    13\tfrom __future__ import annotations\n    14\t\n    15\timport asyncio\n    16\tfrom datetime import datetime, timezone\n    17\t\n    18\tfrom src.app.handlers.execution_handler import ExecutionHandler\n    19\tfrom src.app.testing.fakes import (\n    20\t    CollectingEventSink,\n    21\t    DummyAgentRunner,\n    22\t    FakeClock,\n    23\t    InMemoryAgentRepository,\n    24\t    InMemoryOutbox,\n    25\t    InMemoryPlanRepository,\n    26\t    InMemoryUnitOfWork,\n    27\t    NoOpWorkspace,\n    28\t)\n    29\tfrom src.app.handlers.base import Signal\n    30\tfrom src.domain.aggregates.planner_orchestrator import Plan, PlanPhase\n    31\tfrom src.domain.entities.goal import Goal\n    32\tfrom src.domain.entities.planning_artifacts import Cycle, PlanStatus\n    33\tfrom src.domain.entities.task import Task\n    34\tfrom src.domain.value_objects.lifecycle import Status\n    35\tfrom src.domain.value_objects.tasks_vos import TaskResult\n    36\t\n    37\tNOW = datetime(2026, 7, 14, tzinfo=timezone.utc)\n    38\t\n    39\t\n    40\tdef test_unpromotable_done_goal_blocks_instead_of_raising() -> None:\n    41\t    # A DONE task with no verification_evidence: navigation sees an all-terminal,\n    42\t    # no-failure goal and returns (goal, None) — \"close it\" — but the task never\n    43\t    # earned accepted evidence, so promotion cannot legally proceed.\n    44\t    task = Task(\n    45\t        id=\"task-1\",\n    46\t        name=\"implement feature\",\n    47\t        position=0,\n    48\t        description=\"implement feature\",\n    49\t        status=Status.DONE,\n    50\t        result=TaskResult.success(\"looked done, never independently verified\"),\n    51\t    )\n    52\t    goal = Goal(id=\"goal-1\", name=\"goal\", position=0, description=\"goal\", tasks=[task])\n    53\t    cycle = Cycle(\n    54\t        id=\"cycle-1\",\n    55\t        intent_proposal_id=\"intent-1\",\n    56\t        draft_id=\"draft-1\",\n    57\t        goals=[goal],\n    58\t        started_at=NOW,\n    59\t    )\n    60\t    plan = Plan(\n    61\t        id=\"plan-1\",\n    62\t        project_id=\"project-1\",\n    63\t        brief=\"brief\",\n    64\t        phase=PlanPhase.RUNNING,\n    65\t        status=PlanStatus.RUNNING,\n    66\t        cycles=[cycle],\n    67\t    )\n    68\t\n    69\t    clock = FakeClock(NOW)\n    70\t    plans = InMemoryPlanRepository(clock)\n    71\t    plans.add(plan)\n    72\t    uow = InMemoryUnitOfWork(plans, InMemoryOutbox())\n    73\t    handler = ExecutionHandler(\n    74\t        DummyAgentRunner(),\n    75\t        InMemoryAgentRepository([]),\n    76\t        NoOpWorkspace(),\n    77\t        CollectingEventSink(),\n    78\t        clock,\n    79\t    )\n    80\t\n    81\t    signal = asyncio.run(handler.handle(plan.id, plan, uow))\n    82\t\n    83\t    assert signal == Signal.PAUSED\n    84\t    blocked = plans.get(plan.id)\n    85\t    assert blocked.status == PlanStatus.BLOCKED\n    86\t    assert blocked.block is not None\n    87\t    assert blocked.block.kind == \"execution_failure\"\n    88\t    assert blocked.block.goal_id == \"goal-1\"\n    89\t    assert blocked.block.task_id == \"task-1\"\n    90\t    assert \"edit_task\" in blocked.block.legal_resolutions\n    91\t    assert \"start_replan\" in blocked.block.legal_resolutions\n    92\t    # The goal never merges/completes on this path.\n    93\t    still_open_goal = blocked.active_cycle.goals[0]  # type: ignore[union-attr]\n    94\t    assert still_open_goal.status != Status.DONE\n    60\t    clock = FakeClock()\n    61\t    repo = InMemoryPlanRepository(clock)\n    62\t    repo.add(plan)\n    63\t    outbox = InMemoryOutbox()\n    64\t    uow = InMemoryUnitOfWork(repo, outbox)\n    65\t    runner = DummyAgentRunner(script or {})\n    66\t    agents = InMemoryAgentRepository([agent()], default_id=\"a1\")\n    67\t    return repo, outbox, uow, runner, agents, NoOpWorkspace(), CollectingEventSink(), clock\n    68\t\n    69\t\n    70\t# ===== entering REPLANNING =====\n    71\tdef test_request_replan_mid_running_skips_pending_work():\n    72\t    \"\"\"Skip place ONE: at request time every PENDING goal (and PENDING tasks of a\n    73\t    RUNNING goal) is skipped; the in-flight RUNNING task is left to finalize.\"\"\"\n    74\t    running_goal = goal(\n    75\t        \"g1\",\n    76\t        0,\n    77\t        [task(\"g1t0\", 0, Status.DONE), task(\"g1t1\", 1, Status.RUNNING), task(\"g1t2\", 2)],\n    78\t        status=Status.RUNNING,\n    79\t    )\n    80\t    pending_goal = goal(\"g2\", 1, [task(\"g2t0\", 0)])\n    81\t    plan = Plan(\n    82\t        project_id=\"project-1\",\n    83\t        id=\"p1\",\n    84\t        brief=\"b\",\n    85\t        phase=PlanPhase.RUNNING,\n    86\t        goals=[running_goal, pending_goal],\n    87\t    )\n    88\t    repo, outbox, uow, *_ = harness(plan)\n    89\t\n    90\t    request_replan(\"p1\", uow)\n    91\t    saved = repo.get(\"p1\")\n    92\t    assert saved.phase == PlanPhase.REPLANNING\n    93\t    assert saved.goals[1].status == Status.SKIPPED  # pending goal skipped\n    94\t    assert saved.goals[1].tasks[0].status == Status.SKIPPED\n    95\t    assert saved.goals[0].status == Status.RUNNING  # active goal left for finalize\n    96\t    assert saved.goals[0].tasks[1].status == Status.RUNNING  # in-flight untouched\n    97\t    assert saved.goals[0].tasks[2].status == Status.SKIPPED  # its pending work skipped\n    98\t    assert \"ReplanRequested\" in outbox.types()\n    99\t\n   100\t\n   101\tdef test_review_replan_enters_replanning_from_review():\n   102\t    plan = Plan(\n   103\t        project_id=\"project-1\",\n   104\t        id=\"p1\",\n   105\t        brief=\"b\",\n   106\t        phase=PlanPhase.REVIEW,\n   107\t        goals=[goal(\"g1\", 0, [task(\"t0\", 0, Status.DONE)], Status.DONE)],\n   108\t    )\n   109\t    repo, outbox, uow, *_ = harness(plan)\n   110\t    review_replan(\"p1\", uow)\n   111\t    assert repo.get(\"p1\").phase == PlanPhase.REPLANNING\n   112\t    assert repo.get(\"p1\").goals[0].status == Status.DONE  # history untouched\n   113\t\n   114\t\n   115\t@pytest.mark.parametrize(\n   116\t    \"phase\",\n   117\t    [\n   118\t        PlanPhase.DISCOVERY,\n   119\t        PlanPhase.ARCHITECTURE,\n   120\t        PlanPhase.ENRICHING,\n   121\t        PlanPhase.AWAITING_REVIEW,\n   122\t        PlanPhase.REPLANNING,\n   123\t    ],\n   124\t)\n   125\tdef test_replan_only_from_running_or_review(phase):\n   126\t    plan = Plan(project_id=\"project-1\", id=\"p1\", brief=\"b\", phase=phase)\n   127\t    repo, outbox, uow, *_ = harness(plan)\n   128\t    with pytest.raises(InvalidTransitionError):\n   129\t        request_replan(\"p1\", uow)\n   130\t\n   131\t\n   132\t# ===== committing the new goal set =====\n   133\tdef test_commit_replanned_goals_appends_bumps_iteration_and_flows_to_architecture():\n   134\t    done_goal = goal(\"g1\", 0, [task(\"g1t0\", 0, Status.DONE)], Status.DONE)\n   135\t    plan = Plan(\n   136\t        project_id=\"project-1\", id=\"p1\", brief=\"b\", phase=PlanPhase.REVIEW, goals=[done_goal]\n   137\t    )\n   138\t    repo, outbox, uow, *_ = harness(plan)\n   139\t    review_replan(\"p1\", uow)\n   140\t\n   141\t    new_goals = [\n   142\t        Goal(id=\"n1\", name=\"n1\", position=0, description=\"\"),\n   143\t        Goal(id=\"n2\", name=\"n2\", position=1, description=\"\"),\n   144\t    ]\n   145\t    with uow:\n   146\t        p = uow.plans.get(\"p1\")\n   147\t        p.commit_replanned_goals(new_goals)\n   148\t        p.bump_version()\n   149\t        uow.plans.save(p)\n   150\t\n   151\t    saved = repo.get(\"p1\")\n   152\t    assert saved.phase == PlanPhase.ARCHITECTURE\n   153\t    assert saved.iteration == 2\n   154\t    assert [g.id for g in saved.goals] == [\"g1\", \"n1\", \"n2\"]  # append-only\n   155\t    assert [g.position for g in saved.goals] == [0, 1, 2]  # positions continue\n   156\t    assert saved.goals[0].status == Status.DONE  # prior DONE goals are history\n   157\t\n   158\t\n   159\tdef test_finalize_abandon_closes_leftover_nonterminal_goals():\n   160\t    \"\"\"Skip place TWO (the resurrection fix): commit closes whatever the prior\n   161\t    iteration left non-terminal, so the scan can never re-select stale work\n   162\t    after the next iteration starts.\"\"\"\n   163\t    leftover = goal(\"g1\", 0, [task(\"t0\", 0, Status.RUNNING), task(\"t1\", 1)], status=Status.RUNNING)\n   164\t    plan = Plan(\n   165\t        project_id=\"project-1\", id=\"p1\", brief=\"b\", phase=PlanPhase.RUNNING, goals=[leftover]\n   166\t    )\n   167\t    repo, outbox, uow, *_ = harness(plan)\n   168\t    request_replan(\"p1\", uow)  # t1 skipped here; t0 still RUNNING (in flight)\n   169\t\n   170\t    with uow:\n   171\t        p = uow.plans.get(\"p1\")\n   172\t        p.commit_replanned_goals(\n   173\t            [Goal(id=\"n1\", name=\"n1\", position=0, description=\"\", tasks=[task(\"n1t0\", 0)])]\n   174\t        )\n   175\t        p.bump_version()\n   176\t        uow.plans.save(p)\n   177\t\n   178\t    saved = repo.get(\"p1\")\n   179\t    assert saved.goals[0].status == Status.SKIPPED  # finalize-abandon closed it\n   180\t    assert saved.goals[0].tasks[0].status == Status.SKIPPED  # in-flight abandoned\n   181\t    # THE regression: the scan must select ONLY the new iteration's work\n   182\t    action = next_action(saved.goals, FakeClock().now())\n   183\t    picked_goal, picked_task = action\n   184\t    assert picked_goal.id == \"n1\" and picked_task.id == \"n1t0\"\n   185\t\n   186\t\n   187\tdef test_commit_only_from_replanning():\n   188\t    plan = Plan(project_id=\"project-1\", id=\"p1\", brief=\"b\", phase=PlanPhase.RUNNING)\n   189\t    with pytest.raises(InvalidTransitionError):\n   190\t        plan.commit_replanned_goals([])\n   210\t    return Plan(\n   211\t        project_id=\"project-1\",\n   212\t        id=\"p1\",\n   213\t        brief=\"b\",\n   214\t        phase=PlanPhase.RUNNING,\n   215\t        goals=[goal(\"g1\", 0, [task(\"t0\", 0)])],\n   216\t    )\n   217\t\n   218\t\n   219\tdef test_late_failure_terminal_skips_never_requeues():\n   220\t    repo, outbox, uow, _, agents, ws, sink, clock = harness(_one_task_running_plan())\n   221\t    runner = _ReplanDuringRun(\n   222\t        {\"t0\": DummyBehavior(always_fail=True, fail_reason=\"late boom\")}, uow, \"t0\"\n   223\t    )\n   224\t    sig = asyncio.run(advance_plan(\"p1\", uow, runner, agents, ws, sink, clock))\n   225\t    assert sig == \"paused\"  # plan is in REPLANNING now\n   226\t    saved = repo.get(\"p1\")\n   227\t    assert saved.goals[0].tasks[0].status == Status.SKIPPED  # terminal-skip\n   228\t    assert \"TaskRequeued\" not in outbox.types()  # NEVER requeued into abandoned iter\n   229\t    assert \"TaskAbandoned\" in outbox.types()\n   230\t\n   231\t\n   232\tdef test_late_success_is_rejected_and_abandoned():\n   233\t    repo, outbox, uow, _, agents, ws, sink, clock = harness(_one_task_running_plan())\n   234\t    runner = _ReplanDuringRun({\"t0\": DummyBehavior(output=\"late ok\")}, uow, \"t0\")\n   235\t    asyncio.run(advance_plan(\"p1\", uow, runner, agents, ws, sink, clock))\n   236\t    saved = repo.get(\"p1\")\n   237\t    assert saved.phase == PlanPhase.REPLANNING\n   238\t    assert saved.goals[0].tasks[0].status == Status.SKIPPED\n   239\t    assert saved.goals[0].tasks[0].result is None\n   240\t    assert \"TaskCompleted\" not in outbox.types()\n   241\t    assert \"TaskAbandoned\" in outbox.types()\n   242\t\n   243\t\n   244\tdef test_late_success_after_finalize_abandon_is_dropped():\n   245\t    \"\"\"The late-late edge: the conversational replan COMMITTED (finalize-abandon\n   246\t    closed the task) before the agent returned. The stale success is dropped.\"\"\"\n   247\t    repo, outbox, uow, _, agents, ws, sink, clock = harness(_one_task_running_plan())\n   248\t\n   249\t    class _ReplanAndCommit(_ReplanDuringRun):\n   250\t        async def run(self, task, spec, **kw):\n   251\t            request_replan(\"p1\", self._uow)\n   252\t            with self._uow:\n   253\t                p = self._uow.plans.get(\"p1\")\n   254\t                p.commit_replanned_goals([Goal(id=\"n1\", name=\"n1\", position=0, description=\"\")])\n   255\t                p.bump_version()\n   256\t                self._uow.plans.save(p)\n   257\t            return await DummyAgentRunner.run(self, task, spec, **kw)\n   258\t\n   259\t    runner = _ReplanAndCommit({\"t0\": DummyBehavior(output=\"too late\")}, uow, \"t0\")\n   260\t    sig = asyncio.run(advance_plan(\"p1\", uow, runner, agents, ws, sink, clock))\n   261\t    assert sig == \"paused\"\n   262\t    saved = repo.get(\"p1\")\n   263\t    assert saved.goals[0].tasks[0].status == Status.SKIPPED  # stays closed\n   264\t    assert saved.goals[0].tasks[0].result is None  # stale result NOT recorded\n   265\t    assert \"TaskCompleted\" not in outbox.types()\n   266\t\n   267\t\n   268\t# ===== reopen (human redo) through the aggregate =====\n   269\tdef test_reopen_task_reopens_goal_and_scan_reselects():\n   270\t    done = goal(\"g1\", 0, [task(\"t0\", 0, Status.DONE)], Status.DONE)\n   271\t    done.tasks[0].result = TaskResult.success(\"v1\")\n   272\t    plan = Plan(project_id=\"project-1\", id=\"p1\", brief=\"b\", phase=PlanPhase.REVIEW, goals=[done])\n   273\t\n   274\t    plan.reopen_task(\"g1\", \"t0\")\n   275\t    assert plan.goals[0].status == Status.RUNNING\n   276\t    t = plan.goals[0].tasks[0]\n   277\t    assert t.status == Status.PENDING and t.result is None and t.reopen_count == 1\n   278\t    picked_goal, picked_task = next_action(plan.goals, FakeClock().now())\n   279\t    assert picked_task.id == \"t0\"  # scan re-selects the reopened work\n   280\t\n   281\t\n   282\t# ===== set_iteration_goals (the planning phases' write path) =====\n   283\tdef test_set_iteration_goals_replaces_pending_keeps_history():\n   284\t    history = goal(\"old\", 0, [task(\"oldt\", 0, Status.DONE)], Status.DONE)\n   285\t    draft = goal(\"draft\", 1, [task(\"draftt\", 0)])\n   286\t    plan = Plan(\n   287\t        project_id=\"project-1\",\n   288\t        id=\"p1\",\n   289\t        brief=\"b\",\n   290\t        phase=PlanPhase.ARCHITECTURE,\n   291\t        goals=[history, draft],\n   292\t    )\n   293\t    plan.set_iteration_goals(\n   294\t        [\n   295\t            Goal(id=\"n1\", name=\"n1\", position=0, description=\"\"),\n   296\t            Goal(id=\"n2\", name=\"n2\", position=1, description=\"\"),\n   297\t        ]\n   298\t    )\n   299\t    assert [g.id for g in plan.goals] == [\"old\", \"n1\", \"n2\"]  # draft replaced\n   300\t    assert [g.position for g in plan.goals] == [0, 1, 2]  # renumbered after history\n   301\t    assert plan.goals[0].status == Status.DONE  # history untouched\n   302\t\n   303\t\n   304\t@pytest.mark.parametrize(\n   305\t    \"phase\",\n   306\t    [\n   307\t        PlanPhase.AWAITING_REVIEW,\n   308\t        PlanPhase.RUNNING,\n   309\t        PlanPhase.REVIEW,\n   310\t        PlanPhase.REPLANNING,\n   311\t        PlanPhase.DONE,\n   312\t    ],\n   313\t)\n   314\tdef test_set_iteration_goals_only_in_planning_phases(phase):\n   315\t    plan = Plan(project_id=\"project-1\", id=\"p1\", brief=\"b\", phase=phase)\n   316\t    with pytest.raises((InvalidTransitionError, Exception)):\n   317\t        plan.set_iteration_goals([])\n    35\t    t.start()\n    36\t    t.fail(\"boom\")\n    37\t    assert t.status == Status.FAILED and t.result.failure_reason == \"boom\"\n    38\t\n    39\t\n    40\tdef test_task_running_reentry_idempotent_start():\n    41\t    t = mk_task()\n    42\t    t.start()\n    43\t    t.start()  # re-pick after crash\n    44\t    assert t.status == Status.RUNNING and t.attempt == 2\n    45\t\n    46\t\n    47\tdef test_task_failed_to_requeue_preserves_attempts():\n    48\t    t = mk_task()\n    49\t    t.start()\n    50\t    t.fail(\"x\")\n    51\t    t.requeue()\n    52\t    assert t.status == Status.PENDING and t.result is None and t.attempt == 1\n    53\t\n    54\t\n    55\tdef test_task_pending_to_skipped():\n    56\t    t = mk_task()\n    57\t    t.skip()\n    58\t    assert t.status == Status.SKIPPED\n    59\t\n    60\t\n    61\t# ---- Task: every ILLEGAL transition raises ----\n    62\t@pytest.mark.parametrize(\n    63\t    \"status,action\",\n    64\t    [\n    65\t        (Status.DONE, \"start\"),\n    66\t        (Status.DONE, \"complete\"),\n    67\t        (Status.PENDING, \"complete\"),  # complete requires RUNNING\n    68\t        (Status.DONE, \"requeue\"),\n    69\t        (Status.PENDING, \"requeue\"),\n    70\t        (Status.DONE, \"skip\"),\n    71\t        (Status.RUNNING, \"skip\"),\n    72\t        (Status.SKIPPED, \"start\"),\n    73\t    ],\n    74\t)\n    75\tdef test_task_illegal_transitions_raise(status, action):\n    76\t    t = mk_task(status)\n    77\t    with pytest.raises(InvalidTransitionError):\n    78\t        if action == \"complete\":\n    79\t            t.complete(TaskResult.success(\"x\"))\n    80\t        else:\n    81\t            getattr(t, action)()\n    82\t\n    83\t\n    84\t# ---- Goal transitions ----\n    85\tdef test_goal_lifecycle():\n    86\t    g = Goal(id=\"g\", name=\"g\", position=0, description=\"\")\n    87\t    g.start()\n    88\t    assert g.status == Status.RUNNING\n    89\t    g.complete()\n    90\t    assert g.status == Status.DONE\n    91\t\n    92\t\n    93\tdef test_goal_illegal_transition_raises():\n    94\t    g = Goal(id=\"g\", name=\"g\", position=0, description=\"\")\n    95\t    g.start()\n    96\t    g.complete()\n    97\t    with pytest.raises(InvalidTransitionError):\n    98\t        g.start()  # can't restart a DONE goal\n    99\t\n   100\t\n   101\t# ---- Task.reopen (human redo of a good result) ----\n   102\tdef test_task_reopen_done_to_pending_clears_result_counts_separately():\n   103\t    t = mk_task()\n   104\t    t.start()\n   105\t    t.complete(TaskResult.success(\"ok\"))\n   106\t    t.reopen()\n   107\t    assert t.status == Status.PENDING\n   108\t    assert t.result is None  # scan will re-select it\n   109\t    assert t.reopen_count == 1\n   110\t    assert t.attempt == 1  # redo does NOT eat into the failure/retry budget\n   111\t\n   112\t\n   113\t@pytest.mark.parametrize(\"status\", [Status.PENDING, Status.RUNNING, Status.FAILED, Status.SKIPPED])\n   114\tdef test_task_reopen_only_from_done(status):\n   115\t    t = mk_task(status)\n   116\t    with pytest.raises(InvalidTransitionError):\n   117\t        t.reopen()\n   118\t\n   119\t\n   120\t# ---- Task.abandon (tolerant finalize: iteration abandoned by a replan) ----\n   121\tdef test_task_abandon_running_to_skipped():\n   122\t    t = mk_task()\n   123\t    t.start()\n   124\t    t.abandon()\n   125\t    assert t.status == Status.SKIPPED\n   126\t\n   127\t\n   128\t@pytest.mark.parametrize(\"status\", [Status.DONE, Status.SKIPPED, Status.FAILED])\n   129\tdef test_task_abandon_never_from_terminal(status):\n   130\t    t = mk_task(status)\n   131\t    with pytest.raises(InvalidTransitionError):\n   132\t        t.abandon()\n   133\t\n   134\t\n   135\t# ---- Goal.skip guards ----\n   136\tdef mk_goal(tasks=None, status=Status.PENDING):\n   137\t    g = Goal(id=\"g\", name=\"g\", position=0, description=\"\", tasks=tasks or [])\n   138\t    g.status = status\n   139\t    return g\n   140\t\n   141\t\n   142\tdef test_goal_skip_from_pending():\n   143\t    g = mk_goal()\n   144\t    g.skip()\n   145\t    assert g.status == Status.SKIPPED\n   146\t\n   147\t\n   148\tdef test_goal_skip_from_running_requires_all_tasks_terminal():\n   149\t    live = mk_task()\n   150\t    live.start()  # RUNNING task inside\n   151\t    g = mk_goal(tasks=[live], status=Status.RUNNING)\n   152\t    with pytest.raises(InvalidTransitionError):\n   153\t        g.skip()  # cannot skip a goal out from under a live task\n   154\t    live.abandon()\n   155\t    g.skip()  # all tasks terminal -> the finalize-abandon path may close it\n   156\t    assert g.status == Status.SKIPPED\n   157\t\n   158\t\n   159\t@pytest.mark.parametrize(\"status\", [Status.DONE, Status.SKIPPED, Status.FAILED])\n   160\tdef test_goal_skip_never_from_terminal(status):\n   161\t    g = mk_goal(status=status)\n   162\t    with pytest.raises(InvalidTransitionError):\n   163\t        g.skip()\n   164\t\n   165\t\n   166\t# ---- Goal.reopen ----\n   167\tdef test_goal_reopen_done_to_running():\n   168\t    g = mk_goal(status=Status.DONE)\n   169\t    g.reopen()\n   170\t    assert g.status == Status.RUNNING\n   171\t\n   172\t\n   173\tdef test_goal_reopen_only_from_done():\n   174\t    g = mk_goal(status=Status.PENDING)\n   175\t    with pytest.raises(InvalidTransitionError):\n    55\t        self.result = result\n    56\t        self.status = Status.DONE\n    57\t\n    58\t    def fail(self, reason: str, kind: FailureKind | None = None) -> None:\n    59\t        self._guard({Status.RUNNING, Status.PENDING}, Status.FAILED)\n    60\t        self.status = Status.FAILED\n    61\t        if self.result is None:\n    62\t            self.result = TaskResult.failure(reason, kind)\n    63\t        else:\n    64\t            self.result.failure_reason = reason\n    65\t            self.result.failure_kind = kind\n    66\t\n    67\t    def requeue(self, not_before: datetime | None = None) -> None:\n    68\t        self._guard({Status.RUNNING, Status.FAILED}, Status.PENDING)\n    69\t        self.status = Status.PENDING\n    70\t        self.result = None\n    71\t        self.retry_not_before = not_before\n    72\t\n    73\t    def skip(self) -> None:\n    74\t        self._guard({Status.PENDING}, Status.SKIPPED)\n    75\t        self.status = Status.SKIPPED\n    76\t\n    77\t    def abandon(self) -> None:\n    78\t        self._guard({Status.RUNNING, Status.PENDING}, Status.SKIPPED)\n    79\t        self.status = Status.SKIPPED\n    80\t\n    81\t    def retry(self) -> None:\n    82\t        \"\"\"Start a new human retry cycle without reusing absolute identity.\"\"\"\n    83\t        self._guard({Status.FAILED}, Status.PENDING)\n    84\t        self.status = Status.PENDING\n    85\t        self.result = None\n    86\t        self.retry_cycle += 1\n    87\t        self.cycle_attempt = 0\n    88\t        self.retry_not_before = None\n    89\t\n    90\t    def semantic_edit(self, *, name: str | None = None, description: str | None = None) -> None:\n    91\t        \"\"\"Revise executable meaning and invalidate revision-bound artifacts.\"\"\"\n    92\t        self._guard({Status.PENDING, Status.FAILED}, Status.PENDING)\n    93\t        if name is not None:\n    94\t            self.name = name\n    95\t        if description is not None:\n    96\t            self.description = description\n    97\t        self.status = Status.PENDING\n    98\t        self.result = None\n    99\t        self.revision += 1\n   100\t        if self.contract is not None:\n   101\t            self.contract = self.contract.model_copy(\n   102\t                update={\n   103\t                    \"revision\": self.revision,\n   104\t                    \"objective\": self.description or self.name,\n   105\t                }\n   106\t            )\n   107\t        if self.test_bundle is not None:\n   108\t            self.test_bundle.invalidate(\"semantic task edit\")\n   109\t        self.verification_evidence = []\n   110\t        self.cycle_attempt = 0\n   111\t        self.retry_not_before = None\n   112\t\n   113\t    def clear_backoff(self) -> None:\n   114\t        self.retry_not_before = None\n   115\t\n   116\t    def reopen(self) -> None:\n   117\t        self._guard({Status.DONE}, Status.PENDING)\n   118\t        self.status = Status.PENDING\n   119\t        self.result = None\n   120\t        self.reopen_count += 1\n    25\t        if self.status not in allowed_from:\n    26\t            raise InvalidTransitionError(\"Goal\", self.id, self.status.value, to.value)\n    27\t\n    28\t    def start(self) -> None:\n    29\t        self._guard({Status.PENDING, Status.RUNNING}, Status.RUNNING)\n    30\t        self.status = Status.RUNNING\n    31\t\n    32\t    def complete(self) -> None:\n    33\t        self._guard({Status.RUNNING, Status.PENDING}, Status.DONE)\n    34\t        self.status = Status.DONE\n    35\t\n    36\t    def fail(self) -> None:\n    37\t        self._guard({Status.RUNNING, Status.PENDING}, Status.FAILED)\n    38\t        self.status = Status.FAILED\n    39\t\n    40\t    def skip(self) -> None:\n    41\t        \"\"\"Close the goal as SKIPPED (its iteration was abandoned by a replan).\n    42\t        Allowed from PENDING always; from RUNNING only once every task is terminal\n    43\t        — the finalize-abandon path closes the tasks first, then the goal. A\n    44\t        RUNNING goal with live tasks can never be skipped out from under them.\"\"\"\n    45\t        if self.status == Status.RUNNING and not all(t.is_terminal for t in self.tasks):\n    46\t            raise InvalidTransitionError(\"Goal\", self.id, self.status.value, Status.SKIPPED.value)\n    47\t        self._guard({Status.PENDING, Status.RUNNING}, Status.SKIPPED)\n    48\t        self.status = Status.SKIPPED\n    49\t\n    50\t    def reopen(self) -> None:\n    51\t        \"\"\"Re-enter a finished goal because one of its tasks was reopened (human\n    52\t        redo). DONE -> RUNNING so the scan re-selects the goal.\"\"\"\n    53\t        self._guard({Status.DONE}, Status.RUNNING)\n    54\t        self.status = Status.RUNNING\n    55\t\n    56\t    @property\n    57\t    def is_terminal(self) -> bool:\n    58\t        return self.status in TERMINAL\n    10\t\n    11\tfrom enum import Enum\n    12\t\n    13\t\n    14\tclass Status(str, Enum):\n    15\t    \"\"\"Lifecycle state shared by goals and tasks. str-based so comparisons and JSON\n    16\t    serialization are natural (task.status == Status.DONE works).\"\"\"\n    17\t\n    18\t    PENDING = \"pending\"\n    19\t    RUNNING = \"running\"\n    20\t    DONE = \"done\"\n    21\t    SKIPPED = \"skipped\"\n    22\t    FAILED = \"failed\"\n    23\t\n    24\t\n    25\t# States the navigation scan treats as finished. A FAILED node being terminal is\n    26\t# what prevents the infinite-loop: it is skipped, never re-selected forever.\n    27\tTERMINAL: frozenset[Status] = frozenset({Status.DONE, Status.SKIPPED, Status.FAILED})\n    28\t\n    29\t\n    30\tclass FailureKind(str, Enum):\n    31\t    \"\"\"Typed classification of a task failure. Produced by the agent runner,\n    32\t    consumed by RetryPolicy.should_retry — a checked classification, not string\n","exit_code":0,"status":"completed"}}
{"type":"item.started","item":{"id":"item_9","type":"command_execution","command":"/bin/bash -lc \"rg -n \\\"#41|issue #41|41\\\\.\\\" docs ROADMAP.md backend --glob '*.md' --glob '*.py'\nrg -n \\\"Status\\\\.SKIPPED|status.*skipped|skipped\\\" backend/src --glob '*.py'\nnl -ba backend/src/domain/aggregates/planner_orchestrator.py | sed -n '95,165p;165,205p;555,680p'\nnl -ba backend/src/domain/entities/planning_artifacts.py | sed -n '15,35p;170,200p'\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
{"type":"item.completed","item":{"id":"item_9","type":"command_execution","command":"/bin/bash -lc \"rg -n \\\"#41|issue #41|41\\\\.\\\" docs ROADMAP.md backend --glob '*.md' --glob '*.py'\nrg -n \\\"Status\\\\.SKIPPED|status.*skipped|skipped\\\" backend/src --glob '*.py'\nnl -ba backend/src/domain/aggregates/planner_orchestrator.py | sed -n '95,165p;165,205p;555,680p'\nnl -ba backend/src/domain/entities/planning_artifacts.py | sed -n '15,35p;170,200p'\"","aggregated_output":"docs/decisions/decision-log.md:70:41. **🔓 Domain un-freeze #2 (2026-07-08)**: `Plan.planning_retry_not_before` + `planning_attempts` fields and the `record_planning_retry` / `clear_planning_retry` / `fail_plan` transitions. A transient reasoner failure in a worker-driven planning phase (ARCHITECTURE/ENRICHING) now arms a **durable plan-level backoff gate** — the planning-phase analog of a Task's `retry_not_before` + attempt (decision 15) — honored by the claim predicate, so a rate-limited provider makes the worker back off instead of hot-looping it. The budget reuses `retry_policy` (`backoff_for`/`max_attempts`); exhausting it, or a permanent failure, transitions the plan to FAILED via `fail_plan`. Motivated by a live OpenRouter rate-limit (`ResourceExhausted 502`) that produced a ~1s `worker.tick_failed` storm with no operator-visible signal.\ndocs/history/planning/2026-07-02-master-roadmap-final-fable-5.md:508:- [ ] **Docs + decision/refactor history consolidated (#41)** — also campaign material.\nbackend/src/app/handlers/execution_handler.py:721:        # requires a FAILED task (Task.retry rejects skipped/cancelled/terminal ->\nbackend/src/domain/events/outbox.py:53:    Pending work of the current iteration was skipped.\"\"\"\nbackend/src/domain/entities/goal.py:44:        RUNNING goal with live tasks can never be skipped out from under them.\"\"\"\nbackend/src/domain/entities/goal.py:46:            raise InvalidTransitionError(\"Goal\", self.id, self.status.value, Status.SKIPPED.value)\nbackend/src/domain/entities/goal.py:47:        self._guard({Status.PENDING, Status.RUNNING}, Status.SKIPPED)\nbackend/src/domain/entities/goal.py:48:        self.status = Status.SKIPPED\nbackend/src/domain/value_objects/lifecycle.py:21:    SKIPPED = \"skipped\"\nbackend/src/domain/value_objects/lifecycle.py:26:# what prevents the infinite-loop: it is skipped, never re-selected forever.\nbackend/src/domain/value_objects/lifecycle.py:27:TERMINAL: frozenset[Status] = frozenset({Status.DONE, Status.SKIPPED, Status.FAILED})\nbackend/src/domain/entities/task.py:74:        self._guard({Status.PENDING}, Status.SKIPPED)\nbackend/src/domain/entities/task.py:75:        self.status = Status.SKIPPED\nbackend/src/domain/entities/task.py:78:        self._guard({Status.RUNNING, Status.PENDING}, Status.SKIPPED)\nbackend/src/domain/entities/task.py:79:        self.status = Status.SKIPPED\n    95\t    pause_requested: bool = False\n    96\t    # Durable check-to-merge reservation. While set, pause requests may land,\n    97\t    # but lifecycle/artifact mutations that could supersede the candidate may not.\n    98\t    promotion_reservation: str | None = None\n    99\t    legacy_phase: str | None = None\n   100\t    legacy_mapped_status: PlanStatus | None = None\n   101\t    version: int = 0\n   102\t    brief: str\n   103\t    phase: PlanPhase = PlanPhase.DISCOVERY\n   104\t    iteration: int = 1\n   105\t    retry_policy: RetryPolicy = RetryPolicy()\n   106\t    goals: list[Goal] = []\n   107\t\n   108\t    # Durable backoff gate for the worker-driven planning phases (the planning-phase\n   109\t    # analog of a Task's retry_not_before + attempt). Armed on a TRANSIENT reasoner\n   110\t    # failure and honored by the claim predicate, so a rate-limited provider makes\n   111\t    # the worker back off instead of hot-looping it. planning_attempts is the\n   112\t    # transient-failure counter; it resets when planning next progresses.\n   113\t    planning_retry_not_before: datetime | None = None\n   114\t    planning_attempts: int = 0\n   115\t\n   116\t    # Human pause gate (un-freeze #3): an availability flag on the claim predicate\n   117\t    # (the same durable-gate pattern as planning_retry_not_before), NOT a phase —\n   118\t    # the legacy phase projection remains unchanged. Armed by a human pause command;\n   119\t    # cleared by resume(), which is intentionally separate from targeted retry.\n   120\t    paused: bool = False\n   121\t    paused_reason: str | None = None\n   122\t\n   123\t    @model_validator(mode=\"before\")\n   124\t    @classmethod\n   125\t    def map_legacy_phase_status(cls, data: object) -> object:\n   126\t        if not isinstance(data, dict) or \"status\" in data:\n   127\t            return data\n   128\t        raw_phase = data.get(\"phase\", PlanPhase.DISCOVERY.value)\n   129\t        phase = raw_phase.value if isinstance(raw_phase, PlanPhase) else str(raw_phase)\n   130\t        mapped = {\n   131\t            PlanPhase.DISCOVERY.value: PlanStatus.WAITING,\n   132\t            PlanPhase.REPLANNING.value: PlanStatus.WAITING,\n   133\t            PlanPhase.ARCHITECTURE.value: PlanStatus.RUNNING,\n   134\t            PlanPhase.ENRICHING.value: PlanStatus.RUNNING,\n   135\t            PlanPhase.AWAITING_REVIEW.value: PlanStatus.WAITING,\n   136\t            PlanPhase.RUNNING.value: PlanStatus.RUNNING,\n   137\t            PlanPhase.REVIEW.value: PlanStatus.WAITING,\n   138\t            PlanPhase.DONE.value: PlanStatus.IDLE,\n   139\t            PlanPhase.FAILED.value: PlanStatus.BLOCKED,\n   140\t        }\n   141\t        return {**data, \"status\": mapped.get(phase, PlanStatus.BLOCKED)}\n   142\t\n   143\t    # ---- helpers ----\n   144\t    def _set_phase(self, phase: PlanPhase) -> None:\n   145\t        \"\"\"Compatibility checkpoint while active behavior migrates to artifacts.\"\"\"\n   146\t        self.phase = phase\n   147\t        self.status = {\n   148\t            PlanPhase.DISCOVERY: PlanStatus.WAITING,\n   149\t            PlanPhase.REPLANNING: PlanStatus.WAITING,\n   150\t            PlanPhase.ARCHITECTURE: PlanStatus.RUNNING,\n   151\t            PlanPhase.ENRICHING: PlanStatus.RUNNING,\n   152\t            PlanPhase.AWAITING_REVIEW: PlanStatus.WAITING,\n   153\t            PlanPhase.RUNNING: PlanStatus.RUNNING,\n   154\t            PlanPhase.REVIEW: PlanStatus.WAITING,\n   155\t            PlanPhase.DONE: PlanStatus.IDLE,\n   156\t            PlanPhase.FAILED: PlanStatus.BLOCKED,\n   157\t        }[phase]\n   158\t\n   159\t    def bump_version(self) -> None:\n   160\t        self.version += 1\n   161\t\n   162\t    def _assert_not_terminal(self) -> None:\n   163\t        if self.phase in TERMINAL_PHASES:\n   164\t            raise PlanAlreadyTerminalError(self.id, self.phase.value)\n   165\t\n   165\t\n   166\t    def assert_lifecycle_mutation_allowed(self) -> None:\n   167\t        if self.promotion_reservation is not None:\n   168\t            raise InvalidEditError(\"a verified Git promotion is in progress\")\n   169\t\n   170\t    def reserve_promotion(self, reservation: str) -> None:\n   171\t        if self.promotion_reservation not in (None, reservation):\n   172\t            raise InvalidEditError(\"another verified Git promotion is in progress\")\n   173\t        self.promotion_reservation = reservation\n   174\t\n   175\t    def release_promotion(self, reservation: str) -> None:\n   176\t        if self.promotion_reservation == reservation:\n   177\t            self.promotion_reservation = None\n   178\t\n   179\t    def abandon_execution_task(\n   180\t        self,\n   181\t        cycle_id: str | None,\n   182\t        goal_id: str,\n   183\t        task_id: str,\n   184\t    ) -> None:\n   185\t        goals = self.goals\n   186\t        if cycle_id is not None:\n   187\t            cycle = next((item for item in self.cycles if item.id == cycle_id), None)\n   188\t            if cycle is None:\n   189\t                raise InvalidEditError(f\"cycle '{cycle_id}' not found\")\n   190\t            goals = cycle.goals\n   191\t        find_task(find_goal(goals, goal_id), task_id).abandon()\n   192\t\n   193\t    def _guard_phase(self, allowed_from: set[PlanPhase], to: PlanPhase) -> None:\n   194\t        if self.phase not in allowed_from:\n   195\t            raise InvalidTransitionError(\"Plan\", self.id, self.phase.value, to.value)\n   196\t\n   197\t    @property\n   198\t    def execution_goals(self) -> list[Goal]:\n   199\t        cycle = self.active_cycle\n   200\t        return cycle.goals if cycle is not None else self.goals\n   201\t\n   202\t    def _goal(self, goal_id: str) -> Goal:\n   203\t        return find_goal(self.execution_goals, goal_id)\n   204\t\n   205\t    def _task(self, goal: Goal, task_id: str) -> Task:\n   555\t            if self.project_id == project_id:\n   556\t                return\n   557\t            raise InvalidEditError(\"project identity is immutable\")\n   558\t        if self.block is None or self.block.kind != \"project_binding\" or not self.block.active:\n   559\t            raise InvalidEditError(\"plan is not waiting for a project binding\")\n   560\t        self.project_id = project_id\n   561\t        self.block.resolution = \"bind_project\"\n   562\t        self.block.resolved_at = resolved_at\n   563\t        self.status = self.legacy_mapped_status or PlanStatus.IDLE\n   564\t\n   565\t    # ---- cyclic project-plan lifecycle (unfreeze #4) ----\n   566\t    @property\n   567\t    def active_cycle(self) -> Cycle | None:\n   568\t        return next(\n   569\t            (cycle for cycle in self.cycles if cycle.status == CycleStatus.ACTIVE),\n   570\t            None,\n   571\t        )\n   572\t\n   573\t    @property\n   574\t    def status_reason(self) -> dict[str, str | None]:\n   575\t        if self.promotion_reservation is not None:\n   576\t            return {\n   577\t                \"kind\": \"promotion\",\n   578\t                \"code\": \"git_promotion\",\n   579\t                \"message\": \"Promoting verified code at an atomic boundary.\",\n   580\t            }\n   581\t        if self.block is not None and self.block.active:\n   582\t            return {\n   583\t                \"kind\": \"block\",\n   584\t                \"code\": self.block.kind,\n   585\t                \"message\": self.block.explanation,\n   586\t            }\n   587\t        if self.review_gate is not None and self.review_gate.unresolved:\n   588\t            return {\n   589\t                \"kind\": \"review_gate\",\n   590\t                \"code\": self.review_gate.subject_type.value,\n   591\t                \"message\": self.review_gate.continuation,\n   592\t            }\n   593\t        if self.pause_requested:\n   594\t            return {\n   595\t                \"kind\": \"pause_requested\",\n   596\t                \"code\": \"active_action\",\n   597\t                \"message\": self.paused_reason or \"waiting for the current action\",\n   598\t            }\n   599\t        if self.paused:\n   600\t            return {\n   601\t                \"kind\": \"manual_pause\",\n   602\t                \"code\": \"paused\",\n   603\t                \"message\": self.paused_reason,\n   604\t            }\n   605\t        return {\"kind\": self.status.value, \"code\": None, \"message\": None}\n   606\t\n   607\t    @property\n   608\t    def legal_actions(self) -> list[str]:\n   609\t        if self.promotion_reservation is not None:\n   610\t            return [\"pause\"] if self.status == PlanStatus.RUNNING else []\n   611\t        if self.block is not None and self.block.active:\n   612\t            return list(self.block.legal_resolutions)\n   613\t        if self.review_gate is not None and self.review_gate.unresolved:\n   614\t            return [f\"review:{decision}\" for decision in self.review_gate.allowed_decisions]\n   615\t        if self.pause_requested:\n   616\t            return []\n   617\t        if self.status == PlanStatus.RUNNING:\n   618\t            return [\"pause\", \"start_replan\"]\n   619\t        if self.status == PlanStatus.PAUSED and self.paused:\n   620\t            # Only a truly-armed manual pause is resumable. status==PAUSED with\n   621\t            # paused==False is an inconsistent state (unfreeze #10), not a\n   622\t            # resumable one — never advertise resume for it.\n   623\t            return [\n   624\t                \"resume\",\n   625\t                \"start_replan\",\n   626\t                \"edit_pending_work\",\n   627\t            ]\n   628\t        if self.status == PlanStatus.IDLE or (\n   629\t            self.status == PlanStatus.WAITING\n   630\t            and self.review_gate is None\n   631\t            and self.intent_proposal is None\n   632\t            and self.active_cycle is None\n   633\t        ):\n   634\t            # start_intent is INITIAL planning only. A WAITING plan with an active\n   635\t            # cycle is in conversational replan (driven by the replan-message\n   636\t            # endpoint), so it advertises no button command here.\n   637\t            return [\"start_intent\"]\n   638\t        return []\n   639\t\n   640\t    @property\n   641\t    def activity(self) -> str:\n   642\t        \"\"\"Derived activity; never persisted as a second lifecycle enum.\"\"\"\n   643\t        if self.block is not None and self.block.active:\n   644\t            return f\"blocked:{self.block.stage}\"\n   645\t        if self.review_gate is not None and self.review_gate.unresolved:\n   646\t            return f\"review:{self.review_gate.subject_type.value}\"\n   647\t        if self.intent_proposal is not None and self.intent_proposal.approved_at is None:\n   648\t            return \"intent_discovery\"\n   649\t        if (\n   650\t            self.intent_proposal is not None\n   651\t            and self.intent_proposal.approved_at is not None\n   652\t            and self.cycle_draft is None\n   653\t        ):\n   654\t            return \"cycle_architecture\"\n   655\t        if self.cycle_draft is not None and self.cycle_draft.approved_at is None:\n   656\t            return \"cycle_architecture\"\n   657\t        if (\n   658\t            self.status == PlanStatus.WAITING\n   659\t            and self.phase == PlanPhase.REPLANNING\n   660\t            and self.active_cycle is not None\n   661\t            and self.intent_proposal is None\n   662\t        ):\n   663\t            # Cyclic conversational replan before a candidate exists (unfreeze #10):\n   664\t            # the source cycle is retained but planning artifacts are cleared.\n   665\t            return \"replan_discovery\"\n   666\t        cycle = self.active_cycle\n   667\t        if cycle is None:\n   668\t            return \"intent_discovery\" if self.status == PlanStatus.WAITING else \"idle\"\n   669\t        action = next_action(cycle.goals, datetime.max.replace(tzinfo=timezone.utc))\n   670\t        if isinstance(action, tuple):\n   671\t            goal, subject = action\n   672\t            if isinstance(subject, Task):\n   673\t                return f\"task:{goal.id}:{subject.id}\"\n   674\t            return f\"goal:{goal.id}\"\n   675\t        return \"cycle_verification\"\n   676\t\n   677\t    def _open_review_gate(self, gate: ReviewGate) -> None:\n   678\t        if self.review_gate is not None and self.review_gate.unresolved:\n   679\t            raise InvalidEditError(\"a blocking review gate is already open\")\n   680\t        self.review_gate = gate\n    15\t    PAUSED = \"paused\"\n    16\t    WAITING = \"waiting\"\n    17\t    BLOCKED = \"blocked\"\n    18\t    IDLE = \"idle\"\n    19\t\n    20\t\n    21\tclass CycleStatus(str, Enum):\n    22\t    ACTIVE = \"active\"\n    23\t    COMPLETED = \"completed\"\n    24\t    SUPERSEDED = \"superseded\"\n    25\t    CANCELLED = \"cancelled\"\n    26\t\n    27\t\n    28\tclass ProposalKind(str, Enum):\n    29\t    INITIAL = \"initial\"\n    30\t    REPLAN = \"replan\"\n    31\t\n    32\t\n    33\tclass OutputDisposition(str, Enum):\n    34\t    OPEN_PR = \"open_pr\"\n    35\t    MERGE = \"merge\"\n   170\t        for key in keys:\n   171\t            visit(key)\n   172\t        return self\n   173\t\n   174\t\n   175\tclass Cycle(BaseModel):\n   176\t    id: str\n   177\t    intent_proposal_id: str\n   178\t    draft_id: str\n   179\t    status: CycleStatus = CycleStatus.ACTIVE\n   180\t    goals: list[Goal] = Field(default_factory=list)\n   181\t    started_at: datetime\n   182\t    completed_at: datetime | None = None\n   183\t    superseded_at: datetime | None = None\n   184\t    cancelled_at: datetime | None = None\n   185\t    evidence_refs: list[str] = Field(default_factory=list)\n   186\t    output_disposition: OutputDisposition | None = None\n   187\t    output_reference: str | None = None\n   188\t\n   189\t    @property\n   190\t    def immutable(self) -> bool:\n   191\t        return self.status == CycleStatus.COMPLETED\n","exit_code":0,"status":"completed"}}
{"type":"item.started","item":{"id":"item_10","type":"command_execution","command":"/bin/bash -lc \"rg -n \\\"Legacy.*PlanPhase|PlanPhase.*side|dual-authority|#41\\\" docs/architecture docs/history/analyses ROADMAP.md\nnl -ba docs/architecture/known-issues.md | sed -n '1,260p'\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
{"type":"item.completed","item":{"id":"item_10","type":"command_execution","command":"/bin/bash -lc \"rg -n \\\"Legacy.*PlanPhase|PlanPhase.*side|dual-authority|#41\\\" docs/architecture docs/history/analyses ROADMAP.md\nnl -ba docs/architecture/known-issues.md | sed -n '1,260p'\"","aggregated_output":"docs/history/analyses/2026-07-20-api-walkthrough-findings.md:363:14-item legacy-`PlanPhase` side-effect audit is tracked as follow-up cleanup.\ndocs/history/analyses/2026-07-21-replan-recovery-domain-design-codex-sol.md:65:## Legacy `PlanPhase` side-effect audit\ndocs/history/analyses/2026-07-21-replan-recovery-domain-design-codex-sol.md:69:1. `_set_phase()` mutates both the compatibility projection and authoritative root status ([planner_orchestrator.py:144](backend/src/domain/aggregates/planner_orchestrator.py:144)). This is the central dual-authority hazard. Any cyclic compatibility update can silently overwrite a carefully selected status. It happens in `begin_replanning`, `retry_agent_binding`, planning enrichment, and activation.\n     1\t# Known issues and compatibility debt\n     2\t\n     3\tVerified against the refactored code on 2026-07-14; re-verified 2026-07-20\n     4\tagainst merged PRs through #29. Fixed entries are removed; regressions live in\n     5\ttests rather than remaining as warnings here.\n     6\t\n     7\t## Lifecycle compatibility\n     8\t\n     9\t- `PlanPhase`, the legacy conversation/control routes, and root `goals`\n    10\t  remain for readable migrated plans and existing clients. Cyclic plans route\n    11\t  by `PlanStatus` plus open artifacts and active-cycle state, but deleting\n    12\t  the compatibility surface requires a separately versioned API removal.\n    13\t- Some secondary frontend panels still display legacy phase history. The main\n    14\t  status/control surface is status/gate/block/TDD-driven and explicitly\n    15\t  distinguishes RUNNING, pause requested, PAUSED, WAITING, BLOCKED, and IDLE.\n    16\t\n    17\t## Verification and publication\n    18\t\n    19\t- The repository has `ProjectDefinition` but no richer persisted\n    20\t  `ProjectSpec` containing canonical full-suite/build/type/lint/migration\n    21\t  commands. Task verification executes frozen TaskContract commands and goal\n    22\t  promotion requires accepted task evidence; cycle-wide verification can only\n    23\t  aggregate those evidence references until ProjectSpec gains those commands.\n    24\t- `open_pr` and `merge` publication dispositions record the reference of an\n    25\t  operation completed by an external/operator adapter. This repository has no\n    26\t  authenticated GitHub/forge publication port, and this refactor deliberately\n    27\t  did not invent provider-specific push/PR behavior or perform an unauthorized\n    28\t  external write.\n    29\t- Execution attempts have global UUIDs and monotonic absolute numbers, but the\n    30\t  execution ledger does not yet promote `run_kind` as a dedicated SQL column.\n    31\t  Role identity is present in the orchestration path and separate invocations,\n    32\t  prompts/specs, worktrees, run ids, and evidence.\n    33\t\n    34\t## Operational visibility\n    35\t\n    36\t- Lease heartbeat now runs during long actions, but the plan detail read model\n    37\t  exposes the active run start rather than the promoted lease deadline and last\n    38\t  heartbeat. Operational telemetry records liveness; a richer query DTO remains.\n    39\t- A malformed plan that raises before any save can still be reclaimed first by\n    40\t  oldest `updated_at` on a single worker. A dead-letter/operator quarantine\n    41\t  policy is still needed for repeated unexpected application exceptions.\n    42\t- SSE is bounded and non-durable for clients; reconnect relies on refetch.\n    43\t  Relay and event-table retention remain operational work.\n    44\t\n    45\t## Git/process cleanup\n    46\t\n    47\t- Owned process groups are terminated and reaped on success, failure, timeout,\n    48\t  discard, and stale results. A host crash can still leave Git worktree metadata;\n    49\t  periodic `git worktree prune` is not yet automated.\n    50\t- Authoritative test checkpoint branch refs are retained after implementation\n    51\t  forks from their immutable commit. They preserve auditability but need a\n    52\t  retention policy for long-running repositories.\n    53\t\n    54\t## Invariants to preserve\n    55\t\n    56\t1. No live aggregate reference crosses an agent/reasoner side effect.\n    57\t2. Plan save, execution identity, and domain events share one UoW.\n    58\t3. Test-author commits never reach the goal branch until independent GREEN\n    59\t   verification accepts the implementation candidate.\n    60\t4. Goal branches never reach the cycle branch until every task is DONE with\n    61\t   accepted revision-bound evidence.\n    62\t5. Resume changes availability only; targeted retry/block resolution are\n    63\t   separate commands.\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_11","type":"agent_message","text":"## Analysis\n\n`SKIPPED` was designed as an iteration-abandonment marker for the legacy execution loop, not as successful finite work. It belongs to the old model where replanning appends a replacement roadmap to the same root `goals` collection and the navigation scan must permanently pass over abandoned entries.\n\nThe lifecycle enum makes `SKIPPED` terminal alongside `DONE` and `FAILED` ([lifecycle.py:14](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/src/domain/value_objects/lifecycle.py:14), [lifecycle.py:25](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/src/domain/value_objects/lifecycle.py:25)). `Task.skip()` accepts only `PENDING`; `Task.abandon()` additionally accepts `RUNNING`; neither can be retried because `Task.retry()` accepts only `FAILED` ([task.py:73](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/src/domain/entities/task.py:73), [task.py:77](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/src/domain/entities/task.py:77), [task.py:81](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/src/domain/entities/task.py:81)). `Goal.skip()` similarly records an abandoned iteration and permits a running goal to close only after every child task is terminal ([goal.py:40](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/src/domain/entities/goal.py:40)).\n\nThe only production callers of `Task.skip()` and `Goal.skip()` are the legacy-root replan operations in `Plan.begin_replanning()` and `Plan.commit_replanned_goals()`:\n\n- `begin_replanning()` skips pending root goals and pending tasks within running root goals ([planner_orchestrator.py:469](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/src/domain/aggregates/planner_orchestrator.py:469), [planner_orchestrator.py:487](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/src/domain/aggregates/planner_orchestrator.py:487)).\n- `commit_replanned_goals()` abandons every remaining live task, skips its goal, appends replacement goals, and increments the legacy iteration ([planner_orchestrator.py:530](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/src/domain/aggregates/planner_orchestrator.py:530)).\n- `set_iteration_goals()` preserves every terminal root goal, including skipped history, while replacing the unfinished roadmap ([planner_orchestrator.py:513](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/src/domain/aggregates/planner_orchestrator.py:513)).\n\nThat solves a real legacy-loop problem: without terminal abandonment markers, the append-only root-goal scan could resurrect work from the superseded iteration. The regression tests explicitly encode that rationale ([test_replan_loop.py:71](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/tests/unit/orchestration/test_replan_loop.py:71), [test_replan_loop.py:159](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/tests/unit/orchestration/test_replan_loop.py:159), [test_replan_loop.py:219](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/tests/unit/orchestration/test_replan_loop.py:219)).\n\nThe cyclic model has a different abandonment boundary. Executable goals come from `active_cycle.goals`, not root `goals` ([planner_orchestrator.py:197](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/src/domain/aggregates/planner_orchestrator.py:197)). Replacement activation atomically changes the old cycle to `SUPERSEDED` and installs the new active cycle ([planner_orchestrator.py:815](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/src/domain/aggregates/planner_orchestrator.py:815)). Therefore no per-task terminal marker is required to keep the old cycle out of navigation: cycle status already supplies that boundary.\n\nNevertheless, `request_replan()` currently mutates every pending, running, or failed task in the still-active source cycle into `SKIPPED` ([request_replan.py:44](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/src/app/use_cases/request_replan.py:44)). This creates three semantic problems:\n\n1. The source cycle is not yet superseded; it remains the active cycle throughout conversational replanning.\n2. A cancelled or otherwise abandoned replan cannot resume the source cycle because its tasks have been irreversibly skipped.\n3. If worker execution is accidentally re-entered before supersession, the active goal contains terminal work that never satisfied its contract or evidence requirements.\n\nThe navigation/promotion divergence is exact. `next_action()` ignores all terminal tasks, reports failure only if one is `FAILED`, and otherwise returns `(goal, None)` ([navigation.py:36](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/src/domain/services/navigation.py:36), [navigation.py:45](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/src/domain/services/navigation.py:45), [navigation.py:56](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/src/domain/services/navigation.py:56)). Thus `{DONE, SKIPPED}` is interpreted as “closeable.” `Plan.peek_next()` delegates without adding cyclic semantics ([planner_orchestrator.py:209](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/src/domain/aggregates/planner_orchestrator.py:209)).\n\nCyclic promotion instead requires every task to be `DONE` and to contain verification evidence, both when reserving and after the external merge ([execution_handler.py:754](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/src/app/handlers/execution_handler.py:754), [execution_handler.py:810](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/src/app/handlers/execution_handler.py:810)). The handler catches the discrepancy and opens a block ([execution_handler.py:137](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/src/app/handlers/execution_handler.py:137), [execution_handler.py:707](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/src/app/handlers/execution_handler.py:707)), but a skipped task cannot take the advertised retry route and cannot become `DONE`. The hot loop is gone, but the state is still irreparable except by superseding the cycle.\n\nTreating skipped tasks as successful under option (a) would weaken the central cyclic guarantee that goal branches reach the cycle branch only after every task is done with accepted revision-bound evidence ([known-issues.md:54](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/docs/architecture/known-issues.md:54)). A human decision not to perform contracted work is a contract change and should produce a replacement draft/cycle, not evidence-free promotion.\n\n## Design plan\n\nChoose direction **(c), reinforced by (b): retain `SKIPPED` solely as a legacy iteration-history state, remove it from active cyclic execution, and make cyclic navigation and promotion share one strict eligibility predicate.**\n\nThe invariant should be:\n\n> For an active cycle, `(goal, promotion-ready)` is reachable if and only if every task is `DONE` with accepted, current-revision verification evidence. A `SKIPPED` task inside an active cycle is invalid abandoned-work state, never successful completion. Legacy navigation remains terminal/no-failure based.\n\n### 1. Separate cyclic and legacy replanning\n\nSplit `Plan.begin_replanning()` at its existing `active_cycle is None` boundary ([planner_orchestrator.py:483](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/src/domain/aggregates/planner_orchestrator.py:483)):\n\n- Preserve the legacy branch byte-for-byte: phase guard, pending root-goal/task skipping, pause clearing, and legacy phase transition.\n- In the cyclic branch, do not call `Task.skip()`, `Task.abandon()`, or `Goal.skip()` on either root goals or active-cycle goals. Retain the source cycle unchanged while the replacement proposal and draft are prepared.\n- Explicitly set the compatibility `phase` to `REPLANNING` and authoritative `status` to `WAITING`, instead of relying on `_set_phase()` to mutate both authorities. Continue clearing stale planning slots as introduced by un-freeze #10 ([planner_orchestrator.py:498](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/src/domain/aggregates/planner_orchestrator.py:498)).\n\nRemove the cyclic task-abandonment loop from `request_replan()` ([request_replan.py:46](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/src/app/use_cases/request_replan.py:46)). Replanning should revoke claimability through `PlanStatus.WAITING`; it should not rewrite the source cycle’s task outcomes.\n\nLate worker results still need their execution ledger marked abandoned, but cyclic stale-result paths should not convert the domain task to `SKIPPED`. Review `ExecutionHandler._abandon_stale()` and the other `abandon_execution_task()` callers at [execution_handler.py:643](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/src/app/handlers/execution_handler.py:643), [execution_handler.py:1122](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/src/app/handlers/execution_handler.py:1122), and [execution_handler.py:1301](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/src/app/handlers/execution_handler.py:1301). For cyclic work invalidated by replanning or supersession, close the execution attempt/run and emit abandonment telemetry without changing the historical task outcome. Keep `Plan.abandon_execution_task()` available for the legacy loop ([planner_orchestrator.py:179](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/src/domain/aggregates/planner_orchestrator.py:179)).\n\n`Task.skip()`, `Task.abandon()`, and `Goal.skip()` should remain for persisted legacy plans and legacy append-only history. Removing the enum or entity methods globally would be an unnecessary migration/API break. Their documentation should state that they are legacy iteration-abandonment transitions and are forbidden for active-cycle completion.\n\n### 2. Introduce one canonical cyclic promotion predicate\n\nAdd a pure domain predicate near navigation, such as `can_promote_goal(goal)`, whose definition is exactly:\n\n- every task has `status == Status.DONE`;\n- every task has accepted verification evidence valid for that task and current revision;\n- optionally centralize the evidence-validity detail in an accompanying diagnostic function so navigation can identify the first offending task.\n\nDo not merely test for a non-empty evidence list if the existing evidence model exposes revision/acceptance validity; the canonical predicate should express the actual accepted-evidence rule.\n\nUse this predicate in all three places:\n\n- cyclic `Plan.peek_next()`;\n- `_reserve_goal_promotion()`;\n- the post-merge revalidation in `_promote_goal()`.\n\nThis removes the duplicated comprehensions currently at [execution_handler.py:762](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/src/app/handlers/execution_handler.py:762) and [execution_handler.py:824](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/src/app/handlers/execution_handler.py:824).\n\n### 3. Give navigation an explicit invalid-completion result\n\nKeep `next_action(goals, now)` unchanged for legacy callers. Its current treatment of skipped history is required for old root-goal scans.\n\nFor active cycles, have `Plan.peek_next()` invoke a strict cyclic navigation variant or pass an explicit promotion policy. When no runnable task remains:\n\n- `FAILED` continues to yield `GOAL_FAILED`;\n- canonical promotion eligibility yields the existing promotion-ready result;\n- any other state—`SKIPPED`, evidence-less `DONE`, stale evidence—yields a distinct `GOAL_UNPROMOTABLE`/`INVALID_COMPLETION` result.\n\nUpdate `NextAction` accordingly ([navigation.py:10](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/src/domain/services/navigation.py:10)). `ExecutionHandler.handle()` should dispatch this result directly to the structured-block path rather than speculatively reserving promotion and catching `TaskFailed` ([execution_handler.py:137](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/src/app/handlers/execution_handler.py:137)).\n\nKeep reservation and post-merge checks despite navigation eligibility: they remain necessary transaction/concurrency guards. They should use the same predicate and retain their current failure behavior if state changes after selection.\n\nFor a persisted active cycle already containing `SKIPPED`, expose only `start_replan` as a truthful repair. Do not advertise retry or edit unless the corresponding transition can actually reopen that status. Evidence-less `DONE` should use an explicit redo/reopen resolution if supported; it should not masquerade as an editable pending task.\n\n### 4. Preserve legacy behavior exactly\n\nWhen `active_cycle is None`:\n\n- `begin_replanning()` continues to skip abandoned root work.\n- `commit_replanned_goals()` continues finalize-abandoning old iteration entries.\n- `set_iteration_goals()` continues preserving terminal history.\n- `next_action()` continues passing over `SKIPPED` tasks and permits a legacy goal with done/skipped, non-failed tasks to close.\n- `_complete_legacy_goal()` remains unchanged ([execution_handler.py:698](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/src/app/handlers/execution_handler.py:698)).\n\nNo persistence migration is required because `Status.SKIPPED` remains readable and meaningful for legacy and historical data.\n\n### 5. Limit `PlanPhase` compatibility side effects\n\nThis change touches the issue-#41 dual-authority area because cyclic `begin_replanning()` currently calls `_set_phase()`, which writes both compatibility `phase` and authoritative `PlanStatus` ([planner_orchestrator.py:144](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/src/domain/aggregates/planner_orchestrator.py:144)). In the cyclic branch, write `phase=REPLANNING` only as a compatibility projection and set `status=WAITING` explicitly. Do not broaden this work into removal of `PlanPhase`.\n\nCycle activation’s compatibility `_set_phase(ENRICHING)` call ([cyclic_planning.py:307](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/src/app/use_cases/cyclic_planning.py:307)) is adjacent debt but need not change for finding #3 unless the implementation establishes a general projection-only helper. Avoid an incidental global refactor.\n\n### 6. Test changes\n\nUpdate or add the following guards:\n\n- `test_aggregate_navigation.py`: retain the legacy skipped-task scan test at [test_aggregate_navigation.py:121](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/tests/unit/orchestration/test_aggregate_navigation.py:121); add cyclic-policy tests for fully evidenced `DONE`, `SKIPPED`, evidence-less `DONE`, stale evidence, and `FAILED`.\n- `test_execution_handler_unpromotable_goal.py`: change the regression from “reservation throws and is caught” to “strict navigation returns invalid completion and opens a block”; add a skipped-task case and assert only executable resolutions are advertised ([test_execution_handler_unpromotable_goal.py:40](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/tests/unit/orchestration/test_execution_handler_unpromotable_goal.py:40)).\n- `test_conversation_and_planning.py`: replace the assertion that cyclic replanning skips every active-cycle task ([test_conversation_and_planning.py:297](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/tests/unit/orchestration/test_conversation_and_planning.py:297)) with assertions that task/goal states remain unchanged while the plan reaches the un-freeze-#10 `WAITING` tuple and planning slots are retired.\n- `test_execution_safety.py`: replace the expected skipped task in the superseded-cycle late-result test ([test_execution_safety.py:289](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/tests/unit/execution/test_execution_safety.py:289)) with ledger/outbox abandonment plus unchanged historical task state.\n- `test_cyclic_project_plan.py`: extend replan activation coverage to prove the source cycle becomes `SUPERSEDED` atomically and its internal task statuses were not used as the supersession mechanism ([test_cyclic_project_plan.py:146](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/tests/unit/orchestration/test_cyclic_project_plan.py:146)).\n- Add cancellation/recovery coverage proving that abandoning a replacement draft leaves the active source cycle resumable rather than permanently skipped.\n- Keep all legacy transition and replan-loop tests at [test_transitions.py:55](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/tests/unit/orchestration/test_transitions.py:55) and [test_replan_loop.py:70](/workspaces/agent-orchestrator/.orchestrator/worktrees/skip-analysis/backend/tests/unit/orchestration/test_replan_loop.py:70) unchanged as the compatibility lock.\n\n### 7. Un-freeze and composition\n\nThis requires a narrow domain un-freeze because it changes aggregate replan semantics, cyclic navigation results, and stale-execution settlement. Scope it to:\n\n- cyclic `begin_replanning()` and `request_replan()`;\n- canonical goal-promotion eligibility;\n- cyclic navigation result typing;\n- cyclic stale-result abandonment;\n- associated orchestration/execution tests.\n\nIt composes directly with un-freezes #9 and #10. Un-freeze #9/#10 prevented repeated worker failure and established a coherent blocked/replanning root state; this change removes the underlying invalid cyclic task state and ensures navigation cannot again disagree with promotion. It preserves #10’s source-cycle retention and makes that retention meaningful: the source is frozen while replanning and is superseded only when replacement activation succeeds."}}
