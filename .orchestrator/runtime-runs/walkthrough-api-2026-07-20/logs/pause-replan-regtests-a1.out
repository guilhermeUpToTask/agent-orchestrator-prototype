{"type":"item.completed","item":{"id":"item_5","type":"command_execution","command":"/bin/bash -lc \"rg -n \\\"active_cycle|begin_replanning|request_pause|\\\\.pause\\\\(|_set_phase|PlanPhase\\\\.REPLANNING|env_factory\\\" backend/tests/unit/orchestration/test_cyclic_project_plan.py backend/tests/unit/orchestration/test_pause_resume.py backend/src/domain/aggregates/planner_orchestrator.py\"","aggregated_output":"backend/src/domain/aggregates/planner_orchestrator.py:132:            PlanPhase.REPLANNING.value: PlanStatus.WAITING,\nbackend/src/domain/aggregates/planner_orchestrator.py:144:    def _set_phase(self, phase: PlanPhase) -> None:\nbackend/src/domain/aggregates/planner_orchestrator.py:149:            PlanPhase.REPLANNING: PlanStatus.WAITING,\nbackend/src/domain/aggregates/planner_orchestrator.py:199:        cycle = self.active_cycle\nbackend/src/domain/aggregates/planner_orchestrator.py:264:    def request_pause(self, active_action: bool, reason: str | None = None) -> None:\nbackend/src/domain/aggregates/planner_orchestrator.py:271:            self.active_cycle is None and self.phase not in WORKER_CLAIMABLE_PHASES\nbackend/src/domain/aggregates/planner_orchestrator.py:296:        if self.active_cycle is None and self.phase not in WORKER_CLAIMABLE_PHASES:\nbackend/src/domain/aggregates/planner_orchestrator.py:311:            if self.active_cycle is not None or self.phase in WORKER_CLAIMABLE_PHASES\nbackend/src/domain/aggregates/planner_orchestrator.py:407:        self._set_phase(PlanPhase.RUNNING)\nbackend/src/domain/aggregates/planner_orchestrator.py:431:        self._set_phase(PlanPhase.FAILED)\nbackend/src/domain/aggregates/planner_orchestrator.py:439:        self._set_phase(to)\nbackend/src/domain/aggregates/planner_orchestrator.py:444:        self._set_phase(PlanPhase.RUNNING)\nbackend/src/domain/aggregates/planner_orchestrator.py:456:        self._set_phase(PlanPhase.DISCOVERY)\nbackend/src/domain/aggregates/planner_orchestrator.py:462:        self._set_phase(PlanPhase.REVIEW)\nbackend/src/domain/aggregates/planner_orchestrator.py:467:        self._set_phase(PlanPhase.DONE)\nbackend/src/domain/aggregates/planner_orchestrator.py:469:    def begin_replanning(self) -> None:\nbackend/src/domain/aggregates/planner_orchestrator.py:483:        if self.active_cycle is None:\nbackend/src/domain/aggregates/planner_orchestrator.py:484:            self._guard_phase({PlanPhase.RUNNING, PlanPhase.REVIEW}, PlanPhase.REPLANNING)\nbackend/src/domain/aggregates/planner_orchestrator.py:498:        self._set_phase(PlanPhase.REPLANNING)\nbackend/src/domain/aggregates/planner_orchestrator.py:524:        self._guard_phase({PlanPhase.REPLANNING}, PlanPhase.ARCHITECTURE)\nbackend/src/domain/aggregates/planner_orchestrator.py:537:        self._set_phase(PlanPhase.ARCHITECTURE)\nbackend/src/domain/aggregates/planner_orchestrator.py:554:    def active_cycle(self) -> Cycle | None:\nbackend/src/domain/aggregates/planner_orchestrator.py:637:        cycle = self.active_cycle\nbackend/src/domain/aggregates/planner_orchestrator.py:693:                self.active_cycle.id if self.active_cycle is not None else None\nbackend/src/domain/aggregates/planner_orchestrator.py:732:        self.status = PlanStatus.PAUSED if self.active_cycle is not None else PlanStatus.IDLE\nbackend/src/domain/aggregates/planner_orchestrator.py:798:        source = self.active_cycle\nbackend/src/domain/aggregates/planner_orchestrator.py:825:        self.status = PlanStatus.PAUSED if self.active_cycle is not None else PlanStatus.IDLE\nbackend/src/domain/aggregates/planner_orchestrator.py:840:        self.status = PlanStatus.PAUSED if self.active_cycle is not None else PlanStatus.IDLE\nbackend/src/domain/aggregates/planner_orchestrator.py:843:        cycle = self.active_cycle\nbackend/src/domain/aggregates/planner_orchestrator.py:857:        cycle = self.active_cycle\nbackend/tests/unit/orchestration/test_pause_resume.py:2:env_factory: the claim predicate must skip a paused plan